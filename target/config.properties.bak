##
# config.properties
##
server.session.timeout=3600

spring.thymeleaf.check-template-location = false
spring.thymeleaf.cache = false
spring.http.multipart.max-file-size=10MB
spring.http.multipart.max-request-size=10MB

management.port=8881
management.address=127.0.0.1
endpoints.shutdown.sensitive=false
endpoints.shutdown.enabled=true
endpoints.enabled=false
endpoints.info.enabled=true

spring.datasource.initialize=false
spring.datasource.type=com.zaxxer.hikari.HikariDataSource
spring.datasource.url=jdbc:postgresql://localhost:13306/OpManagerDB?charSet=UTF-8&prepareThreshold=1
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.username=postgres
spring.datasource.password=
spring.datasource.hikari.idleTimeout=10000  

mybatis.config=classpath:mybatis-config.xml

#system.language.locale=en_KR
system.language.locale=ko_KR
system.widget.pollinginterval=60000
system.floormap.directory=c://ManageEngine/CMS/floormaps/

# logback configuration
logging.level.org.springframework.web=INFO
logging.level.org.thymeleaf=INFO
logging.level.com.i52soft.lscable.cms=DEBUG
logging.file=logs/lscablecms.log

system.nms.ip4=http://localhost/
system.nms.port=80
system.nms.apiKey=77d0490433ac7113d890d727c6721403

system.message.portup.success=스위치 포트 UP을 요청하였습니다. 잠시 기다려 주십시오
system.message.portdown.success=스위치 포트 차단을 요청하였습니다. 잠시 기다려 주십시오
system.message.portup.failure=스위치 포트 UP에 실패하였습니다. 관리자에게 문의하여 주십시오
system.message.portdown.failure=스위치 포트 차단에 실패하였습니다. 관리자에게 문의하여 주십시오
