<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/frame-black.css" th:href="@{/css/frame-black.css}" />
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->

    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- Sparkline -->
    <script src="../../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <script type="text/javascript" th:inline="javascript">
        /*<![CDATA[*/
        document.addEventListener('DOMContentLoaded', function() {

            function getWidgetDataAPI(arg, callbackfnc) {
                $.ajax({
                    url: '/api/getWidgetDataAPI/' + arg,
                    dataType: 'text',
                    method: 'get',
                    success: function(data) {
                        callbackfnc(JSON.parse(data));
                    }
                });
            }
            getWidgetDataAPI("DevicesAvailability", callbackAPIInit);

            function callbackAPIInit(data) {
                var list = data.list;
                var arrayLength = list.length;
                var table_content = '<div class="box-header">\n' + '<h3 class="box-title">' + 
                [[#{dba}]] + '</h3>\n' + '</div>\n' + '<div class="box-body">\n' + '<table class="table devicetable">\n<thead>' + '<tr>\n' + '<th class="device-name">' + 
                [[[#{devicename}]] + '</th>\n' + '<th class="text-center">' + 
                [[[#{avail}]] + '</th>\n' + '</tr></thead>\n<tbody>'

                for (var i = 0; i < arrayLength; i++) {
                    table_content += '<tr>\n' + '<td>' + list[i].displayname + '</td>\n' + '<td>\n<div class="progress progress-xs">\n<div class="progress-bar progress-bar-success" role="progressbar" style="width:' + list[i].avail + '%;">\n</div>\n</div>\n</td>\n' + '<td class="text-center" id="device-avail">\n<span class="dev-val">' + list[i].avail + '</span>\n</td>\n' + '</tr>\n';
                }
                table_content += '</tbody>\n</table>\n</div>';
                $("#table_content").html(table_content);
            };
        });
        var avail = $('#device-avail').find('span').text();
        var val = Math.ceil(avail);
        /*<table class="table devicetable">
                    <thead>
                     <tr>
                       <th class="device-name" th:text="#{devicename}"></th>
                       <th th:text="#{avail}" class="text-center"></th>
                     </tr>
                     </thead>
                     <tbody>
                     <tr th:each="device : ${devices}">
                       <td th:text="${device.displayname}"></td>
                       <td>
                         <div class="progress progress-xs">
                           <div class="progress-bar progress-bar-success" role="progressbar" th:style="'width:' + ${device.avail} +'%;'"></div>
                         </div>
                       </td>
                       <td class="text-center" id="device-avail"><span class="dev-val" th:text="${device.avail}"></span></td>
                     </tr>
                    </tbody>
                   </table>*/
        /*]]>*/
    </script>
    <style>
        body {
            background-color: transparent;
        }
        .devicetable tbody {
            overflow: auto;
            font-size: 13px;
        }
        .table>thead>tr>th {
            border: 0px;
        }
        .device-name {
            width: 180px;
        }
        @media (max-width: 1800px) {
            .device-name {
                width: 120px;
            }
        }
    </style>
</head>

<body oncontextmenu="return false" ondragstart="return false" onselectstart="return false">
    <div id="table_content">
    </div>
</body>

</html>