package com.i52soft.lscable.cms.domain;

import com.fasterxml.jackson.annotation.JsonAutoDetect;
import com.fasterxml.jackson.annotation.JsonProperty;

import lombok.Data;

@Data
@JsonAutoDetect
public class EntityVO {

	public int getId() {
		return id;
	}
	public void setId(int id) {
		this.id = id;
	}
	public String getName() {
		return name;
	}
	public void setName(String name) {
		this.name = name;
	}
	public String getComments() {
		return comments;
	}
	public void setComments(String comments) {
		this.comments = comments;
	}
	public String getAsset_tag() {
		return asset_tag;
	}
	public void setAsset_tag(String asset_tag) {
		this.asset_tag = asset_tag;
	}
	public int getCategory_id() {
		return category_id;
	}
	public void setCategory_id(int category_id) {
		this.category_id = category_id;
	}
	public String getDisplayname() {
		return displayname;
	}
	public void setDisplayname(String displayname) {
		this.displayname = displayname;
	}
	public String getOpm_category() {
		return opm_category;
	}
	public void setOpm_category(String opm_category) {
		this.opm_category = opm_category;
	}
	public String getShape() {
		return shape;
	}
	public void setShape(String shape) {
		this.shape = shape;
	}
	public String getIp() {
		return ip;
	}
	public void setIp(String ip) {
		this.ip = ip;
	}
	public String getOpm_name() {
		return opm_name;
	}
	public void setOpm_name(String opm_name) {
		this.opm_name = opm_name;
	}
	@JsonProperty
	private int id;
	@JsonProperty
	private String name;
	@JsonProperty
	private String comments;
	@JsonProperty
	private String asset_tag;
	@JsonProperty
	private int category_id;
	@JsonProperty
	private String displayname;
	@JsonProperty
	private String opm_category;
	@JsonProperty
	private String shape;
	@JsonProperty
	private String ip;
	@JsonProperty
	private String opm_name;
}
