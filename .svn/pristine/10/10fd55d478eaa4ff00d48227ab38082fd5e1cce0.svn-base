<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" layout:decorator="layout/default8">

<head>
    <title>SimpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />

    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->
    <!-- jQuery 3 -->
    <script src="../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- AdminLTE App -->
    <script src="../static/js/adminlte.min.js" th:src="@{/js/adminlte.min.js}"></script>
    <!-- Sparkline -->
    <script src="../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <!-- SlimScroll -->
    <script src="../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <link rel="stylesheet" type="text/css" media="screen" href="../static/css/circle-styles.css" th:href="@{/css/circle-styles.css}" />
    <script src="../static/js/pages/dashboard2.js" th:src="@{/js/pages/dashboard2.js}"></script>

    <link rel="stylesheet" type="text/css" media="screen" href="../static/css/chartist.min2.css" th:href="@{/css/chartist.min2.css}" />
    <script>
        $(function() {
            $('.content').css('padding', '0px');
            $('#myTable').css('margin', '0px');
            var table = document.getElementById('myTable');
            table.deleteRow(0);
            var row1 = table.insertRow(0);
            var cell1 = row1.insertCell(0);
            cell1.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/circle" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell1).addClass('cell');
            cell1.colSpan = '1'
            var cell2 = row1.insertCell(1);
            cell2.innerHTML = '<div class="box box-gray"><div id="map-widget" style="height:630px;"> <iframe src="ht/preview-map-widget?widget_id=107" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            cell2.colSpan = '4'
            cell2.rowSpan = '3'
            $(cell2).addClass('map-cell');
            var cell3 = row1.insertCell(2);
            cell3.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/piechart" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>';
            $(cell3).addClass('cell');
            cell3.colSpan = '1'
            var row2 = table.insertRow(1);
            var cell7 = row2.insertCell(0);
            cell7.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/devicetable" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell7).addClass('cell');
            cell7.colSpan = '1'
            var cell12 = row2.insertCell(1);
            cell12.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/donutchart" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell12).addClass('cell');

            var row3 = table.insertRow(2);
            var cell13 = row3.insertCell(0);
            cell13.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/deviceusage" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell13).addClass('cell');
            var cell18 = row3.insertCell(1);
            cell18.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/event" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell18).addClass('cell');

            var row4 = table.insertRow(3);
            var cell19 = row4.insertCell(0);
            cell19.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/chartist" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell19).addClass('cell');
            var cell24 = row4.insertCell(1);
            cell24.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/RecentAlarmList" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell24).addClass('cell2');
            cell24.colSpan = '4'
            var cell25 = row4.insertCell(2);
            cell25.innerHTML = '<div class="box box-gray"><div class="box-control"><iframe src="frame1/chartist2" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%;"></iframe></div></div>'
            $(cell25).addClass('cell');
        });
    </script>
</head>

<body scroll="no">

    <div class="page-wrapper" layout:fragment="content">
        <div class="content-wrapper">
            <section class="content">
                <table class="table table-default" cellspacing="0" id="myTable">
                    <tr>
                    </tr>
                </table>
            </section>
        </div>
    </div>
</body>

</html>