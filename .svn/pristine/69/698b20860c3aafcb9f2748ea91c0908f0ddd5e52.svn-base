<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" layout:decorator="layout/default4">

<head>
    <title>simpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/system-black.css" th:href="@{/css/system-black.css}" />
    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->
    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- AdminLTE App -->
    <script src="../../static/js/adminlte.min.js" th:src="@{/js/adminlte.min.js}"></script>
    <!-- AdminLTE for demo purposes -->
    <script src="../../static/js/demo.js" th:src="@{/js/demo.js}"></script>
    <!-- Sparkline -->
    <script src="../../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <!-- SlimScroll -->
    <script src="../../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>
    <!-- ChartJS -->
    <script src="../../static/modules/Chart.js/Chart.js" th:src="@{/modules/Chart.js/Chart.js}"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="../../static/js/pages/dashboard2.js" th:src="@{/js/pages/dashboard2.js}"></script>
    <script type="text/javascript" th:inline="javascript">
        // 사이트 정보가지고오기 //
        /*<![CDATA[*/

        $(document).on("click", "#delete", function() {
            var siteid = $(this).attr('data-id');
            $(".modal-body #getSite_id").val(siteid);
            console.log(siteid);
        }); //삭제버튼 클릭시 모달바디에 데이터 뿌려주기

        $(document).on("click", "#deleteBtn", function() {

            var deleteresult = $("#deleteSite").serialize();
            console.log(deleteresult);
            $.ajax({
                url: '/api/htbackend/removeSite/' + $(".modal-body #getSite_id").val(),
                dataType: 'text',
                contentType: 'application/x-www-form-urlencoded',
                data: deleteresult,
                method: 'get',
                success: function success(r) {
                    alert('삭제완료');
                    $("#deleteSite").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            });
        }); /* 변경버튼 클릭시 ajax 방식으로 데이터 삭제 */
        $(document).on("click", "#linkage", function() {
            var siteid = $(this).attr('data-id');
            console.log(siteid);
            location.href = "../cms/linkage.html?id=" + siteid;
        });
        $(document).on("click", "#modify", function() {
            var siteid = $(this).attr('data-id');
            console.log(siteid);
            location.href = "../cms/modifySite.html?id=" + siteid;
        });
        $(document).on("click", "#view", function() {
            var siteid = $(this).attr('data-id');
            console.log(siteid);
            location.href = "../cms/view.html?siteid=" + siteid;
        });
        /*]]>*/
    </script>
	<style type="text/css">
        .table>thead>tr>th {
            padding: 10px 0;
            line-height: 32px;
        }
	</style>
</head>

<body>

    <div class="page-wrapper" layout:fragment="content">

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="panel-custom-wrap">
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="icon-menu-borderline">
                        <h3 th:text="#{siteopt}" class="title col-sm-6"></h3>
                        <ol class="breadcrumb no-margin-padding col-sm-6  text-right">
                            <li><a href="/cms/index" th:href="@{/cms/index.html}"><i class="fa fa-dashboard"  th:text="' '+#{cmsopt}"></i></a>
                            </li>
                            <li>
                                <a href="../cms/setting" th:href="@{../cms/setting.html}" th:text="#{adminpage}"></a>
                            </li>
                            <li class="active" th:text="#{siteopt}"></li>
                        </ol>
                    </div>
                </section>

                <!-- Main content -->
                <section class="content">
                    <div class="subpage-menu">
                        <div class="panel panel-wrap">
                            <div class="panel-heading">
                                <div class="panel-title">
                                    <span class="godo" th:text="#{site}+' '+#{list}"></span>
                                    <div class="main-btn pull-right">
                                        <a href="../cms/new" th:href="@{../cms/new.html}" class="btn btn-primary-custom"><i class="fa fa-plus" th:text="' '+#{newpage}"></i></a>
                                    </div>
                                </div>
                            </div>
                            <div class="panel panel-body">
                                <div class="table col-md-12">
                                    <table class="table table-striped text-center">
                                        <thead class="thead-catalog">
                                            <tr>
                                                <th th:text="#{id}" class="table-id" style="width:100px;">id</th>
                                                <th th:text="#{sitename}" style="width:200px;">사이트명</th>
                                                <th th:text="#{description}" style="width:300px;">설명</th>
                                                <th th:text="#{region}" style="width:100px;">지역</th>
                                                <th th:text="#{opt}" class="option-btn" style="width:300px;">설정</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- <th:each="prod:${prods}"> <th:text="${prod.Value}"> -->
                                            <tr th:each="getSite : ${Sitelist}" id="tabletr">
                                                <td th:text="${getSite['id']}" id="siteid">사이트아이디</td>
                                                <!-- style="display:none;" -->
                                                <td th:text="${getSite['name']}" id="sitename">구글 서울1</td>
                                                <td th:text="${getSite['description']}" id="regionname">서울 삼성동사옥</td>
                                                <td th:text="${getSite['region_name']}">대한민국 서울</td>
                                                <td>
                                                    <div class="btn-group" role="toolbar" aria-label="Toolbar with button groups">
                                                        <a class="btn btn-warning-custom" th:text="#{modify}" href="#" th:attr="data-id=${getSite['id']}" id="modify">수정</a>
                                                        <button type="button" class="btn btn-danger-custom" data-toggle="modal" data-target="#deleteSite" href="#deleteSite" id="delete" th:text="#{delete}" th:attr="data-id=${getSite['id']}">삭제</button>
                                                        <a class="btn btn-success-custom" th:text="#{connectmap}" href="#" th:attr="data-id=${getSite['id']}" id="linkage">배선도</a>
                                                        <a class="btn btn-info-custom" th:text="#{view}" href="#" th:attr="data-id=${getSite['id']}" id="view">조회</a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="modal fade" id="deleteSite" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                            </button>
                                            <h4 class="modal-title" id="myModalLabel" th:text="#{delete}">삭제</h4>
                                        </div>
                                        <div class="modal-body">
                                            <input type="hidden" id="getSite_id" />
                                            <span th:text="#{delmsg}">삭제하시겠습니까?</span>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-primary-custom" th:text="#{delete}" id="deleteBtn">삭제</button>
                                            <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- /.content -->
            </div>
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->
</body>

</html>