<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>simpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/system-white.css" th:href="@{/css/system-white.css}" />
    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->

    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- AdminLTE App -->
    <script src="../../static/js/adminlte.min.js" th:src="@{/js/adminlte.min.js}"></script>
    <!-- Sparkline -->
    <script src="../../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <!-- SlimScroll -->
    <script src="../../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>
    <!-- ChartJS -->
    <script src="../../static/modules/Chart.js/Chart.js" th:src="@{/modules/Chart.js/Chart.js}"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="../../static/js/pages/dashboard2.js" th:src="@{/js/pages/dashboard2.js}"></script>
    <!-- DataTables -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/datatables.net-bs/css/dataTables.bootstrap.min.css" th:href="@{/modules/datatables.net-bs/css/dataTables.bootstrap.min.css}" />
    <script src="../../static/modules/datatables.net/js/jquery.dataTables.min.js" th:src="@{/modules/datatables.net/js/jquery.dataTables.min.js}"></script>
    <script src="../../static/modules/datatables.net-bs/js/dataTables.bootstrap.min.js" th:src="@{/modules/datatables.net-bs/js/dataTables.bootstrap.min.js}"></script>

    <script type="text/javascript" th:inline="javascript">
        /*<![CDATA[*/

        var widgetData = [[${widgetData}]];
        var mainpage_id = widgetData[0].mainpage_id;
        var widgettype_id = widgetData[0].widgettype_id;
        var colspan = widgetData[0].colspan;
        var rowspan = widgetData[0].rowspan;
        var colindex = widgetData[0].colindex;
        var rowindex = widgetData[0].rowindex;
        var widget_id = widgetData[0].widget_id;
        var isfirst = true;
        var option_data = {};

        var save_msg = [[#{save}]];

        /*]]>*/
    </script>
    <script type="text/javascript">
        /*<![CDATA[*/

        $(document).on("click", "#testButton", function() {
            var url = 'http://' + location.hostname + $("#content_data").val();
            $('#embedsrcid').attr('src', url);
        });
        $(document).on("click", "#saveButton", function() {
            option_data.name = '';
            option_data.option = '';
            $.ajax({
                url: '/api/htbackend/saveMainPageWidget',
                dataType: 'text',
                contentType: 'application/json',
                data: JSON.stringify({
                    mainpage_id: mainpage_id,
                    widgettype_id: widgettype_id,
                    colindex: colindex,
                    rowindex: rowindex,
                    id: widget_id,
                    content_data: $("#content_data").val(),
                    option_data: JSON.stringify(option_data)
                }),
                method: 'post',
                success: function success(r) {

                    window.top.location.href = '/admin/setting2/modify.html?id=' + mainpage_id;
                    //window.top.location.href = window.parent.location.href;

                }
            });
        });
        $('.cell').css('width', colspan * 320 + 'px');
        $('.cell').css('height', rowspan * 214 + 'px');
        /*]]>*/
    </script>
    <style>
        body {
            background-color: transparent;
        }
        .critical {
            color: #ff0000;
        }
        .major {
            color: #ff7200;
        }
        .minor {
            color: #FCB543;
        }
        .warning {
            color: #08CBF9;
        }
    </style>
</head>

<body>

    <!-- Content Wrapper. Contains page content -->
    <div class="content-wrapper">
        <div class="panel-custom-wrap">

            <!-- Main content -->
            <section class="content row">
                <div class="subpage-menu col-sm-12">
                    <div class="panel panel-wrap row">
                        <div class="col-sm-3 no-left-padding">
                            <div class="panel panel-default">
                                <div class="panel-title"><span class="godo" th:text="#{embeddedwidget}">위젯에디터</span>
                                </div>
                                <div class="panel-body" style="height:250px; overflow:auto;">
                                    <form id="testForm">
                                        <textarea name="content_data" class="form-control" id="content_data" rows="8" style="resize: none;"></textarea>
                                    </form>
                                </div>
                            </div>
                            <div class="panel panel-default">
                                <div class="panel-title"><span class="godo" th:text="#{extraoption}"></span>
                                </div>
                                <div class="panel-body" style="height:250px; overflow:auto;">
                                    <form id="testForm">
                                        <input class="form-control" type="text" id="device_name" />
                                    </form>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-9 no-right-padding">
                            <div class="panel panel-default form-inline text-center" style="height:300px;">

                                <div class="box-header">

                                    <div class="form-group pull-right">
                                        <button class="btn btn-primary-custom" th:text="#{test}" id="testButton"></button>
                                        <button class="btn btn-primary-custom" th:text="#{save}" id="saveButton"></button>
                                    </div>
                                </div>
                                <!-- /.box-header -->

                                <div class="box-body box-body-custom2">
                                    <div class="cell" style="height:214px; width:308px; margin:auto; border:1px solid #eee; border-radius:10px;">
                                        <iframe id="embedsrcid" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%; border:1px solid #eee; border-radius:10px;">
                                        </iframe>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- /.content -->
        </div>
    </div>
    <!-- /.content-wrapper -->


</body>

</html>