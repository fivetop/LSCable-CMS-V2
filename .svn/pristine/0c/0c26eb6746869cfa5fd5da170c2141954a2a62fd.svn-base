package com.i52soft.lscable.cms.domain;

import com.fasterxml.jackson.annotation.JsonAutoDetect;
import com.fasterxml.jackson.annotation.JsonProperty;

import lombok.Data;

@Data
@JsonAutoDetect
public class PPInvalidVO {
	@JsonProperty
	private int linkage_connection_id ;
	@JsonProperty
	private int basispatchpanel_id ;
	@JsonProperty
	private int  x ;
	@JsonProperty
	private int  y ;
	@JsonProperty
	private int  nodeid ;
	@JsonProperty
	private int  portname;
	@JsonProperty
	private int  category_id ;
	public int getPortname() {
		return portname;
	}
	public void setPortname(int portname) {
		this.portname = portname;
	}
	public int getBasispatchpanel_id() {
		return basispatchpanel_id;
	}
	public void setBasispatchpanel_id(int basispatchpanel_id) {
		this.basispatchpanel_id = basispatchpanel_id;
	}
	public int getLinkage_connection_id() {
		return linkage_connection_id;
	}
	public void setLinkage_connection_id(int linkage_connection_id) {
		this.linkage_connection_id = linkage_connection_id;
	}
	public int getX() {
		return x;
	}
	public void setX(int x) {
		this.x = x;
	}
	public int getY() {
		return y;
	}
	public void setY(int y) {
		this.y = y;
	}
	public int getNodeid() {
		return nodeid;
	}
	public void setNodeid(int nodeid) {
		this.nodeid = nodeid;
	}
	public int getCategory_id() {
		return category_id;
	}
	public void setCategory_id(int category_id) {
		this.category_id = category_id;
	}
}
