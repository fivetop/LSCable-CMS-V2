<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" layout:decorator="layout/default6">

<head>
    <title>simpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/system-white.css" th:href="@{/css/system-white.css}" />
    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->
    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- SlimScroll -->
    <script src="../../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>

    <link rel="stylesheet" type="text/css" href="../../static/modules/DataTables-1.10.16/css/dataTables.bootstrap4.min.css" th:href="@{/modules/DataTables-1.10.16/css/dataTables.bootstrap4.min.css}" />
    <link rel="stylesheet" type="text/css" href="../../static/modules/Buttons-1.5.1/css/buttons.bootstrap4.min.css" th:href="@{/modules/Buttons-1.5.1/css/buttons.bootstrap4.min.css}" />
    <!--<script type="text/javascript" src="../../static/modules/jQuery-1.12.3/jquery-1.12.3.min.js" th:src="@{/modules/jQuery-1.12.3/jquery-1.12.3.min.js}"></script>-->
    <script type="text/javascript" src="../../static/modules/DataTables-1.10.16/js/jquery.dataTables.min.js" th:src="@{/modules/DataTables-1.10.16/js/jquery.dataTables.min.js}"></script>
    <script type="text/javascript" src="../../static/modules/DataTables-1.10.16/js/dataTables.bootstrap4.min.js" th:src="@{/modules/DataTables-1.10.16/js/dataTables.bootstrap4.min.js}"></script>
    <script type="text/javascript" src="../../static/modules/Buttons-1.5.1/js/dataTables.buttons.min.js" th:src="@{/modules/Buttons-1.5.1/js/dataTables.buttons.min.js}"></script>
    <script type="text/javascript" src="../../static/modules/Buttons-1.5.1/js/buttons.bootstrap4.min.js" th:src="@{/modules/Buttons-1.5.1/js/buttons.bootstrap4.min.js}"></script>
    <script type="text/javascript" src="../../static/modules/Buttons-1.5.1/js/buttons.html5.min.js" th:src="@{/modules/Buttons-1.5.1/js/buttons.html5.min.js}"></script>
    <script type="text/javascript" src="../../static/modules/datatables/JSZip-2.5.0/jszip.min.js" th:src="@{/modules/datatables/JSZip-2.5.0/jszip.min.js}"></script>


    <script type="text/javascript">
        /*<![CDATA[*/
        $('document').ready(function() {
            searchPortUsage_Table();
            //$("#searchBtn").prop("disabled", true);//로드 될시 검색버튼 비활성화
            $("#sel2").on("change", function() {
                // value 값으로 선택
                if ($("#sel2").val() !== 'NONE') {
                    //$("#searchBtn").prop("disabled",false);
                    $.ajax({
                        url: '/api/htbackend/getCMSFSubList?site_id=' + $("#sel2").val(),
                        dataType: 'text',
                        method: 'get',
                        success: function success(r) {
                            console.log(r);
                            var rspns = eval(r);
                            //fill country
                            $("#sel3 option").remove(); // Remove all <option> child tags.
                            $("#sel3").prepend( // Append an object to the inside of the select box
                                $("<option value='NONE'></option>") // Yes you can do this.
                                .text('--- Select ---')
                            );
                            $.each(rspns, function(index, item) { // Iterates through a collection
                                $("#sel3").append( // Append an object to the inside of the select box
                                    $("<option></option>") // Yes you can do this.
                                    .text(item.name)
                                    .val(item.id)
                                );
                            });
                        }
                    }); //ajax//

                } //else {$("#searchBtn").prop("disabled", true);};
            }); // 값이 변경 되는 경우 값이 none 이 아니면 검색 활성화

            $('#searchBtn').click(function() {
                searchPortUsage_Table();
            });
        }); //검색
        function searchPortUsage_Table() {

            PortUsage_Tables = null;
            if (PortUsage_Tables) PortUsage_Tables.destroy();
            var url = "/api/htbackend/retrievePortUsageRate?";
            url += 'type=' + $(":input:radio[name=radio]:checked").val();
            if ($("#sel2").val() && $("#sel2").val() !== 'NONE') {
                url += "&site_id=" + $("#sel2").val();
            } else {
                //$("#searchBtn").prop("disabled", true);
            };
            if ($("#sel3").val() && $("#sel3").val() !== 'NONE') {
                url += "&bld_entity_id=" + $("#sel3").val();
            }
            PortUsage_Tables = $('#cmsPortUsageListTable').DataTable({
                "lengthMenu": [
                    [15, 25, 50, -1],
                    [15, 25, 50, "All"]
                ],
                "pageLength": 15,
                "processing": true,
                //"order": [[ 2, 'asc' ]],
                "drawCallback": function() {
                    var api = this.api();
                    var rows = api.rows({
                        page: 'current'
                    }).nodes();
                    var last = null;
                    var groupadmin = [];
                    api.column(2, {
                        page: 'current'
                    }).data().each(function(group, i) {
                        if (last !== group) {
                            $($(rows).eq(i)).attr('id', i);
                            $($(rows).eq(i)).addClass('group_row');
                            $($(rows).eq(i)).find('.site_name').addClass('fa fa-angle-down arrow');
                            groupadmin.push(i);
                            last = group;
                        }
                    });
                    for (var k = 0; k < groupadmin.length; k++) {
                        // Code added for adding class to sibling elements as "group_<id>"  
                        $("#" + groupadmin[k]).nextUntil("#" + groupadmin[k + 1]).addClass(' group_' + groupadmin[k]);
                        if ($(".group_" + groupadmin[k]).hasClass('active')) {
                            $(".group_" + groupadmin[k]).removeClass('active');
                        }
                        $(".group_" + groupadmin[k]).addClass('hide');
                        // Code added for adding Toggle functionality for each group
                        $("#" + groupadmin[k]).on('click', function() {
                            var gid = $(this).attr("id");
                            $("#" + gid).find('.site_name').toggleClass('fa fa-angle-down');
                            $("#" + gid).find('.site_name').toggleClass('fa fa-angle-up');
                            if ($(".group_" + gid).hasClass('hide')) {
                                $(".group_" + gid).removeClass('hide').addClass('active');
                            } else {
                                $(".group_" + gid).removeClass('active').addClass('hide');
                            }
                        });
                    }

                },
                sAjaxDataProp: "",
                paging: true,
                ordering: false,
                info: false,
                destroy: true,
                searching: false,
                ajax: {
                    url: url,
                    type: 'get'
                }

                ,
                dom: 'Bfrtip',
                buttons: [{
                    extend: 'excel',
                    text: 'Excel',
                    className: 'exportExcel',
                    filename: 'CMS Entity List',
                    exportOptions: {
                        modifier: {
                            page: 'all'
                        }
                    }
                }, {
                    extend: 'csv',
                    text: 'CSV',
                    className: 'exportExcel',
                    filename: 'CMS Entity List',
                    exportOptions: {
                        modifier: {
                            search: 'none',
                            page: 'all'
                        }
                    }
                }],
                //엑셀 csv 파일은 데이터 테이블이 나온 후 버튼 생성.
                "columnDefs": [{
                    className: "site_name",
                    "targets": [0]
                }],
                columns: [
                    //{"data": "id"}
                    {
                        "data": "site_name"
                    }, {
                        "data": "bld_entity_name"
                    }, {
                        "data": "floor_entity_name"
                    }, {
                        "data": "area_entity_name"
                    }, {
                        "data": "total_port_cnt"
                    }, {
                        "data": "connected_cnt"
                    }, {
                        "data": "used_port_cnt"
                    }, {
                        "data": "available_port_cnt"
                    }, {
                        "data": "utilization_rate"
                    }
                ]
            });
            $(".dt-buttons").addClass('pull-right');
            /* $("#cmsEntityListTable_previous").closest("div").unwrap();
			    $("#cmsEntityListTable_previous").closest("div").addClass('col-sm-12');
			    $("#cmsEntityListTable_paginate").siblings("div").remove();
			    $("#cmsEntityListTable_paginate").css("text-align","center");
	    		$("#cmsEntityListTable_length").hide();*/
        };



        $(document).ready(function() {
            $.fn.dataTableExt.sErrMode = 'none';

            $('#cmsPortUsageListTable tbody').on('click', 'tr', function() {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                } //row 셀렉션
                else {

                    PortUsage_Tables.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');

                    var d = PortUsage_Tables.row(this).data();
                    console.log(d);
                    var host = window.location.hostname;
                    //var url = host+"/ht/viewing-site-tree.html?siteid=" + d.site_id + "&nodeid=" +d.id
                    var url = "/ht/viewing-site-tree.html?siteid=" + d.site_id + "&nodeid=" + d.id
                        //http://localhost:8080/ht/viewing-site-tree.html?siteid=38&nodeid=225
                        //window.open(url);
                }
            });
            $.ajax({
                url: '/api/htbackend/getCMSFSubList',
                dataType: 'text',
                method: 'get',
                success: function success(r) {
                    console.log(r);
                    var rspns = eval(r);
                    //fill country
                    $("#sel2 option").remove(); // Remove all <option> child tags.
                    $("#sel2").prepend( // Append an object to the inside of the select box
                        $("<option value='NONE'></option>") // Yes you can do this.
                        .text('--- Select ---')
                    );
                    $.each(rspns, function(index, item) { // Iterates through a collection
                        $("#sel2").append( // Append an object to the inside of the select box
                            $("<option></option>") // Yes you can do this.
                            .text(item.name)
                            .val(item.id)
                        );
                    });
                }
            }); //ajax//
        });

        /*]]>*/
    </script>
    <style>
        .table>thead>tr>th {
            padding: 12px 0;
            font-size: 16px;
            line-height: 30px;
        }
        .table>tbody>tr>td {
            padding: 9px;
            line-height: 30px;
            vertical-align: middle !important;
        }
        .group_row {
            cursor: pointer;
            background-color: #eaeaea !important;
        }
        .group_row * {
            font-weight: bold;
            vertical-align: middle;
            color: #686868;
        }
        .fa-angle-down:before,
        .fa-angle-up:before {
            float: left;
            padding: 0 10px;
            vertical-align: middle;
            font-weight: bold;
        }
        .table-hover>tbody>tr {
            cursor: pointer;
        }
        .dataTables_paginate {
            text-align: center!important;
        }
        .exportExcel {
            color: #eee;
            padding: 5px;
            background: #79b4c1;
            border: 1px solid #79b4c1;
            margin: 5px;
            cursor: pointer;
        }
        .exportExcel:hover,
        .exportExcel:active:focus {
            background: #4c8a96!important;
            border: 1px solid #4c8a96;
            color: #eee;
        }
        /* The container */
        
        .checkbox-wrapper {
            display: inline-block;
            position: relative;
            margin-bottom: 12px;
            margin: 0;
            padding: 2px 20px 8px 30px !important;
            cursor: pointer;
            font-size: 14px;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
        }
        /* Hide the browser's default radio button */
        
        .checkbox-wrapper input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }
        /* Create a custom radio button */
        
        .checkmark {
            position: absolute;
            top: 0;
            left: 0;
            height: 22px;
            width: 22px;
            background-color: #fff;
            border-radius: 50%;
            border: 1px solid #aaa;
        }
        /* On mouse-over, add a grey background color */
        
        .checkbox-wrapper:hover input ~ .checkmark {
            background-color: #ccc;
        }
        /* When the radio button is checked, add a blue background */
        
        .checkbox-wrapper input:checked ~ .checkmark {
            background-color: #fff;
        }
        /* Create the indicator (the dot/circle - hidden when not checked) */
        
        .checkmark:after {
            content: "";
            position: absolute;
            display: none;
        }
        /* Show the indicator (dot/circle) when checked */
        
        .checkbox-wrapper input:checked ~ .checkmark:after {
            display: block;
        }
        /* Style the indicator (dot/circle) */
        
        .checkbox-wrapper .checkmark:after {
            top: 4px;
            left: 4px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #2196F3;
        }
    </style>
</head>

<body>

    <div class="page-wrapper" layout:fragment="content">

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="panel-custom-wrap">
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="subpage-menu-border">
                        <h3 th:text="#{portUsage}" class="title col-sm-6"></h3>
                        <ol class="breadcrumb no-margin-padding col-sm-6  text-right">
                            <li><a href="/cms2/index" th:href="@{/cms2/index.html}"><i class="fa fa-dashboard" th:text="' '+#{cmsopt}"></i></a>
                            </li>
                            <li class="active" th:text="#{portUsage}"></li>
                        </ol>
                    </div>
                </section>
                <!-- Main content -->
                <section class="content row">
                    <div class="subpage-menu">
                        <div class="col-md-12 nopadding">
                            <div class="panel panel-default form-inline text-center" style="margin-bottom:8px; border:none;">
                                <div class="form-group input-custom">
                                    <label class="checkbox-wrapper"><span th:text="#{switchPortUsage}"></span>
                                        <input type="radio" checked="checked" name="radio" value="switch" id="Switch_Port" />
                                        <span class="checkmark"></span>
                                    </label>
                                    <label class="checkbox-wrapper"><span th:text="#{PPportUsage}"></span>
                                        <input type="radio" name="radio" id="P_port" value="patchpanel" />
                                        <span class="checkmark"></span>
                                    </label>
                                </div>
                                <div class="form-group input-custom">
                                    <label for="sel2" th:text="#{site}+' :'" style="margin: 0;"></label>
                                    <select id="sel2" name="sel2" class="form-control" style="width:180px; padding: 6px;"></select>
                                </div>
                                <div class="form-group input-custom">
                                    <label for="sel3" th:text="#{building}+' :'" style="margin: 0;"></label>
                                    <select id="sel3" name="sel3" class="form-control" style="width:130px; padding: 6px;"></select>
                                </div>
                                <div class="form-group input-custom">
                                    <button type="button" class="btn btn-success-custom btn-md" id="searchBtn">
                                        <i class="glyphicon glyphicon-search" th:text="' '+#{search}"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 nopadding">
                            <div class="panel panel-wrap" style="min-height:400px;">
                                <table class="table table-striped text-center table-hover" id="cmsPortUsageListTable" style="width: 100%;">
                                    <thead class="thead-search">
                                        <tr id="tableth">
                                            <th th:text="#{site}" rowspan="2" style="width: 15%;"></th>
                                            <th th:text="#{building}" rowspan="2" style="width: 15%;"></th>
                                            <th th:text="#{floor}" rowspan="2" style="width: 15%;"></th>
                                            <th th:text="#{area}" rowspan="2" style="width: 15%;"></th>
                                            <th th:text="#{total}+' '+#{portCnt}" rowspan="2" style="width: 10%;"></th>
                                            <th th:text="#{connected}+' '+#{portCnt}" rowspan="1" colspan="2" style="width: 10%;border-bottom: 0 !important;"></th>
                                            <th th:text="#{Unconnected}+' '+#{portCnt}" rowspan="2" style="width: 10%;"></th>
                                            <th th:text="#{usedPercentage}+'(%)'" rowspan="2" style="width: 10%;"></th>
                                        </tr>
                                        <tr>
                                            <th th:text="#{terminal}" style="width: 5%;border-radius:0!important;"></th>
                                            <th th:text="#{diagram}" style="width: 5%;border-radius:0!important;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr id="tabletr">
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- /.content -->
            </div>
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->
</body>

</html>