<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" layout:decorator="layout/default6">

<head>
    <title>simpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/system-white.css" th:href="@{/css/system-white.css}" />
    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->


    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- AdminLTE App -->
    <script src="../../static/js/adminlte.min.js" th:src="@{/js/adminlte.min.js}"></script>
    <!-- AdminLTE for demo purposes -->
    <script src="../../static/js/demo.js" th:src="@{/js/demo.js}"></script>
    <!-- Sparkline -->
    <script src="../../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <!-- SlimScroll -->
    <script src="../../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>
    <!-- ChartJS -->
    <script src="../../static/modules/Chart.js/Chart.js" th:src="@{/modules/Chart.js/Chart.js}"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="../../static/js/pages/dashboard2.js" th:src="@{/js/pages/dashboard2.js}"></script>
    <script type="text/javascript">
        /*<![CDATA[*/
        $(document).ready(function() {
            $.ajax({
                url: '/api/htbackend/getSubRegion',
                dataType: 'text',
                method: 'get',
                success: function success(r) {
                    console.log(r);
                    var rspns = eval(r);
                    //fill country
                    $("#country option").remove(); // Remove all <option> child tags.
                    $("#country").append( // Append an object to the inside of the select box
                        $("<option></option>") // Yes you can do this.
                        .text('--- Select ---')
                        .val('NONE')
                    );
                    $.each(rspns, function(index, item) { // Iterates through a collection
                        $("#country").append( // Append an object to the inside of the select box
                            $("<option></option>") // Yes you can do this.
                            .text(item.name)
                            .val(item.id)
                        );
                    });
                }
            }); //ajax//
            $('#country').on('change', function() {
                var selected = $(this).find("option:selected").val();
                $.ajax({
                    url: '/api/htbackend/getSubRegion/' + selected,
                    dataType: 'text',
                    method: 'get',
                    success: function success(r) {
                        console.log(r);
                        var rspns = eval(r);
                        //fill city
                        $("#city option").remove(); // Remove all <option> child tags.
                        $("#city option").append( // Append an object to the inside of the select box
                            $("<option></option>") // Yes you can do this.
                            .text('--- Select ---')
                            .val('NONE')
                        );
                        $.each(rspns, function(index, item) { // Iterates through a collection
                            $("#city").append( // Append an object to the inside of the select box
                                $("<option></option>") // Yes you can do this.
                                .text(item.name)
                                .val(item.id)
                            );
                        });
                    }
                }); //ajax// 
            }); //#country//
        });

        /*<![CDATA[*/
        $(document).on("click", "#createBtn", function() {
            var x = document.getElementById("createSite");
            var createresult = $("#createSite").serialize();
            var sitename = $("#createSite #name").val();

            var sitetreejson_data = "{" +
                "\"v\": \"6.1.8\"," +
                "\"p\": {" +
                "  \"autoAdjustIndex\": true," +
                "  \"hierarchicalRendering\": false" +
                "}," +
                "\"d\": [" +
                "  {" +
                "    \"c\": \"ht.Data\"," +
                "    \"i\": 4," +
                "    \"p\": {" +
                "      \"name\": \"" + sitename + "\"" +
                "    }," +
                "    \"a\": {" +
                "      \"name\": \"" + sitename + "\"," +
                "      \"type\": 86" +
                "    }" +
                "  }" +
                "]" +
                "}";
            createresult += '&sitetreejson_data=' + sitetreejson_data;
            console.log(createresult);
            console.log(sitename);
            $.ajax({
                url: '/api/htbackend/createCMSSite',
                dataType: 'text',
                contentType: 'application/x-www-form-urlencoded',
                data: createresult,
                method: 'post',
                success: function success(r) {
                    console.log(r);
                    site_id = JSON.parse(r).id;
                    $.ajax({
                        url: '/api/htbackend/registerCMSSiteRoot',
                        dataType: 'json',
                        contentType: 'application/json;charset=utf-8',
                        data: JSON.stringify({
                            entityParam: {
                                "name": sitename
                            },
                            siteTreeParam: {
                                "site_id": site_id,
                                "level": 0,
                                "level_rank": 1
                            }
                        }),
                        method: 'post',
                        success: function success(r) {
                            console.log(r);
                            var rspn = eval(r);
                            var sitetreejson_data = "{" +
                                "\"v\": \"6.1.8\"," +
                                "\"p\": {" +
                                "  \"autoAdjustIndex\": true," +
                                "  \"hierarchicalRendering\": false" +
                                "}," +
                                "\"d\": [" +
                                "  {" +
                                "    \"c\": \"ht.Data\"," +
                                "    \"i\": 4," +
                                "    \"p\": {" +
                                "      \"name\": \"" + sitename + "\"" +
                                "    }," +
                                "    \"a\": {" +
                                "      \"name\": \"" + sitename + "\"," +
                                "      \"type\": " + rspn.siteTreeParam.type_id + "," +
                                //" {  "+
                                " \"siteTreeParam\":{\"id\":" + rspn.siteTreeParam.id + "," +
                                " \"site_id\":" + rspn.siteTreeParam.site_id + "," +
                                " \"type_id\":" + rspn.siteTreeParam.type_id + "," +
                                " \"level\":0,\"level_rank\":1,\"entity_id\":" + rspn.siteTreeParam.entity_id +
                                " }," +
                                " \"entityParam\":{\"id\":" + rspn.entityParam.id + "," +
                                "  \"name\":\"" + rspn.entityParam.name + "\"," +
                                " \"category_id\":" + rspn.entityParam.category_id + "}} " +
                                //" }"+   		 				  		 				  
                                //"    }"+
                                "  }" +
                                "]" +
                                "}";
                            $.ajax({
                                url: '/api/htbackend/updateCMSSiteRoot/' + site_id,
                                dataType: 'text',
                                contentType: 'application/x-www-form-urlencoded',
                                data: 'sitetreejson_data=' + sitetreejson_data,
                                method: 'post',
                                success: function success(r) {
                                    console.log(r);
                                    //alert('생성완료');
                                    new window.frames[0].init(site_id);
                                    //history.back(-1); 	   				
                                }
                            });

                        }
                    });

                }
            });
        }); /* 생성버튼 클릭시 ajax 방식으로 데이터 인서트 */
        /*]]>*/
    </script>
</head>

<body>

    <div class="page-wrapper" layout:fragment="content">

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="panel-custom-wrap">
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="subpage-menu-border">
                        <h3 th:text="#{cmsnew}" class="title col-sm-6"></h3>
                        <ol class="breadcrumb no-margin-padding col-sm-6  text-right">
                            <li><a href="../cms2/setting" th:href="@{../cms2/setting.html}"><i class="fa fa-dashboard" th:text="' '+#{cmsopt}"></i></a>
                            </li>
                            <li><a href="../cms2/siteset" th:href="@{../cms2/siteset.html}" th:text="#{siteopt}">cms-siteset</a>
                            </li>
                            <li class="active" th:text="#{cmsnew}">cms-new</li>
                        </ol>
                    </div>
                </section>
                <!-- Main content -->
                <section class="content">
                    <div class="subpage-menu">
                        <form accept-charset="UTF-8" role="form" method="post" id="createSite">
                            <div class="row">
                                <div class="col-md-12 text-center">
                                    <div class="panel panel-default form-inline text-center">

                                        <div class="form-group input-custom">
                                            <label for="country" th:text="#{countryname}+' :'">country:</label>
                                            <select id="country" name="country" class="form-control">
                                            </select>
                                        </div>
                                        <div class="form-group input-custom">
                                            <label for="region_id" th:text="#{cityName}+' :'">city:</label>
                                            <select id="city" name="region_id" class="form-control">
                                            </select>
                                        </div>
                                        <div class="form-group input-custom">
                                            <label for="name" th:text="#{sitename}+' :'">site name:</label>
                                            <input id="name" name="name" type="text" class="form-control" />
                                        </div>
                                        <div class="form-group input-custom">
                                            <label for="description" th:text="#{description}+' :'">sub:</label>
                                            <input type="text" id="description" name="description" class="form-control" />
                                        </div>
                                        <div class="form-group input-custom">
                                            <button type="button" id="createBtn" class="btn btn-primary-custom btn-md" th:text="#{create}">만들기</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="panel panel-default form-inline">

                                        <div class="panel panel-body" style="height:920px; margin-bottom:0;" id="building-site-tree">
                                            <iframe src="/ht/building-site-tree" scrolling="no" frameborder="0" style="position: relative; height: 100%; width: 100%; border:1px solid #ddd;">
                                            </iframe>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </section>
                <!-- /.content -->
            </div>
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->

</body>

</html>