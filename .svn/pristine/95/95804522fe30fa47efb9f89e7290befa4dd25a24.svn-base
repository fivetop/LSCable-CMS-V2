	}, {
		key: 'handleCheckUnique',
		value: function handleCheckUnique() {
			var form = this.newCompForm,
			    name = this.newCompForm.v('name');

			if (name === undefined || util.trim(name) === '') {
				form.showError('Please enter a name');
				return;
			}
			this.ajaxCheckUnique().then(function (s) {
				loading.hide();
				if (s) {
					form.showError('Duplicate name');
				} else {
					form.showInfo('Unique name');
				}
			});
		}
	}, {
		key: 'ajaxCheckUnique',
		value: function ajaxCheckUnique(callback) {
			loading.show();
			return new Promise(function (resolve) {
				util.ajax({
					url: 'http://211.114.70.120:8080/api/htbackend/checkDuplicateName?siteid=' + siteid + '&name=' + name,
					success: function success(r) {
						if (r && r[0]) {
							resolve(r[0].Status);
						}
					}
				});
			});
		}
	}, {
		key: 'handleCreateTreeNode',
		value: function handleCreateTreeNode() {
			var _this3 = this;

			var form = this.newCompForm,
			    dialog = this.newCompDialog,
			    name = form.v('name'),
			    type = form.v('type'),
			    category = form.v('category');

			if (name === undefined || name === '') {
				form.showError('Please enter a name');
				return;
			}
			this.ajaxCheckUnique().then(function (s) {
				if (s) {
					_this3.newCompForm.showError('Duplicate name');
					return;
				}
				util.ajax({
					url: 'http://211.114.70.120:8080/api/htbackend/saveSiteTreeNodeDetail',
					type: 'post',
					dataType: 'json',
					data: JSON.stringify({
						site_id: siteid,
						type_id: type,
						name: name,
						category_id: category
					}),
					success: function success(r) {
						loading.hide();
						var htdata = _this3.createData({
							name: name, type: type
						}, _this3.treeView.sm().ld());

						dialog.hide();

						_this3.sm.ss(htdata);

						_this3.notifier.fire({
							kind: 'treeAdd',
							data: htdata
						});
					},
					error: function error(r) {
						debugger;
						loading.hide();
						tipWin.show('Server error');
					}
				});
			});
		}
	}, {
		key: 'createData',
		value: function createData(data, parent) {
			var self = this,
			    htData = new ht.Data(),
			    dm = this.treeView.dm();
			htData.a(data);
			htData.setName(data.name);
			if (parent) {
				htData.setParent(parent);
			}
			dm.add(htData);
			if (data.children) {
				data.children.forEach(function (d) {
					self.createData(d, htData);
				});
			}
			return htData;
		}
