			var _this4 = this;

			util.ajax({
				url: 'http://211.114.70.120:8080/api/htbackend/getSiteTreeModelData/' + siteid,
				success: function success(r) {
					if (r && r[0] && r[0].sitetreejson_data) {
						_this4.treeView.dm().deserialize(r[0].sitetreejson_data);
						_this4.treeView.expandAll();

						_this4.dm.mm(_this4.handleTreeUpdate, _this4);
						_this4.dm.mh(_this4.handleTreeUpdate, _this4);
						_this4.dm.md(_this4.handleTreeUpdate, _this4);
					}
				}
			});
		}
