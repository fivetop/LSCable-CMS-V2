					_this5.toolbar.iv();
				}
			});
		}
	}, {
		key: 'updateForm',
		value: function updateForm(type) {
			var self = this,
			    name = this.getNodeTypeNameById(type),
			    form = this.formMap[name],
			    ld = this.treeView.sm().ld();
			if (!form) {
				var clazz = formConfig[name];
				if (!clazz) {
					return;
				}
				var _form = new clazz(this, siteid, ld);
				this.formMap[name] = _form;
				this.splitView.setRightView(_form);
			}
			// if (name === 'Site') {

			// }
			return;
			if (type === FLOOR) {
				if (!this.floorBuild) {
					this.floorBuild = new FloorBuild(this);
				}
				this.floorBuild.setData(ld);
				this.splitView.setRightView(this.floorBuild.getHTView());
			} else if (type === RACK_SPACE) {
				if (!this.rackBuild) {
					this.rackBuild = new RackBuild(this);
				}
				this.rackBuild.setData(ld);
				this.splitView.setRightView(this.rackBuild.getHTView());
			} else if (type === L2_SWITCH || type === L3_SWITCH) {
				if (!this.switchBuild) {
					this.switchBuild = new SwitchBuild(this);
				}
				this.switchBuild.setData(ld);
				this.splitView.setRightView(this.switchBuild.getHTView());
			} else {
				if (!form) {
					var config = formConfig[name];
					if (!config) return;
					form = new FormPane();

					form.addFormItems(config, [0.1, 0.2, 0.6, 0.1], 28);
					if (type === PATCH_PANEL) {
						form.addRow(['', {
							button: {
								label: 'Managing Linkage',
								onClicked: function onClicked() {
									// todo
									location.href = 'http://www.hightopo.com';
								}
							}
						}, ''], [0.1, 0.1, 0.8], 32);
					} else if (type === AREA) {
						form.addRow(['', {
							button: {
								label: 'Define Area',
								onClicked: function onClicked() {
									// todo
									location.href = 'http://www.hightopo.com';
								}
							}
						}, ''], [0.1, 0.1, 0.8], 32);
					}

					form.addRow(['', {
						button: {
							label: 'Save',
							onClicked: self.handleSave.bind(self)
						}
					}, {
						button: {
							label: 'Remove',
							onClicked: self.remove.bind(self)
						}
					}, ''], [0.1, 80, 80, 0.1], 36);
					this.formMap[name] = form;
				}
				this.splitView.setRightView(form);
				form.setValues(ld.getAttrObject());
			}
		}
	}, {
		key: 'handleSave',
		value: function handleSave() {
			var self = this,
			    form = self.splitView.getRightView(),
			    ld = self.treeView.sm().ld(),
			    values = form.getValueObject();

			ld.a(values);
		}
