			comboBox.element.setValues(list.map(function (d) {
				return d.id;
			}));
			comboBox.element.setLabels(list.map(function (d) {
				return d.name;
			}));
			comboBox.element.setValue(list.length > 0 ? list[0].id : '');
		}
