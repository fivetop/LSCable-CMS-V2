	<insert id="insertMainPageWidgetLayout" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap" >
	   	INSERT INTO lscms_mainpage_widget(
    			mainpage_id, widget_id, title, widgettype_id, rowspan, colspan, rowindex, colindex)
    			VALUES (#{mainpage_id}, #{widget_id}, #{title}, 
    			(select widget_type from lscms_widget_sample where id=#{samplewidget_id}),
    			(select rowspan from lscms_widget_sample where id=#{samplewidget_id}),
    			(select colspan from lscms_widget_sample where id=#{samplewidget_id}),
    			#{rowindex}, #{colindex})
	</insert>		
	
	<update id="updateMainPageWidgetLayout"  parameterType="java.util.HashMap" >
		update lscms_mainpage_widget set
		<if test="samplewidget_id != null">
		widgettype_id=(select widget_type from lscms_widget_sample where id=#{samplewidget_id}),
		rowspan=(select rowspan from lscms_widget_sample where id=#{samplewidget_id}), 
		colspan=(select colspan from lscms_widget_sample where id=#{samplewidget_id}),		
		</if>		
		<if test="title != null">
		title=#{title}, 
		</if>	
		widget_id=#{widget_id}
		where mainpage_id=#{mainpage_id} and rowindex=#{rowindex} and colindex=#{colindex}
	</update>		
	
	<update id="resetMainPageWidget"  parameterType="java.util.HashMap" >
		update lscms_mainpage_widget set widget_id=null, title=null
		where widget_id=#{widget_id} and mainpage_id=#{mainpage_id}
	</update>	
	
	<select id="getCMSInfoForDevice" parameterType="java.lang.String" resultType="java.util.HashMap">	
		select b.site_id, b.id node_id from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c
		where 1=1
        and a.id=b.entity_id and b.site_id=c.id and c.is_deleted = False
		and a.is_deleted = False and a.opm_name is not null and a.opm_name=#{devicename} limit 1
	</select>

	<select id="getCompatibleWidgetForLayout" parameterType="int" resultType="java.util.HashMap">	
		select c.name mainpage_name, a.title, a.widget_id, b.widgettype_id from lscms_mainpage_widget a, lscms_widget b, lscms_mainpage c
		where a.widget_id=b.id and a.mainpage_id=c.id and a.mainpage_id not in (select mainpage_id from lscms_mainpage_widget where widget_id=#{widget_id})
		and b.widgettype_id=(select widget_type from lscms_widget_sample where id=#{samplewidget_id})
		and a.colspan=(select colspan from lscms_widget_sample where id=#{samplewidget_id})
		and a.rowspan=(select rowspan from lscms_widget_sample where id=#{samplewidget_id})
	</select>
	
	<select id="getMainPageWidgetData" parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		select 
		a.*, (select name from lscms_common_code where group_id = (select id from lscms_common_code where group_id is null and name='Mainpage Widget Type') and id=a.widgettype_id) widgettype, 
		b.content_data, b.option_data
		from lscms_mainpage_widget a left outer join lscms_widget b
		on a.widget_id=b.id
		where a.mainpage_id=#{mainpage_id}
		and a.rowindex=#{rowindex} and a.colindex=#{colindex}
	</select>
				
	<insert id="addManufacturer" useGeneratedKeys="true" keyProperty="id" parameterType="RegionVO">
		insert into lscms_cms_manufacturer (name)	
	    values(#{name})
	</insert>
	
	<update id="updateManufacturer" parameterType="RegionVO" >
		update lscms_cms_manufacturer 
		set name=#{name}
		where id=#{id}
	</update>		
				
	<delete id="deleteManufacturer" parameterType="int">
		delete from lscms_cms_manufacturer where id=#{id}
	</delete>	
	
	<select id="getAvailableDataProvider" parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		select id, name from lscms_cms_widget_dataprovider where widgettype_id=#{widgettype_id}
	</select>	
	
	<select id="getLinkageImageForType" parameterType="int" resultType="java.lang.String">	
		select image_linkage_connection from lscms_cms_category where type_id=#{type_id} and image_linkage_connection is not null and is_deleted=False order by id limit 1
	</select>	
		
	<select id="getMainpageWidgetTypeIDByName" resultType="int" parameterType="java.lang.String">	
		select id from lscms_common_code where group_id =(select id from lscms_common_code where group_id is null and name='Mainpage Widget Type') and name=#{typename} limit 1
	</select>	
		
	<select id="getDefaultMainPageID"  parameterType="java.util.HashMap" resultType="java.lang.Integer">
		select mainpage_id from lscms_systemuser_mainpage
		where
		is_default=True and systemuser_id = (select id from lscms_auth_systemuser where username=#{systemUserName})
	</select>		
				
