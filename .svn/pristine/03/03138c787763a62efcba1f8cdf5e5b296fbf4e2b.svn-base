<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.i52soft.lscable.cms.dao.HTBackendDao">
	
	<resultMap id="SampleWidgetVOMap" type="SampleWidgetVO">
	  	<id column="id"  property="id"  />
	  	<result column="widget_type"  property="widgetType"  /> 
	 	<result column="name"  property="name"  />  
	 	<result column="img"  property="img"  /> 
	 	<result column="colSpan"  property="colSpan"  />  
	 	<result column="rowSpan"  property="rowSpan"  /> 
	</resultMap>

	<select id="getAvailableWidgetForBuildingLayout" resultMap="SampleWidgetVOMap">
		select id, widget_type, name, img, colSpan, rowSpan from lscms_widget_sample
	</select>

	<insert id="insertWidgetForBuildingLayout" useGeneratedKeys="true" keyProperty="id" parameterType="SampleWidgetVO2" >
		INSERT INTO lscms_widget_sample (widget_type, name, img, colSpan, rowSpan) VALUES (#{widget_type}, #{name}, #{img}, #{colSpan}, #{rowSpan})
	</insert>
	
	<delete id="deleteWidgetForBuildingLayout" parameterType="int">
		delete from lscms_widget_sample where id=#{id}
	</delete>

	<select id="getWidgetTypeForMainPage" resultType="java.util.HashMap">
		SELECT id, name, description FROM lscms_common_code
		where group_id=(select id from lscms_common_code where name='Mainpage Widget Type')	
	</select>		
	
	<select id="getAvailableLayoutForBuildingLayout" resultType="java.lang.String">
		select name from lscms_common_code
		where group_id=(select id from lscms_common_code where group_id is null and name='Mainpage Layout')
	</select>		

	<select id="getAvailableLayoutForBuildingLayout2" resultType="java.util.HashMap">
		select * from lscms_common_code
		where group_id=(select id from lscms_common_code where group_id is null and name='Mainpage Layout')
	</select>

	<select id="getAvailableLayoutTheme" resultType="java.util.HashMap">
		select * from lscms_common_code
		where group_id=(select id from lscms_common_code where group_id is null and name='Mainpage Theme')
	</select>	
	
	<select id="getAvailableWidgetForLayoutSize" parameterType="java.lang.String" resultType="java.util.HashMap">
		select z.img, z.id samplewidget_id, y.id, y.name, y.description from (
		select * from lscms_widget_layout_size where layout_size = (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Widget Layout Size') and name=#{layoutsize})
		    ) x, lscms_common_code y, (
		 	select id, img, widget_type, colspan||'X'||rowspan size from lscms_widget_sample           
            ) z
		where x.widget_type = y.id	and z.widget_type=x.widget_type and z.size=#{layoutsize}			
	</select>	

	<select id="getAllWidgetTypeForSize" parameterType="java.lang.String" resultType="java.util.HashMap">
		select x.widget_type widgettype_id, y.name widgettype_name from (select * from lscms_widget_layout_size where 
		layout_size = (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Widget Layout Size') and name=#{layoutsize}	)
		) x, lscms_common_code y
		where x.widget_type=y.id		
	</select>	

	<update id="updateMainPageWidget" parameterType="MainPageWidgetVO" >
		UPDATE lscms_widget SET widgettype_id = #{widgettype_id}, content_data = #{content_data}, option_data = #{option_data} where id=#{id}
	</update>	
	
	<insert id="insertMainPageWidget" useGeneratedKeys="true" keyProperty="id" parameterType="MainPageWidgetVO" >
		INSERT INTO lscms_widget (widgettype_id, content_data, option_data) VALUES (#{widgettype_id}, #{content_data}, #{option_data})
	</insert>	
	
	<delete id="deleteMainPageWidget" parameterType="int">
		delete from lscms_widget where id=#{id}
	</delete>
	
	<select id="getMainPageWidgetModelData" parameterType="int" resultType="java.util.HashMap">
		select content_data, option_data from lscms_widget where id=#{id}
	</select>

	<select id="getAlarmStatusOfMapWidget" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		SELECT a.mapwidget_id::TEXT deviceName, 'SubMap' as type ,--, COALESCE(min(d.status), 5) status
        (select COALESCE(min(status), 5)  from lscms_cms_mapwidget_entity x left outer join lscms_cms_entity y
		    on x.entity_id = y.id
		    left outer join managedobject z
		    on y.opm_name=z.name
            where x.mapwidget_id=a.mapwidget_id) status
			FROM lscms_cms_mapwidget_hierarchy a
		 <if test="id gt 0">
		    where a.mapwidget_parent_id=#{id}
		 </if>   
		  union all  
		 SELECT distinct c.name deviceName, 'Device' as type, c.status
			FROM lscms_cms_mapwidget_entity a, lscms_cms_entity b, managedobject c
		    where a.entity_id = b.id
		    and b.opm_name=c.name
		  <if test="id gt 0">   
		    and a.mapwidget_id=#{id}   
		  </if>	
	</select>
		
	<insert id="insertDeviceIntoMapWidget" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_mapwidget_entity (mapwidget_id, entity_id, displayname) VALUES (#{widgetId}, #{deviceId}, #{displayName})
	</insert>	
		
	<delete id="deleteAllDeviceFromMapWidget" parameterType="int">
		delete from lscms_cms_mapwidget_entity where mapwidget_id=#{widgetId}
	</delete>	
		
	<insert id="insertSubMapWidgetIntoMapWidget" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_mapwidget_hierarchy (mapwidget_parent_id, mapwidget_id, type, displayname ) VALUES (#{widgetId}, #{submapId}, (select id from lscms_common_code where group_id = (select id from lscms_common_code where group_id is null and name='CMS Hierarchy Type') and name='MapWidget'), #{displayName})
	</insert>	
	
	<update id="updateMainPageLayoutToNull" parameterType="int" >
		update lscms_mainpage_widget set widget_id=null where widget_id=#{id}
	</update>	
	
	<delete id="deleteAllFromMapWidgetTree" parameterType="int">
		delete from lscms_cms_mapwidget_hierarchy where mapwidget_parent_id=#{widgetId} or mapwidget_id=#{widgetId}
	</delete>

	<delete id="deleteAllSubMapWidgetFromMapWidget" parameterType="int">
		delete from lscms_cms_mapwidget_hierarchy where mapwidget_parent_id=#{widgetId}
	</delete>			
			
	<select id="getDeviceId" parameterType="java.lang.String" resultType="java.lang.Integer">
		select id from lscms_cms_entity
		where 1=1
		and is_deleted = False and opm_name is not null and opm_name=#{deviceName} limit 1
	</select>
	
	<insert id="insertDeviceInfo" useGeneratedKeys="true" keyProperty="id" parameterType="DeviceParam" >
		INSERT INTO lscms_cms_entity(
		name, category_id, opm_category, displayname, opm_name)
		VALUES (#{deviceName}, #{productId}, #{opmCategory}, #{displayName}, #{deviceName})
	</insert>	
	
	<select id="getProductMapIcon" resultType="java.util.HashMap">
		select a.id product_id, a.name product_name, a.type_id type_id, b.name type_name, a.image_map image_map from lscms_cms_category a, lscms_common_code b
		where a.type_id=b.id and is_deleted is False and is_nms
	</select>
	
	<select id="getImagesForProduct" parameterType="int" resultType="java.util.HashMap">
		select  image_tree, image_default, image_map, image_rack_front, image_rack_rear, image_linkage_connection from lscms_cms_category 
        where id=#{id}
	</select>
	
	<delete id="deleteMapWidgetFromMapWidget" parameterType="int">
		delete from lscms_cms_mapwidget_hierarchy where mapwidget_parent_id is null and mapwidget_id=#{widgetId}
	</delete>
	
	<insert id="insertMapWidgetIntoMapWidget" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_mapwidget_hierarchy (mapwidget_parent_id, mapwidget_id, type, displayname) VALUES (null, #{widgetId}, (select id from lscms_common_code where group_id = (select id from lscms_common_code where group_id is null and name='CMS Hierarchy Type') and name='MapWidget'), #{displayName})
	</insert>	
		
	<select id="searchMapWidget" resultType="java.util.HashMap">
		select False "isSNMP", '' ipaddress, '' "statusStr", '' "prettyTime", displayname "displayName", False "isNew", '' "vendorName", '' as type, mapwidget_id "deviceName", '' "statusNum", '' "addedTime", '' "numericStatus", 0 "interfaceCount", '' "mapName", 'MapWidget' category, '' status from lscms_cms_mapwidget_hierarchy where mapwidget_parent_id is null
	</select>
	
	<select id="getProductTree" resultType="java.lang.String">
		select content_data from lscms_cms_product_tree
	</select>
	
	<delete id="deleteProductTree" >
		delete from lscms_cms_product_tree
	</delete>
		
	<update id="saveProductTree" parameterType="java.lang.String" >
		update lscms_cms_product_tree set content_data=#{content}
	</update>		
	
	<select id="getProductType" resultType="java.util.HashMap">
		select id, name, description from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type')
	</select>	
	
	<insert id="createMainPageLayout" useGeneratedKeys="true" keyProperty="id"  parameterType="MainPageLayoutVO" >
		INSERT INTO lscms_mainpage(
		name, description, layout, theme, creator_id, json_data)
		VALUES (#{name}, #{description}, #{layout}, #{theme},(select id from lscms_auth_systemuser where username=#{creator_name}), #{json_data});
	</insert>	
	
	<delete id="deleteAllDefaultTable" parameterType="int">
		delete from lscms_systemuser_mainpage where mainpage_id=#{id}
	</delete>
	
	<delete id="deleteAllDefaultAdminTable" parameterType="int">
		delete from lscms_systemuser_mainpage_admin_default where mainpage_id=#{id}
	</delete>
	
			
	<delete id="deleteAllWidgetFromMainPage" parameterType="int">
		delete from lscms_mainpage_widget where mainpage_id=#{id}
	</delete>

	<delete id="deleteWidgetFromMainPage" parameterType="java.util.HashMap">
		delete from lscms_mainpage_widget where mainpage_id=#{mainpage_id} and rowindex=#{rowindex} and colindex=#{colindex}
	</delete>	

	<delete id="deleteMainPageLayout" parameterType="int">
		delete from lscms_mainpage where id=#{id}
	</delete>
	
	<update id="updateMainPageLayout" parameterType="MainPageLayoutVO" >
		UPDATE lscms_mainpage SET name=#{name}, description=#{description}, 
		layout=#{layout}, theme=#{theme}, json_data=#{json_data}, last_updated=CURRENT_TIMESTAMP
		WHERE id=#{id}
	</update>		

	<update id="updateMainPageLayout2" parameterType="MainPageLayoutVO" >
		UPDATE lscms_mainpage SET description=#{description}, 
		last_updated=CURRENT_TIMESTAMP
		WHERE id=#{id}
	</update>		
	
	<insert id="insertWidgetIntoMainPage"  parameterType="java.util.HashMap" >
		INSERT INTO lscms_mainpage_widget(
		mainpage_id, widget_id, description, title, rowspan, colspan, rowindex, colindex)
		VALUES (#{mainpage_id}, #{widget_id}, #{description}, #{title}, #{rowspan}, #{colspan}, #{rowindex}, #{colindex})
	</insert>	

	<select id="getCIList" resultType="java.util.HashMap">
		SELECT a.id ci_id, b.name as ci_type, a.name ci_name, (select name from lscms_cms_manufacturer where id=a.manufacturer_id) manufacturer, a.model, a.description, a.dimensions, a.total_port
		FROM lscms_cms_category a, lscms_common_code b where a.type_id=b.id and a.is_deleted = False order by a.id
	</select>
	
	<select id="getProductInfo" parameterType="int" resultType="java.util.HashMap">
		SELECT a.id, a.type_id, a.name, a.description, a.image_tree, a.image_default, a.manufacturer_id, a.model, a.image_map, a.total_port, a.u_height, a.u_size, a.full_depth, a.image_rack_front, a.image_rack_rear, a.dimensions, a.image_linkage_connection, a.is_nms, a.is_product, b.image_rack_front image_rack_front3d, b.image_rack_rear image_rack_rear3d, a.rack_type_id 
		FROM lscms_cms_category a, lscms_cms_category_3d_texture b where a.id=b.category_id and a.type_id=#{type} and a.is_deleted = False	
	</select>

	<select id="getProductInfoByTypeName" parameterType="java.lang.String" resultType="java.util.HashMap">
		SELECT id, type_id, name, description, image_tree, image_default, manufacturer_id, model, image_map, total_port, u_height, u_size, full_depth, image_rack_front, image_rack_rear, dimensions, image_linkage_connection, is_nms, is_product, (select name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Rack Type') and id=rack_type_id) rack_type
		FROM lscms_cms_category where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where name='CMS Category Type') and name=#{type}) and is_deleted = False
	</select>	
	
	<select id="getManufacturer" resultType="java.util.HashMap">
		SELECT id, name
		FROM lscms_cms_manufacturer
	</select>
	
	<select id="getRackType" resultType="java.util.HashMap">
		select id, name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Rack Type')
	</select>
		
	<insert id="registerProduct" useGeneratedKeys="true" keyProperty="id" parameterType="ProductVO" >
		INSERT INTO lscms_cms_category(
		type_id, name, description, image_tree, image_default, manufacturer_id, model, image_map, total_port, u_height, u_size, full_depth, image_rack_front, image_rack_rear, dimensions, image_linkage_connection, is_product, is_nms, rack_type_id)
		VALUES (#{type_id}, #{name}, #{description}, #{image_tree}, #{image_default}, #{manufacturer_id}, #{model}, #{image_map}, #{total_port}, #{u_height}, #{u_size}, #{full_depth}, #{image_rack_front}, #{image_rack_rear}, #{dimensions}, #{image_linkage_connection}, #{is_product}, #{is_nms}, #{rack_type_id})
	</insert>

	<insert id="registerProduct2" useGeneratedKeys="true" keyProperty="id" parameterType="ProductVO" >
		INSERT INTO lscms_cms_category(
		type_id, name, description, image_tree, image_default, manufacturer_id, model, image_map, total_port, u_height, u_size, full_depth, image_rack_front, image_rack_rear, dimensions, image_linkage_connection, is_product, is_nms, rack_type_id)
		VALUES (
		(select id from lscms_common_code where group_id=(select id from lscms_common_code where name='CMS Category Type') and name=#{type_name}),
		#{name}, #{description}, #{image_tree}, #{image_default}, #{manufacturer_id}, #{model}, #{image_map}, #{total_port}, #{u_height}, #{u_size}, #{full_depth}, #{image_rack_front}, #{image_rack_rear}, #{dimensions}, #{image_linkage_connection}, #{is_product}, #{is_nms}, #{rack_type_id})
	</insert>	
	
	
	<update id="updateProduct" parameterType="ProductVO" >
		UPDATE lscms_cms_category 
		SET
		<if test="type_id gt 0">
		type_id=#{type_id}, 
		</if>
		<if test="name != null and name != ''">
		name=#{name},
		</if>
		<if test="description != null and description != ''">
		description=#{description}, 
		</if>	
		<if test="image_tree != null and image_tree != ''">
		image_tree=#{image_tree}, 
		</if>
		<if test="image_default != null and image_default != ''">
		image_default=#{image_default},
		</if>
		<if test="manufacturer_id gt 0">
		manufacturer_id=#{manufacturer_id},
		</if>
		<if test="rack_type_id gt 0">
		rack_type_id=#{rack_type_id},
		</if>		
		<if test="model != null and model != ''">
		model=#{model}, 
		</if>
		<if test="image_map != null and image_map != ''">
		image_map=#{image_map},
		</if>
		<if test="total_port gt 0">
		total_port=#{total_port}, 
		</if>
		<if test="u_height gt 0">
		u_height=#{u_height}, 
		</if>
		<if test="u_size gt 0">
		u_size=#{u_size}, 
		</if>
		<if test="full_depth != null">
		full_depth=#{full_depth},
		</if>																					
		<if test="image_rack_front != null and image_rack_front != ''">
		image_rack_front=#{image_rack_front}, 
		</if>
		<if test="image_rack_rear != null and image_rack_rear != ''">
		image_rack_rear=#{image_rack_rear}, 
		</if>
		<if test="dimensions != null and dimensions != ''">
		dimensions=#{dimensions}, 
		</if>				
		<if test="image_linkage_connection != null and image_linkage_connection != ''">
		image_linkage_connection=#{image_linkage_connection},
		</if>
		<if test="is_product != null">
		is_product=#{is_product},
		</if>
		<if test="is_nms != null">
		is_nms=#{is_nms},
		</if>
		last_updated=CURRENT_TIMESTAMP
		WHERE id=#{id}
	</update>
	
	<update id="deleteProduct" parameterType="int">
		update lscms_cms_category set
		is_deleted=True, last_updated=CURRENT_TIMESTAMP
		where id=#{id}
	</update>		
	
	<select id="getEndUser" resultType="java.util.HashMap">
		SELECT id, name, empno, string_agg(upper(mac_address::TEXT), ',') as mac_address, full_name, contact, email, asset_tag, host(reg_ip_address) as ip_address
		FROM lscms_view_enduser
        group by id, name, empno,  full_name, contact, email, asset_tag, reg_ip_address
	</select>

	<insert id="registerBulkEndUser_20181111" useGeneratedKeys="true" keyProperty="id" parameterType="EndUserVO" >
		INSERT INTO lscms_ipam_enduser( name, empno, mac_address, full_name, contact, email, asset_tag) values
        <foreach collection="list" item="user" separator=" , ">
            (#{user.name}, #{user.empno}, #{user.mac_address}::varchar, #{user.full_name}, #{user.contact}, #{user.email}, #{user.asset_tag})
        </foreach>
	</insert>	

	<insert id="registerBulkEndUser" useGeneratedKeys="true" keyProperty="id" parameterType="EndUserVO" >
		INSERT INTO lscms_ipam_enduser( name, empno, mac_address, full_name, contact, email, asset_tag, ip_address) values
        <foreach collection="list" item="user" separator=" , ">
            (#{user.name}, #{user.empno}, SUBSTR(#{user.mac_address}, 1, 17)::varchar, #{user.full_name}, #{user.contact}, #{user.email}, #{user.asset_tag}, #{user.ip_address}::INET)
        </foreach>
	</insert>	
	<insert id="insertEndUserMac" parameterType="java.util.HashMap" >
		INSERT INTO lscms_ipam_enduser_mac( mac_address, enduser_id) values
		(#{mac_address}, #{enduser_id})
	</insert>		
			
	<insert id="registerEndUser_20181111" useGeneratedKeys="true" keyProperty="id" parameterType="EndUserVO" >
		INSERT INTO lscms_ipam_enduser( name, empno, mac_address, full_name, contact, email, asset_tag)
		VALUES (#{name}, #{empno}, #{mac_address}::varchar, #{full_name}, #{contact}, #{email}, #{asset_tag})
	</insert>	
	
	<insert id="registerEndUser" useGeneratedKeys="true" keyProperty="id" parameterType="EndUserVO" >
		INSERT INTO lscms_ipam_enduser( name, empno, mac_address, full_name, contact, email, asset_tag, ip_address)
		VALUES (#{name}, #{empno}, SUBSTR(#{mac_address}, 1, 17)::varchar, #{full_name}, #{contact}, #{email}, #{asset_tag}, #{ip_address}::INET)
	</insert>	
		
	<update id="updateEndUser_20181111" parameterType="EndUserVO" >
		UPDATE lscms_ipam_enduser SET
		name=#{name}, empno=#{empno}, mac_address=#{mac_address}::varchar, full_name=#{full_name}, contact=#{contact}, email=#{email}, asset_tag=#{asset_tag}
		WHERE id=#{id}
	</update>	

	<update id="updateEndUser" parameterType="EndUserVO" >
		UPDATE lscms_ipam_enduser SET
		name=#{name}, empno=#{empno}, mac_address=SUBSTR(#{mac_address}, 1, 17)::varchar, full_name=#{full_name}, contact=#{contact}, email=#{email}, asset_tag=#{asset_tag}, ip_address=#{ip_address}::INET
		WHERE id=#{id}
	</update>	
		
	<delete id="deleteAllEndUser">
		delete from lscms_ipam_enduser
	</delete>	

	<delete id="deleteEndUser" parameterType="int">
		delete from lscms_ipam_enduser where id=#{id}
	</delete>	
		
	<delete id="deleteAllEndUserMac" >
		delete from lscms_ipam_enduser_mac
	</delete>	
			
	<delete id="deleteEndUserMac" parameterType="int">
		delete from lscms_ipam_enduser_mac where enduser_id=#{enduser_id}
	</delete>	
			
	<select id="getSystemUser" resultType="java.util.HashMap">
		SELECT c.systemuser_id, a.last_login, a.is_superuser, a.username, a.first_name, a.last_name, a.email, a.date_joined, a.fullname, c.group_id, b.name group_name
		FROM lscms_auth_systemuser a, lscms_auth_group b, lscms_auth_systemuser_groups c
        where a.id=c.systemuser_id and b.id=c.group_id
	</select>	
	
	<insert id="registerSystemUser" useGeneratedKeys="true" keyProperty="systemuser_id" parameterType="SystemUserVO" >
		INSERT INTO lscms_auth_systemuser (is_superuser, username, first_name, last_name, email, fullname)
		VALUES (False, #{username}, #{first_name}, #{last_name}, #{email}, #{fullname})
	</insert>
	
	<update id="updateSystemUser" parameterType="SystemUserVO" >
		UPDATE lscms_auth_systemuser SET
		username=#{username}, email=#{email}, fullname=#{fullname}
		WHERE id=#{systemuser_id}
	</update>	
	
	<delete id="deleteSystemUser" parameterType="int">
		delete from lscms_auth_systemuser where id=#{id}
	</delete>		
	
	<select id="getSystemUserNameById" parameterType="int" resultType="java.lang.String">
		SELECT username
		FROM lscms_auth_systemuser where id=#{id}
	</select>		
	
	<select id="getSystemGroup" resultType="java.util.HashMap">
		SELECT id, name
		FROM lscms_auth_group
	</select>		
	
	<insert id="registerSystemUserGroup" parameterType="SystemUserVO" >
		INSERT INTO lscms_auth_systemuser_groups (systemuser_id, group_id)
		VALUES (#{systemuser_id}, #{group_id})
	</insert>	
		
	<delete id="deleteSystemUserGroup" parameterType="int">
		delete from lscms_auth_systemuser_groups where systemuser_id=#{systemuser_id}
	</delete>	
	
	<delete id="deleteSystemUserMainpage" parameterType="int">
		delete from lscms_systemuser_mainpage where systemuser_id=#{systemuser_id}
	</delete>		

	<delete id="deleteSystemUserAdminMainpage" parameterType="int">
		delete from lscms_systemuser_mainpage_admin_default where systemuser_id=#{systemuser_id}
	</delete>			

	<select id="getSiteTreeModelData" parameterType="int" resultType="java.util.HashMap">
		SELECT id, sitetreejson_data
		FROM lscms_cms_site where id=#{id} and is_deleted=False
	</select>			
		
	<select id="getAvailableNodeTypeAsChild" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select a.parent_type, a.child_type, b.name from lscms_cms_sitetree_legimate_child a, lscms_common_code b
		where 1=1
	   <if test="type gt 0">
	     and a.parent_type=#{type}
	   </if>		
	   <if test="type == 0">
	     and a.parent_type is null
	   </if>
		and a.child_type=b.id
	</select>		
	<select id="getAvailableNodeTypeAllInOne" resultType="java.util.HashMap">
		select a.parent_type, a.child_type as type, b.name from lscms_cms_sitetree_legimate_child a, lscms_common_code b
		where 1=1	
		and a.child_type=b.id
	</select>	
	
	<select id="getProductByType" parameterType="int" resultType="java.util.HashMap">
		select a.id, a.name, a.description,
		a.image_tree, a.image_default, a.image_map, a.image_rack_front, a.image_rack_rear, a.image_linkage_connection,
		a.manufacturer_id, b.name manufacturer_name, a.model, 
		a.dimensions, a.is_product, a.is_nms, (select name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Rack Type') and id=a.rack_type_id) rack_type, 
		a.total_port, a.u_height, a.u_size, a.full_depth from lscms_cms_category a
		left outer join lscms_cms_manufacturer b on a.manufacturer_id=b.id
        where 1=1		
		and a.type_id=#{type} and a.is_deleted = False
	</select>		

	<select id="checkDuplicateName" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select 
		       CASE WHEN count(*) = 0 THEN False
		            ELSE True
		       END "Status"   
		from lscms_cms_entity a, lscms_cms_sitetree b
		where 1=1
		and b.entity_id=a.id
		and b.site_id=#{siteid}
		and a.name=#{name}	
	</select>	

	<select id="getCategoryID" parameterType="java.lang.String" resultType="java.lang.Integer">
		select * from lscms_cms_category where type_id = (
		select id from lscms_common_code 
		where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type') 
		and name=#{name}	limit 1
		   ) and is_deleted=False
	</select>	

	<select id="getTypeID" parameterType="java.lang.String" resultType="java.lang.Integer">
		select id from lscms_common_code 
		where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type') 
		and name=#{name}	
	</select>	
	
	<update id="updateCMSSiteRoot"  parameterType="java.util.HashMap" >
		update lscms_cms_site set sitetreejson_data=#{sitetreejson_data}
		where id=#{id}
	</update>

	<insert id="createCMSSite" useGeneratedKeys="true" keyProperty="id" parameterType="CMSSiteVO" >
		INSERT INTO lscms_cms_site(name, description, region_id, sitetreejson_data)
		VALUES (#{name}, #{description}, #{region_id}, #{sitetreejson_data})
	</insert>
	
	<select id="getSiteDetail" parameterType="int" resultType="java.util.HashMap">
		select a.id, a.name, a.description, a.region_id, b.name region_name, a.image_site, a.sitetreejson_data
		from lscms_cms_site a, lscms_cms_region b where 1=1
		and a.region_id=b.id
		and a.id=#{id} and a.is_deleted=False
	</select>
	
	<update id="saveSiteDetail" parameterType="CMSSiteVO" >
		update lscms_cms_site 
		set 
		<if test="name != null and name != ''">
		name=#{name},
		</if>
		<if test="description != null and description != ''">
		description=#{description},
		</if>
		<if test="region_id gt 0">
		region_id=#{region_id},
		</if>
		<if test="sitetreejson_data != null and sitetreejson_data != ''">
		sitetreejson_data=#{sitetreejson_data}, 
		</if>
		<if test="image_site != null and image_site != ''">
		image_site=#{image_site}, 
		</if>								
		last_updated=CURRENT_TIMESTAMP
		where id=#{id}
	</update>	
	
	<select id="getSubRegion" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		WITH RECURSIVE lscms_cms_region_tree (id, name, level, parent_id, level_rank) 
		AS ( 
		  SELECT
		    id, 
		    name, 
		    level, 
		    parent_id, 
		    level_rank
		  FROM lscms_cms_region 
		  WHERE parent_id is NULL and is_deleted=False	 
		  UNION ALL
		  SELECT
		    mn.id, 
		    mn.name, 
		    mn.level, 
		    mt.id, 
		    mn.level_rank 
		  FROM lscms_cms_region mn, lscms_cms_region mt 
		  WHERE mn.parent_id = mt.id and mt.is_deleted=False
		) 
		SELECT * FROM lscms_cms_region_tree 
		WHERE level >= 0 
	   <if test="parent_id gt 0">
	     and parent_id=#{parent_id}
	   </if>		
	   <if test="parent_id == 0">
	     and parent_id is null
	   </if>		
		ORDER BY level, parent_id, level_rank	
	</select>	
	
	<select id="checkDuplicateSystemUserId" parameterType="java.lang.String" resultType="java.util.HashMap">
		select 
		       CASE WHEN count(*) = 0 THEN False
		            ELSE True
		       END "Status"   
		from lscms_auth_systemuser
		where username=#{id}
	</select>	
	
	<select id="getSampleWidgetPreviewImage" parameterType="int"  resultMap="SampleWidgetVOMap">
		select id, widget_type, name, img, colSpan, rowSpan from lscms_widget_sample
		where id=#{id}
	</select>	
	
	<insert id="addRegion" useGeneratedKeys="true" keyProperty="id" parameterType="RegionVO" >
		insert into lscms_cms_region (name, level_rank, parent_id, level)		
	   <if test="parent_id gt 0">
	     values(#{name}, (select COALESCE(max(level_rank),0) +1 from lscms_cms_region where parent_id =#{parent_id}), #{parent_id}, (select (level)+1 from lscms_cms_region where id =#{parent_id}))
	   </if>
	   <if test="parent_id == 0">
	     values(#{name}, (select COALESCE(max(level_rank),0) +1 from lscms_cms_region where parent_id is null), null, 0)
	   </if>	
	</insert>
	
	<update id="updateRegion" parameterType="RegionVO" >
		update lscms_cms_region 
		set name=#{name}
		where id=#{id}
	</update>		
				
	<update id="deleteRegionSelf" parameterType="int">
		update lscms_cms_region set is_deleted=True where id=#{id}
	</update>	
	
	<select id="isRegionAvailableForDeletion" parameterType="int" resultType="int">
		select case when #{id} in 
		(		    
		    (
		    select region_id from lscms_cms_site where is_deleted=False
		    )
		    union all
		    select parent_id from lscms_cms_region where id in 
		    (
		    select region_id from lscms_cms_site where is_deleted=False
		    )
		) then 0
		else 1 end available 
	</select>	
		
	<update id="deleteRegionChildren" parameterType="int">
		update lscms_cms_region set is_deleted=True where parent_id=#{id}
	</update>	

	<select id="getAllRegion" resultType="java.util.HashMap">
		SELECT t1.id as country_id, t1.name as country_name, t2.id as city_id, t2.name as city_name
		FROM lscms_cms_region AS t1
		LEFT JOIN lscms_cms_region AS t2 ON t2.parent_id = t1.id
		where t1.parent_id is null and t1.is_deleted=False and t2.is_deleted=False
		order by t1.name
	</select>		
	
	<select id="getCMSSiteBySiteID" parameterType="int" resultType="java.util.HashMap">
    	select a.id, a.name, a.description, a.region_id, b.name region_name, a.image_site, a.sitetreejson_data
		from lscms_cms_site a, lscms_cms_region b
        where 1=1
		and a.region_id=b.id
		and a.id=#{id} and a.is_deleted=False
	</select>	
	
	<select id="getCMSSiteByID" parameterType="int" resultType="java.util.HashMap">
    	select a.id, a.name, a.description, a.region_id, b.name region_name, a.image_site, a.sitetreejson_data, c.systemuser_id
		from lscms_cms_site a, lscms_cms_region b, lscms_systemuser_cms_site c
        where 1=1
        and a.is_deleted=False
		and a.region_id=b.id
        and a.id=c.cms_site_id
		and c.systemuser_id=#{id}
	</select>	

	<select id="getCMSSite" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select * from 
        (select a.id, a.name, a.description, a.region_id, b.name region_name, a.image_site, a.sitetreejson_data
		from lscms_cms_site a, lscms_cms_region b --, lscms_systemuser_cms_site c
        where 1=1
		and a.region_id=b.id and a.is_deleted is False) x
        left outer join lscms_systemuser_cms_site y
        on x.id=y.cms_site_id
        where 1=1	         
	   <if test="systemUserRole != 'Administrators'">
	     and y.systemuser_id=(select id from lscms_auth_systemuser where username=#{systemUserName})
	   </if>        
	</select>	
	
	<update id="removeSite" parameterType="int">
		update lscms_cms_site set is_deleted=True, last_updated=CURRENT_TIMESTAMP where id=#{id}
	</update>		
	
	<update id="saveSiteTreeModelData" parameterType="java.util.HashMap">
		update lscms_cms_site 
		set sitetreejson_data=#{sitetreejson_data}, last_updated=CURRENT_TIMESTAMP 
		where id=#{siteid}
	</update>		
	
	<update id="updateEntityParam" parameterType="EntityVO">
		UPDATE lscms_cms_entity
		SET 
		<if test="name != null and name != ''">
		name=#{name},
		</if>
		<if test="comments != null and comments != ''">
		comments=#{comments},
		</if>
		<if test="asset_tag != null and asset_tag != ''">
		asset_tag=#{asset_tag},
		</if>
		<if test="category_id gt 0">
		category_id=#{category_id},
		</if>
		<if test="displayname != null and displayname != ''">
		displayname=#{displayname},
		</if>		
		<if test="opm_category != null and opm_category != ''">
		opm_category=#{opm_category},
		</if>	
		<if test="opm_name != null and opm_name != ''">
		opm_name=#{opm_name},
		</if>			
		<if test="shape != null and shape != ''">
		shape=#{shape},
		</if>		
		<if test="ip != null and ip != ''">
		ip=#{ip},
		</if>											
		last_updated=CURRENT_TIMESTAMP
		where id=#{id}
	</update>	
	
	<update id="updateSiteTreeParam" parameterType="SiteTreeVO">
		UPDATE lscms_cms_sitetree
		SET 
		<if test="site_id gt 0">
		site_id=#{site_id},
		</if>
		<if test="type_id gt 0">
		type_id=#{type_id},
		</if>
		<if test="level gte 0">
		level=#{level},
		</if>
		<if test="level_rank gt 0">
		level_rank=#{level_rank},
		</if>		
		<if test="parent_id gt 0">
		parent_id=#{parent_id},
		</if>
		<if test="entity_id gt 0">
		entity_id=#{entity_id},
		</if>
		last_updated=CURRENT_TIMESTAMP 
		where id=#{id}
	</update>	
	
	<insert id="insertEntityParam" useGeneratedKeys="true" keyProperty="id" parameterType="EntityVO" >
		INSERT INTO lscms_cms_entity(
		name, comments, asset_tag, category_id, displayname, opm_category, shape, ip, opm_name)
		VALUES (#{name}, #{comments}, #{asset_tag}, #{category_id}, #{displayname}, #{opm_category}, #{shape}, (select distinct ipaddress from topoobject where isnode='true' and name=#{opm_name}), #{opm_name})
	</insert>

	<insert id="insertSiteTreeParam" useGeneratedKeys="true" keyProperty="id" parameterType="SiteTreeVO" >
		INSERT INTO lscms_cms_sitetree(
		site_id, type_id, level, level_rank, parent_id, entity_id)
		VALUES (#{site_id}, #{type_id}, #{level}, #{level_rank}, #{parent_id}, #{entity_id})
	</insert>
	
	<select id="getSiteTreeNodeDetail" parameterType="int" resultType="java.util.HashMap">
		 SELECT X.*, Y.json_data, Z.name manufacturer_name FROM (
		 select a.id nodeid, a.site_id, a.type_id, a.level, a.level_rank, a.parent_id, a.entity_id, b.id entityid, b.name, b.comments, b.asset_tag, b.category_id, b.displayname, b.ip, b.created, b.last_updated, b.opm_category, b.opm_name, b.shape,
		 c.name ci_name, c.model, c.total_port, c.u_size, c.dimensions, c.manufacturer_id, c.u_height, c.full_depth, (select name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='Rack Type') and id=c.rack_type_id) rack_type
		 from lscms_cms_sitetree a, lscms_cms_entity b, lscms_cms_category c
		 where a.entity_id=b.id and b.category_id=c.id and a.id=#{id}) X 
		 LEFT OUTER JOIN lscms_cms_sitetree_placement Y ON X.nodeid=Y.sitetree_id
		 LEFT OUTER JOIN lscms_cms_manufacturer Z ON X.manufacturer_id=Z.id	
	</select>	
	
	<delete id="removeNode" parameterType="int">
		delete from lscms_cms_sitetree where id=#{id}
	</delete>				

	<insert id="insertSiteTreePlacement" useGeneratedKeys="true" keyProperty="id" parameterType="SiteTreePlacementVO" >
		INSERT INTO lscms_cms_sitetree_placement(
		sitetree_id, json_data)
		VALUES (#{sitetree_id}, #{json_data});
	</insert>

	<insert id="insertChildrenEntityIntoPlacement" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_sitetree_placement_entity(
		sitetree_placement_id, entity_id)
		VALUES (#{sitetree_placement_id}, #{entity_id});
	</insert>

	<insert id="insertRackspacePosition" parameterType="SiteTreeRackspacePositionVO" >
		INSERT INTO lscms_cms_sitetree_rackspace_position(
		sitetree_placement_id, sitetree_palcement_entity_id, position_rack, position_u, position_front)
		VALUES (#{sitetree_placement_id}, #{sitetree_palcement_entity_id}, #{position_rack}, #{position_u}, #{position_front});
	</insert>

	<insert id="insertRackspacePosition2" parameterType="SiteTreeRackspacePositionVO" >
		INSERT INTO lscms_cms_sitetree_rackspace_position(
		sitetree_palcement_entity_id, position_rack, position_u, position_front)
		VALUES (
		(select a.id from lscms_cms_sitetree_placement_entity a, 
		lscms_cms_entity b where b.id=a.entity_id
		and b.name=#{sitetree_palcement_entity_name}), #{position_rack}, #{position_u}, #{position_front});
	</insert>
	
	<select id="checkTypeMatch" resultType="int" parameterType="java.util.HashMap">
		select count(*) from lscms_common_code 
		where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
		and name = #{name}
		and id=#{type}
	</select>	
	
	<delete id="deleteRackspacePositionByNodeID" parameterType="int">
		delete from lscms_cms_sitetree_rackspace_position
		where sitetree_placement_id in (
		select id from lscms_cms_sitetree_placement 
		    WHERE sitetree_id=#{nodeid})
	</delete>		

	<delete id="deleteChildrenEntityFromPlacement" parameterType="int" >
		delete from lscms_cms_sitetree_placement_entity
		where sitetree_placement_id in (
		select id from lscms_cms_sitetree_placement
		    where sitetree_id=#{nodeid}
		)
	</delete>

	<delete id="deleteEntityFromPlacement" parameterType="int" >
		delete from lscms_cms_sitetree_placement_entity
		where entity_id=#{entityid}
	</delete>

	<delete id="deleteEntityFromRackspacePosition" parameterType="int" >
		delete from lscms_cms_sitetree_rackspace_position
		where sitetree_palcement_entity_id in (select id from lscms_cms_sitetree_placement_entity where entity_id=#{entityid})
	</delete>

	<delete id="deleteSiteTreePlacement" parameterType="int" >
		delete from lscms_cms_sitetree_placement
		where sitetree_id=#{nodeid}
	</delete>

	<update id="changeSiteTreeParentNode" parameterType="SiteTreeVO" >
		update lscms_cms_sitetree 
		set parent_id=#{parent_id},
		level_rank = (select COALESCE(max(level_rank),0) +1 from lscms_cms_sitetree where parent_id =#{parent_id}),
		level =(select (level)+1 from lscms_cms_sitetree where id =#{parent_id}),
		last_updated=CURRENT_TIMESTAMP 
		where id=#{id}
	</update>	

	<select id="getLinkageConnectionModelData" parameterType="int" resultType="java.util.HashMap">
		 select a.id, a.json_data from lscms_cms_linkage_connection a, lscms_cms_linkage_connection_patchpanel b, lscms_cms_sitetree c where a.id=b.linkage_connection_id and b.sitetree_id=c.id and c.type_id=(select id from lscms_common_code where 
		 group_id=(select id from lscms_common_code where name='CMS Category Type') and name='Patch Panel') and b.sitetree_id=#{id}
	</select>

	<select id="getLinkageConnectionIDByNodeID" parameterType="int" resultType="java.lang.Integer">
		 select (a.id) from lscms_cms_linkage_connection a, lscms_cms_linkage_connection_patchpanel b, lscms_cms_sitetree c where a.id=b.linkage_connection_id and b.sitetree_id=c.id and c.type_id=(select id from lscms_common_code where 
		 group_id=(select id from lscms_common_code where name='CMS Category Type') and name='Patch Panel') and b.sitetree_id=#{id} order by a.id desc
	</select>

	<select id="getLinkageConnectionModelData2" parameterType="int" resultType="java.util.HashMap">
		with originala as
		(
		    select a.*, d.id nodeid, b.name portname from 
			lscms_cms_linkage_connection_interface a, lscms_cms_interface b, lscms_cms_entity c, lscms_cms_sitetree d where a.interface_a_id=b.id and b.entity_id=c.id and c.id=d.entity_id and a.linkage_connection_id=#{connectionid}
		),
		originalb as
		(
		    select  a.*, d.id nodeid, b.name portname from 
			lscms_cms_linkage_connection_interface a, lscms_cms_interface b, lscms_cms_entity c, lscms_cms_sitetree d where a.interface_b_id=b.id and b.entity_id=c.id and c.id=d.entity_id and a.linkage_connection_id=#{connectionid}
		)
		select a.nodeid a_nodeid, a.portname a_portname, a.connector_id, b.nodeid b_nodeid, b.portname b_portname from originala a, originalb b where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id		
	</select>		

	<select id="getLinkageConnectionModelDataInvalid" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		 select  x, y, nodeid, port, category_id from lscms_cms_linkage_connection_invalid where linkage_connection_id=#{linkage_connection_id} and basispatchpanel_id=#{basispatchpanel_id} 
	</select>		

	<select id="deleteLinkageConnectionInvalid" parameterType="int">
		 delete from lscms_cms_linkage_connection_invalid where linkage_connection_id=#{connectionid}
	</select>	

	<insert id="insertLinkageConnectionInvalid" parameterType="PPInvalidVO" >
		INSERT INTO lscms_cms_linkage_connection_invalid(
		 linkage_connection_id, basispatchpanel_id, x, y, nodeid, port, category_id)
		VALUES (
		#{linkage_connection_id}, #{basispatchpanel_id}, #{x}, #{y}, #{nodeid}, #{port}, #{category_id});
	</insert>				

	<insert id="insertLinkageConnectionInvalidCable" parameterType="PPInvalidVO" >
		INSERT INTO lscms_cms_linkage_connection_invalid(
		 linkage_connection_id, basispatchpanel_id, x, y, category_id)
		VALUES (
		#{linkage_connection_id}, #{basispatchpanel_id}, #{x}, #{y}, #{category_id});
	</insert>	
	
	<insert id="insertLinkageConnectionInvalidDevice" parameterType="PPInvalidVO" >
		INSERT INTO lscms_cms_linkage_connection_invalid(
		 linkage_connection_id, basispatchpanel_id, x, y, nodeid, port)
		VALUES (
		#{linkage_connection_id}, #{basispatchpanel_id}, #{x}, #{y}, #{nodeid}, #{portname});
	</insert>						
		
	<select id="getLinkageConnectionDetail" parameterType="int" resultType="java.util.HashMap">
		select a.id nodeid, a.site_id, a.type_id, a.level, a.level_rank, a.parent_id, a.entity_id,
		b.id entityid, b.name, b.comments, b.asset_tag, b.category_id, b.displayname, b.created, b.last_updated, b.opm_category, b.shape, c.json_data
		from 
		lscms_cms_sitetree a, lscms_cms_entity b, lscms_cms_sitetree_placement c
		where a.entity_id=b.id and a.id=c.sitetree_id
		and a.id=#{id}
	</select>		
	
	<insert id="insertLinkageConnection" useGeneratedKeys="true" keyProperty="id" parameterType="LinkageConnectionVO" >
		INSERT INTO lscms_cms_linkage_connection(
		json_data )
		VALUES (#{json_data});
	</insert>	
	
	<insert id="insertPPIntoLinkageConnection" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_linkage_connection_patchpanel(
		linkage_connection_id, sitetree_id, is_basis)
		VALUES (#{linkage_connection_id}, #{sitetree_id}, #{is_basis});
	</insert>	
	
	<insert id="insertInterface" parameterType="InterfaceVO" >
		INSERT INTO lscms_cms_interface(
		name, entity_id, mac_address, mtu, ifindex, description, enabled)
		VALUES (#{name}, #{entity_id},
		#{mac_address}::varchar, #{mtu}, #{ifindex}, #{description}, True)
	</insert>	
	
	<update id="updateInterface" parameterType="InterfaceVO" >
		update lscms_cms_interface 
		set mac_address=#{mac_address}::varchar, ifindex=#{ifindex}, description=#{description}, enabled=True
		where name=#{name} and entity_id=#{entity_id}
	</update>	
	
	<insert id="insertLinkageConnectionDetail" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_linkage_connection_interface(
		linkage_connection_id, interface_a_id, connector_id, interface_b_id)
		VALUES (#{linkage_connection_id}, #{interface_a_id}, #{connector_id}, #{interface_b_id})
	</insert>	

	<insert id="insertLinkageConnectionSwitchTopoDetail" parameterType="java.util.HashMap" >
		INSERT INTO lscms_cms_linkage_connection_interface_switchtopo(
		linkage_connection_id, interface_a_id, connector_id, interface_b_id)
		VALUES (#{linkage_connection_id}, #{interface_a_id}, #{connector_id}, #{interface_b_id})
	</insert>		
			
	<update id="updateLinkageConnection" parameterType="LinkageConnectionVO" >
		UPDATE lscms_cms_linkage_connection
		SET json_data=#{json_data}
		where id=#{id}
	</update>		
		
	<delete id="deletePPFromLinkageConnection" parameterType="int" >
		delete from lscms_cms_linkage_connection_patchpanel
		where linkage_connection_id=#{linkage_connection_id}
	</delete>		
		
	<delete id="deleteInterface" parameterType="int" >
		delete from lscms_cms_interface where id in 
		(
		    (select interface_a_id interface_id from lscms_cms_linkage_connection_interface
		    where 
		        linkage_connection_id=#{linkage_connection_id}
		     ) 
		 union all
		     (select interface_b_id interface_id from lscms_cms_linkage_connection_interface
		    where 
		        linkage_connection_id=#{linkage_connection_id}
		     )
		)
	</delete>			
		
	<delete id="deleteLinkageConnectionDetail" parameterType="int" >
		delete from lscms_cms_linkage_connection_interface
		where linkage_connection_id=#{linkage_connection_id}
	</delete>		

	<delete id="deleteLinkageConnectionSwitchTopoDetail" parameterType="int" >
		delete from lscms_cms_linkage_connection_interface_switchtopo
		where linkage_connection_id=#{linkage_connection_id}
	</delete>	
			
	<delete id="removeLinkageConnection" parameterType="int" >
		delete from lscms_cms_linkage_connection
		where id=#{id}
	</delete>		
		
	<select id="getCableIcon" resultType="java.util.HashMap">
		select name, id, type_id, image_linkage_connection from lscms_cms_category
		where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where name='CMS Category Type') and name='Cable')
		and is_deleted is False
	</select>		

	<select id="checkDandDAvailability" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select 
		       CASE WHEN count(*) = 0 THEN True
		            ELSE False
		       END "Status"   
		from		(
		    (select interface_a_id interface_id from lscms_cms_linkage_connection_interface
		     ) 
		 union all
		     (select interface_b_id interface_id from lscms_cms_linkage_connection_interface
		     )
		) a, lscms_cms_interface b, lscms_cms_sitetree c
        where a.interface_id = b.id
        and b.entity_id=c.entity_id
        and b.name=#{portname}
        and c.id=#{nodeid}
	</select>			
		
	<select id="getTotalPortByCategory" parameterType="int" resultType="java.lang.Integer">
		select total_port from lscms_cms_category
		where id =#{category} and is_deleted is False
	</select>		
	
	<select id="getUHeightBuyEntityID" parameterType="java.lang.Integer" resultType="java.lang.Integer">
		select u_height from lscms_cms_entity a, lscms_cms_category b where a.category_id=b.id
		and a.id=#{id}
	</select>			
		
	<select id="getEntityIDFromSiteTreeByNodeID" parameterType="int" resultType="java.lang.Integer">
		select entity_id from lscms_cms_sitetree where id=#{id}
	</select>	
			
	<select id="getEntityInfoByNodeID" parameterType="int" resultType="java.util.HashMap">
		select a.id node_id, entity_id, type_id from lscms_cms_sitetree a, lscms_cms_entity b where a.entity_id=b.id and a.id=#{id} limit 1
	</select>				

	<select id="getEntityInfoByEntityID" parameterType="int" resultType="java.util.HashMap">
		select a.id node_id, entity_id, type_id from lscms_cms_sitetree a, lscms_cms_entity b where a.entity_id=b.id and b.id=#{id} limit 1
	</select>	
				
	<delete id="deleteInterfaceByNodeID" parameterType="int" >
		delete from lscms_cms_interface
		where entity_id=(select entity_id from lscms_cms_sitetree where id=#{id})
	</delete>			

	<update id="deleteEntityByNodeID" parameterType="int" >
		update lscms_cms_entity
		set is_deleted=True, last_updated=CURRENT_TIMESTAMP
		where id=(select entity_id from lscms_cms_sitetree where id=#{id})
	</update>			

	<update id="deleteChildrenEntityByNodeID" parameterType="int" >
		update lscms_cms_entity
		set is_deleted=True, last_updated=CURRENT_TIMESTAMP
		where id in (
			select b.entity_id from lscms_cms_sitetree_placement a, lscms_cms_sitetree_placement_entity b where a.id=b.sitetree_placement_id and a.sitetree_id=#{id}
		)
	</update>

	<delete id="deleteInterfaceByEntityID" parameterType="int" >
		delete from lscms_cms_interface
		where entity_id=#{entityid}
	</delete>			

	<update id="deleteEntityByEntityID" parameterType="int" >
		update lscms_cms_entity set
		is_deleted=True, last_updated=CURRENT_TIMESTAMP
		where id=#{entityid}
	</update>	
			
	<select id="getInterfaceID" resultType="int" parameterType="java.util.HashMap">
        SELECT id
	    FROM lscms_cms_interface WHERE name=#{name} AND entity_id=#{entity_id}
	</select>			
	
	<select id="getInterfaceIDByNodeID" resultType="int" parameterType="java.util.HashMap">
        SELECT a.id
	    FROM lscms_cms_interface a, lscms_cms_sitetree b WHERE A.entity_id=b.entity_id and a.name=#{name} AND b.id=#{nodeid}
	</select>			
		
	<select id="getL3Gateway" resultType="java.util.HashMap">
	<![CDATA[ 
		select distinct a.opm_name || '(' || a.ip || ')' as name, a.opm_name as id, a.ip, b.type_id
	 	from lscms_cms_entity a, lscms_cms_category b, lscms_cms_site c, lscms_cms_sitetree d where a.category_id=b.id and a.is_deleted=False and c.id=d.site_id and d.entity_id=a.id and c.is_deleted=False
		and b.type_id in (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name in ('Backbone Switch&Router', 'L3 Switch'))
		and a.opm_name is not null and a.opm_name || a.ip::TEXT like '%' ||  #{keyword} || '%'
	]]>
	</select>		

	<select id="getL2Switch" resultType="java.util.HashMap">
	<![CDATA[ 
		select distinct a.opm_name || '(' || a.ip || ')' as name, a.opm_name as id, a.ip, b.type_id
		from lscms_cms_entity a, lscms_cms_category b, lscms_cms_site c, lscms_cms_sitetree d where a.category_id=b.id and a.is_deleted=False and c.id=d.site_id and d.entity_id=a.id and c.is_deleted=False
		and b.type_id in (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name in ('L2 Switch'))
		and a.opm_name is not null and a.opm_name || a.ip::TEXT like '%' ||  #{keyword} || '%'
	]]>
	</select>			

	<select id="getNetworkL3Switch" parameterType="int" resultType="java.util.HashMap">
	<![CDATA[ 
		SELECT a.type_id , a.opm_name || '(' || host(a.ip) || ')' as name, a.opm_name as id, host(a.ip) ip FROM lscms_ipam_network_switch a
		WHERE a.type_id in (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name in ('Backbone Switch&Router', 'L3 Switch'))
        and a.network_id=#{networkid} 
	]]>        
	</select>
	
	<select id="getNetworkL2Switch" parameterType="int" resultType="java.util.HashMap">
		SELECT a.type_id , a.opm_name || '(' || host(a.ip) || ')' as name, a.opm_name as id, host(a.ip) ip FROM lscms_ipam_network_switch a
		WHERE a.type_id in (select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name in ('L2 Switch'))
        and a.network_id=#{networkid}
	</select>

	<select id="checkDuplicateIPAddress" parameterType="java.lang.String" resultType="java.util.HashMap">
		select id, description, is_deleted  
		from lscms_ipam_ipaddress
		where 1=1
		and address=#{ipaddress}::INET	
	</select>	

	<select id="getIPAddress" resultType="java.util.HashMap">
		SELECT id, created, last_updated, host(address) address, description
		FROM lscms_ipam_ipaddress where is_deleted=False
	</select>
	
	<insert id="registerIPAddress" useGeneratedKeys="true" keyProperty="id" parameterType="java.util.HashMap" >
		INSERT INTO lscms_ipam_ipaddress(
		address, description, network_id)
		VALUES (#{address}::INET, #{description}, #{network_id});
	</insert>	

	<update id="updateIPAddress" parameterType="java.util.HashMap" >
		UPDATE lscms_ipam_ipaddress SET
		<if test="address != null and address != ''">
		address=#{address}::INET,
		</if>	
		<if test="description != null and description != ''">
		description=#{description},
		</if>	
		<if test="is_deleted != null">
		is_deleted=#{is_deleted},
		</if>	
		<if test="network_id != null">	
		network_id= #{network_id},
		</if>								  
		last_updated=CURRENT_TIMESTAMP
		WHERE id=#{id}
	</update>	
	
	<update id="deleteIPAddress" parameterType="int">
		UPDATE lscms_ipam_ipaddress SET
		is_deleted=True, last_updated=CURRENT_TIMESTAMP
		WHERE id=#{ipid}
	</update>				
				
	<select id="getNetwork" resultType="java.util.HashMap">
		SELECT id, name, network, subnet, host(start_ipaddress) start_ipaddress, host(end_ipaddress) end_ipaddress, description
		FROM lscms_ipam_network where is_deleted=False
	</select>
	
	<insert id="registerNetwork" useGeneratedKeys="true" keyProperty="id" parameterType="NetworkVO" >
		INSERT INTO lscms_ipam_network(
			name, network, subnet, start_ipaddress, end_ipaddress, description)
			VALUES (#{name}, #{network}, #{subnet}, #{start_ipaddress}::INET, #{end_ipaddress}::INET, #{description});
	</insert>	
	
	<insert id="insertNetworkSwitch"  parameterType="NetworkSwitchVO" >
		INSERT INTO lscms_ipam_network_switch(
		network_id, type_id, opm_name, ip)
		VALUES (#{network_id}, #{type_id}, #{opm_name}, #{ip}::INET);
	</insert>	
		
	<delete id="deleteNetworkSwitch" parameterType="int" >
		delete from lscms_ipam_network_switch
		where network_id=#{id}
	</delete>			
		
	<update id="updateNetwork" parameterType="NetworkVO" >
		UPDATE lscms_ipam_network SET
		<if test="name != null and name != ''">
		name=#{name}, 
		</if>
		<if test="network != null and network != ''">
		network=#{network}, 
		</if>
		<if test="subnet != null and subnet != ''">
		subnet=#{subnet}, 
		</if>
		<if test="start_ipaddress != null and start_ipaddress != ''">
		start_ipaddress=#{start_ipaddress}::INET, 
		</if>
		<if test="end_ipaddress != null and end_ipaddress != ''">
		end_ipaddress=#{end_ipaddress}::INET, 
		</if>	
		<if test="description != null and description != ''">
		description=#{description},
		</if>										  
		last_updated=CURRENT_TIMESTAMP
		WHERE id=#{id}
	</update>	

	<update id="deleteNetwork" parameterType="int">
		UPDATE lscms_ipam_network SET
		is_deleted=True, last_updated=CURRENT_TIMESTAMP
		WHERE id=#{networkid}
	</update>	
		
	<select id="getNMSInterfaceInfo" parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		select z.parentnode switch_name, z.ifindex, z.ifspeed, z.ifdescr, z.ifspeedin, z.ifspeedout, z.ifname, replace(upper(z.physaddr), ' ', ':') macaddress from (
		select (ROW_NUMBER() OVER(ORDER BY a.ifindex)) AS ROWNUM, * from snmpinterface a, ipaddress b
		where a.name=b.name and a.physmedia=6 and not a.ifname like '%/0'
		and b.parentnode=#{switch_name}
		    ) z where z.ROWNUM = cast(#{portno} as int)
	</select>

	<select id="getConnectionDiagramTopDown" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		WITH RECURSIVE topdownsearchtree AS (
		  SELECT interface_a_id, ARRAY[interface_b_id,interface_a_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_b_id not in (select interface_a_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, topdownsearchtree.linkagepath || lscms_cms_linkage_connection_interface.interface_a_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, topdownsearchtree
		  WHERE lscms_cms_linkage_connection_interface.interface_b_id = topdownsearchtree.interface_a_id
		) 
		select x.*, y.idx from 
		( select t.*, z.name connectorname, z.image_linkage_connection connectorimage from
		(select a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
		 where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and a.id in (
		SELECT unnest(linkagepath) FROM topdownsearchtree 
		where interface_a_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname} )
		)) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id left outer join lscms_cms_category z on tt.connector_id = z.id) x, 
		(SELECT unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx
		 FROM topdownsearchtree 
		where interface_a_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname} )
		)y where x.ifid = y.ifid
		order by y.idx desc
	</select>	
	
	<select id="getConnectionDiagramEndUser" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select 
		0 ifid, 0 entityid, c.name devicename, 
		(select image_linkage_connection from lscms_cms_category where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='PC') and name='EndUser') deviceimage, 
		0 portname, upper(c.mac_address::TEXT) mac_address, null site_id, null node_id,
		null connectorname,
		(select image_linkage_connection from lscms_cms_category where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Cable')  and name='EndUser') connectorimage
		from lscms_ipam_accesslist a, lscms_view_enduser c
		where a.enduser_name = c.name and a.enduser_mac=c.mac_address and a.mac_address=#{switch_mac}::varchar
	</select>		

	<select id="getConnectionDiagramUnauthorized" parameterType="java.util.HashMap" resultType="java.util.HashMap">
	select 
		0 ifid, 0 entityid, zz.mac_address devicename, 
		(select image_linkage_connection from lscms_cms_category where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='PC') and name='UnauthorizedUser' ) deviceimage, 
		0 portname, zz.mac_address mac_address,  null site_id, null node_id,
		null connectorname,
		(select image_linkage_connection from lscms_cms_category where type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Cable')  and name='EndUser') connectorimage
		from
		lscms_view_connectioninfo zzzz,
		( 
			select x.* from
        	(
	        select  
			b.ip_address || '' as ip_address, upper(a.peer_mac_address) || '' as mac_address 
	        from lscms_mac_to_port a left join lscms_mac_to_ip b
			on a.peer_mac_address=b.mac_address
	        left join (select mac_address from lscms_view_enduser union all select mac_address from lscms_ipam_unmanaged) c 
			on a.peer_mac_address = upper(c.mac_address::TEXT)		
	        where c.mac_address is null 
            ) x left outer join (select distinct a.ip from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c where a.id=b.entity_id and b.site_id=c.id and c.is_deleted=False and a.is_deleted=False) y
            on x.ip_address = y.ip
            where y.ip is null               
		) zz
		where (zzzz.peer_mac_address)=zz.mac_address
        and zzzz.macaddress=#{switch_mac}::varchar
	</select>	        
        
	<select id="getConnectionDiagramBottomUp" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		WITH RECURSIVE bottomuptree AS (
		  SELECT interface_a_id, ARRAY[interface_a_id,interface_b_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_a_id not in (select interface_b_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, bottomuptree.linkagepath || lscms_cms_linkage_connection_interface.interface_b_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, bottomuptree
		  WHERE lscms_cms_linkage_connection_interface.interface_a_id = bottomuptree.interface_b_id
		) 
		select x.*, y.idx from 
		( select t.*, z.name connectorname, z.image_linkage_connection connectorimage from
		(select a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
		 where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and a.id in (
		SELECT unnest(linkagepath) FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname} )
		)) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id left outer join lscms_cms_category z on tt.connector_id = z.id) x, 
		(SELECT unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx
		 FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname} )
		)y where x.ifid = y.ifid
		order by y.idx
	</select>	

	<select id="getConnectionDiagramSwitchTopo2" parameterType="java.lang.String" resultType="java.util.HashMap">
		with originala as
		(
		    select a.*, d.id nodeid, b.name portname from 
			lscms_cms_linkage_connection_interface_switchtopo a, lscms_cms_interface b, lscms_cms_entity c, lscms_cms_sitetree d where a.interface_a_id=b.id and b.entity_id=c.id and c.id=d.entity_id and a.linkage_connection_id=#{linkage_connection_id}
		),
		originalb as
		(
		    select a.*, d.id nodeid, b.name portname from 
			lscms_cms_linkage_connection_interface_switchtopo a, lscms_cms_interface b, lscms_cms_entity c, lscms_cms_sitetree d where a.interface_b_id=b.id and b.entity_id=c.id and c.id=d.entity_id and a.linkage_connection_id=#{linkage_connection_id}
		),
        fullinfo as (
		select a.nodeid a_nodeid, a.portname a_portname, a.connector_id, b.nodeid b_nodeid, b.portname b_portname 
        from originala a, originalb b 
        where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id	
        )
        select a.a_nodeid from fullinfo a, fullinfo b
        where a.b_nodeid = b.a_nodeid
        
		with originala as
		(
            select e.*, a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id 
            from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d, lscms_cms_linkage_connection_interface_switchtopo e
		    where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and e.interface_a_id=a.id
		),
		originalb as
		(
            select e.*, a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id 
            from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d, lscms_cms_linkage_connection_interface_switchtopo e
		    where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and e.interface_b_id=a.id
        ),
        lvl1 as
        (
            select a.entityid entityid_a, a.devicename devicename_a, a.deviceimage deviceimage_a, a.portname portname_a, a.mac_address mac_address_a, a.site_id site_id_a, a.node_id node_id_a, a.connector_id, 
            b.entityid entityid_b, b.devicename devicename_b, b.deviceimage deviceimage_b, b.portname portname_b, b.mac_address mac_address_b, b.site_id site_id_b, b.node_id node_id_b
            from originala a, originalb b
            where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and b.node_id=58324 and b.portname='1'             
        ),
        lvl2 as
        (
            select a.entityid entityid_a, a.devicename devicename_a, a.deviceimage deviceimage_a, a.portname portname_a, a.mac_address mac_address_a, a.site_id site_id_a, a.node_id node_id_a, a.connector_id, 
            b.entityid entityid_b, b.devicename devicename_b, b.deviceimage deviceimage_b, b.portname portname_b, b.mac_address mac_address_b, b.site_id site_id_b, b.node_id node_id_b
            from originala a, originalb b, lvl1 c
            where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and b.node_id=c.node_id_a           
        )
        
        select * from lvl1
        union all
        select * from lvl2               
	</select>	

	<select id="getConnectionDiagramSwitchTopo" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		with originala as
		(
            select e.*, a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id 
            from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d, lscms_cms_linkage_connection_interface_switchtopo e
		    where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and e.interface_a_id=a.id
		),
		originalb as
		(
            select e.*, a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id 
            from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d, lscms_cms_linkage_connection_interface_switchtopo e
		    where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and e.interface_b_id=a.id
        )
		select  a.entityid, a.devicename, a.deviceimage, a.portname, a.mac_address, a.site_id, a.node_id, c.name connectorname, c.image_linkage_connection connectorimage 
        from originala a, originalb b, lscms_cms_category c
        where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and a.connector_id=c.id and a.node_id=#{nodeid} and a.portname=#{portname}
       union all 
		select  b.entityid, b.devicename, b.deviceimage, b.portname, b.mac_address, b.site_id, b.node_id, null connectorname, null connectorimage 
        from originala a, originalb b
        where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and a.node_id=#{nodeid} and a.portname=#{portname}   
        union all
		select  a.entityid, a.devicename, a.deviceimage, a.portname, a.mac_address, a.site_id, a.node_id, c.name connectorname, c.image_linkage_connection connectorimage 
        from originala a, originalb b, lscms_cms_category c
        where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and a.connector_id=c.id and b.node_id=#{nodeid} and b.portname=#{portname}
       union all 
		select  b.entityid, b.devicename, b.deviceimage, b.portname, b.mac_address, b.site_id, b.node_id, null connectorname, null connectorimage 
        from originala a, originalb b
        where a.interface_a_id=b.interface_a_id and a.interface_b_id=b.interface_b_id and b.node_id=#{nodeid} and b.portname=#{portname}           
 	</select>       
        

	<select id="getConnectionDiagramTopDownIPAM" parameterType="java.lang.String" resultType="java.util.HashMap">
		WITH RECURSIVE topdownsearchtree AS (
		  SELECT interface_a_id, ARRAY[interface_b_id,interface_a_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_b_id not in (select interface_a_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, topdownsearchtree.linkagepath || lscms_cms_linkage_connection_interface.interface_a_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, topdownsearchtree
		  WHERE lscms_cms_linkage_connection_interface.interface_b_id = topdownsearchtree.interface_a_id
		) 
		select x.*, y.idx from 
		( select t.*, z.name connectorname, z.image_linkage_connection connectorimage from
		(select a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
		 where a.entity_id=b.id and b.category_id=c.id and b.id=d.entity_id and a.id in (
             select unnest(linkagepath) from (
		SELECT * FROM topdownsearchtree 
		where interface_a_id in (select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b, lscms_cms_sitetree c, lscms_cms_site d where a.id=c.entity_id and c.site_id=d.id and d.is_deleted=False and a.is_deleted=False and a.id=b.entity_id and  b.mac_address is not null and b.mac_address=(select a.mac_address from lscms_ipam_accesslist a, lscms_view_enduser b where a.enduser_name=b.name and a.enduser_mac=b.mac_address and upper(b.mac_address::TEXT)=#{mac_address}))
		limit 1 ) q ) ) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id left outer join lscms_cms_category z on tt.connector_id = z.id) x, 
		( select unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx from (
         SELECT *
		 FROM topdownsearchtree 
		where interface_a_id in (select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b, lscms_cms_sitetree c, lscms_cms_site d where a.id=c.entity_id and c.site_id=d.id and d.is_deleted=False and a.is_deleted=False and a.id=b.entity_id and  b.mac_address is not null and b.mac_address=(select a.mac_address from lscms_ipam_accesslist a, lscms_view_enduser b where a.enduser_name=b.name and a.enduser_mac=b.mac_address and upper(b.mac_address::TEXT)=#{mac_address}))
		limit 1 ) qq ) y where x.ifid = y.ifid 
		order by y.idx desc
	</select>	

	<select id="getConnectionDiagramBottomUpIPAM" parameterType="java.lang.String" resultType="java.util.HashMap">
		WITH RECURSIVE bottomuptree AS (
		  SELECT interface_a_id, ARRAY[interface_a_id,interface_b_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_a_id not in (select interface_b_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, bottomuptree.linkagepath || lscms_cms_linkage_connection_interface.interface_b_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, bottomuptree
		  WHERE lscms_cms_linkage_connection_interface.interface_a_id = bottomuptree.interface_b_id
		) 
		select x.*, y.idx from 
		( select t.*, z.name connectorname, z.image_linkage_connection connectorimage from
		(select a.id ifid, b.id entityid, b.name devicename, c.image_linkage_connection deviceimage, a.name portname, upper(a.mac_address::TEXT) mac_address, d.site_id, d.id node_id from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
		 where a.entity_id=b.id and b.category_id=c.id  and b.id=d.entity_id and a.id in (
             select unnest(linkagepath) from (
		SELECT * FROM bottomuptree 
		where interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b, lscms_cms_sitetree c, lscms_cms_site d where a.id=c.entity_id and c.site_id=d.id and d.is_deleted=False and a.is_deleted=False and a.id=b.entity_id and  b.mac_address is not null and b.mac_address=(select a.mac_address from lscms_ipam_accesslist a, lscms_view_enduser b where a.enduser_name=b.name and a.enduser_mac=b.mac_address and upper(b.mac_address::TEXT)=#{mac_address}))
		limit 1 ) q ) ) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id left outer join lscms_cms_category z on tt.connector_id = z.id) x, 
		( select unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx from (
         SELECT *
		 FROM bottomuptree 
		where interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b, lscms_cms_sitetree c, lscms_cms_site d where a.id=c.entity_id and c.site_id=d.id and d.is_deleted=False and a.is_deleted=False and a.id=b.entity_id and  b.mac_address is not null and b.mac_address=(select a.mac_address from lscms_ipam_accesslist a, lscms_view_enduser b where a.enduser_name=b.name and a.enduser_mac=b.mac_address and upper(b.mac_address::TEXT)=#{mac_address}))
		limit 1 ) qq ) y where x.ifid = y.ifid 
		order by y.idx desc
	</select>	
	
	<select id="getOutletUsageHistory" parameterType="java.util.HashMap" resultType="java.util.HashMap">
	select z.entity_name switch_name, 
     	(zzz.ip) switch_ip, 
        zzz.asset_tag switch_asset_tag,
         z.port_no switch_port_no,
         z.ifindex switch_ifindex,  
         upper(zz.mac_address::TEXT) switch_mac_address,
         host(zz.ip_address) enduser_ip_address,
         upper(zz.clientmac::TEXT) enduser_mac_address, 
         zz.enduser_name,
         zz.enduser_asset_tag,
         to_char(zz.access_time, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
         null as access_end
		from
		lscms_view_cmsinfo_interface z,
		( select a.*, b.mac_address clientmac, b.asset_tag enduser_asset_tag from
		lscms_ipam_accesslist a left outer join lscms_view_enduser b
		on (a.enduser_name = b.name and a.enduser_mac=b.mac_address )
		) zz, lscms_cms_entity zzz, lscms_cms_sitetree e, lscms_cms_site f
		where (z.mac_address)=(zz.mac_address) and zzz.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and zzz.is_deleted=False
        and z.entity_name=zzz.name
		and z.mac_address= #{switch_macaddress}
        
 union all
 
	select z.entity_name switch_name, 
     	(zzz.ip) switch_ip, 
        zzz.asset_tag switch_asset_tag,
         z.port_no switch_port_no,
         z.ifindex switch_ifindex,  
         upper(zz.mac_address::TEXT) switch_mac_address,
         host(zz.ip_address) enduser_ip_address,
         upper(zz.clientmac::TEXT) enduser_mac_address, 
         zz.enduser_name,
         zz.enduser_asset_tag,
         to_char(zz.access_begin, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
		to_char(zz.access_end, 'MM-DD-YYYY HH24:MI:SS') as access_end
		from
		lscms_view_cmsinfo_interface z,
		( select a.*, b.mac_address clientmac, b.asset_tag enduser_asset_tag from
		lscms_ipam_accesshistory a left outer join lscms_view_enduser b
		on (a.enduser_name = b.name and a.enduser_mac=b.mac_address)
        order by a.access_begin desc
		) zz, lscms_cms_entity zzz, lscms_cms_sitetree e, lscms_cms_site f
		where (z.mac_address)=(zz.mac_address) and zzz.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and zzz.is_deleted=False
        and z.entity_name=zzz.name
		and z.mac_address= #{switch_macaddress}
		
	</select>	
	
	<select id="getOutletUsageHistory_20181111" parameterType="java.util.HashMap" resultType="java.util.HashMap">
	select z.switch_name switch_name, 
     	(zzz.ip) switch_ip, 
        zzz.asset_tag switch_asset_tag,
        (select b.name from lscms_cms_entity a, 
			lscms_cms_interface b
            where a.id=b.entity_id and a.opm_name=z.switch_name and b.ifindex=z.ifindex limit 1) switch_port_no,
         z.ifindex switch_ifindex,  
         z.macaddress switch_mac_address,
         z.peer_ip_address enduser_ip_address,
         upper(zz.clientmac::TEXT) enduser_mac_address, 
         zz.enduser_name,
         zz.enduser_asset_tag,
         to_char(zz.access_time, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
         null as access_end
		from
		lscms_view_connectioninfo z,
		( select a.*, b.mac_address clientmac, b.asset_tag enduser_asset_tag from
		lscms_ipam_accesslist a left outer join lscms_ipam_enduser b
		on (a.enduser_name = b.name and a.enduser_mac=b.mac_address)
		) zz, lscms_cms_entity zzz, lscms_cms_sitetree e, lscms_cms_site f
		where (z.macaddress)=upper(zz.mac_address::TEXT) and zzz.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and zzz.is_deleted=False
        and z.switch_name=zzz.opm_name
		and z.macaddress= upper(#{switch_macaddress})
        
 union all
 
	select z.switch_name switch_name, 
     	(zzz.ip) switch_ip, 
        zzz.asset_tag switch_asset_tag,
        (select b.name from lscms_cms_entity a, 
			lscms_cms_interface b
            where a.id=b.entity_id and a.opm_name=z.switch_name and b.ifindex=z.ifindex limit 1) switch_port_no,
         z.ifindex switch_ifindex,  
         z.macaddress switch_mac_address,
         z.peer_ip_address enduser_ip_address,
         upper(zz.clientmac::TEXT) enduser_mac_address, 
         zz.enduser_name,
         zz.enduser_asset_tag,
         to_char(zz.access_begin, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
		to_char(zz.access_end, 'MM-DD-YYYY HH24:MI:SS') as access_end
		from
		lscms_view_connectioninfo z,
		( select a.*, b.mac_address clientmac, b.asset_tag enduser_asset_tag from
		lscms_ipam_accesshistory a left outer join lscms_ipam_enduser b
		on (a.enduser_name = b.name and a.enduser_mac=b.mac_address)
        order by a.access_begin desc
		) zz, lscms_cms_entity zzz, lscms_cms_sitetree e, lscms_cms_site f
		where (z.macaddress)=upper(zz.mac_address::TEXT) and zzz.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and zzz.is_deleted=False
        and z.switch_name=zzz.opm_name
		and z.macaddress= upper(#{switch_macaddress})
		
	</select>	
	<select id="getOutletPortName" parameterType="int" resultType="String">
		select a.name from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_sitetree c
        where a.entity_id=b.id and b.id=c.entity_id
        and c.id =#{nodeid} order by a.id
	</select>
		
	<select id="getOutletPortStatus" parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		WITH RECURSIVE bottomuptree AS (
		  SELECT interface_a_id, ARRAY[interface_a_id,interface_b_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_a_id not in (select interface_b_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, bottomuptree.linkagepath || lscms_cms_linkage_connection_interface.interface_b_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, bottomuptree
		  WHERE lscms_cms_linkage_connection_interface.interface_a_id = bottomuptree.interface_b_id
		) 
select yyy.*,  zz.enduser_name, zz.enduser_ip from
(		
        select yy.*, #{portname} outletport from      
        (
		select x.*, y.idx from 
		( select t.* from
		(select a.id ifid, b.id entityid, b.name devicename, a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b
		 where a.entity_id=b.id  and a.id in (
		SELECT unnest(linkagepath) FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname})
		)) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id) x, 
		(SELECT unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx
		 FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname})
		)y where x.ifid = y.ifid
		order by y.idx limit 1
        ) xx,       
		(
		select x.*, y.name ifname, y.ifadminstatus, y.ifoperstatus 
        from 
        (select a.id entityid, b.id ifid,  a.ip, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex
         from lscms_cms_entity a, lscms_cms_interface b, lscms_cms_sitetree d, lscms_cms_site e
            where a.id=b.entity_id  and a.id=d.entity_id and d.site_id=e.id and e.is_deleted=False
         ) x left outer join snmpinterface y
            on upper(x.mac_address::TEXT)=replace(upper(y.physaddr), ' ', ':') 
		) yy where xx.ifid = yy.ifid and xx.entityid=yy.entityid
) yyy		
        left outer join
(
	select distinct
        v.switch_name,
        v.macaddress switch_mac,
        name  enduser_name, 
        full_name enduser_full_name,
        v.peer_ip_address enduser_ip, 
        upper(mac_address)  enduser_mac 
        from
        lscms_view_connectioninfo v,
        (
        select x.* from 
	        (
			select a.name, a.full_name, b.ip_address, b.peer_mac_address mac_address 		
	        from lscms_view_enduser a, 
			( select aa.peer_mac_address, bb.ip_address from lscms_mac_to_port aa left join lscms_mac_to_ip bb
			on aa.peer_mac_address=bb.mac_address ) b
			where upper(a.mac_address::TEXT)=b.peer_mac_address	
	        ) x
		) vv where (v.peer_mac_address)=vv.mac_address    
		union all       
	select distinct
        v.switch_name,
        v.macaddress switch_mac,
    	'Unauthorized' enduser_name, 
        'Unauthorized' enduser_full_name, 
         vv.mac_address enduser_ip,
         upper(vv.mac_address) enduser_mac
		from
		lscms_view_connectioninfo v,
		( 
		select x.* from
        (
        select  
			b.ip_address as ip_address, a.peer_mac_address mac_address 
	    	from lscms_mac_to_port a left join lscms_mac_to_ip b on a.peer_mac_address=b.mac_address		
	        left join (select mac_address from lscms_view_enduser union all select mac_address from lscms_ipam_unmanaged) c 
			on a.peer_mac_address = upper(c.mac_address::TEXT)
	        where c.mac_address is null 
            ) x left outer join (select distinct a.ip from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c where a.id=b.entity_id and b.site_id=c.id and c.is_deleted=False and a.is_deleted=False) y
            on x.ip_address = y.ip
            where y.ip is null         
		) vv
		where (v.peer_mac_address)=vv.mac_address      
)  zz          
on yyy.mac_address=zz.switch_mac
	</select>	

		
	<select id="getOutletPortStatus_20181114" parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		WITH RECURSIVE bottomuptree AS (
		  SELECT interface_a_id, ARRAY[interface_a_id,interface_b_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		  FROM lscms_cms_linkage_connection_interface WHERE interface_a_id not in (select interface_b_id from lscms_cms_linkage_connection_interface)
		 
		  UNION ALL
		 
		  SELECT lscms_cms_linkage_connection_interface.interface_a_id, bottomuptree.linkagepath || lscms_cms_linkage_connection_interface.interface_b_id,
		    lscms_cms_linkage_connection_interface.connector_id, lscms_cms_linkage_connection_interface.interface_b_id
		  FROM lscms_cms_linkage_connection_interface, bottomuptree
		  WHERE lscms_cms_linkage_connection_interface.interface_a_id = bottomuptree.interface_b_id
		) 
        select yy.*, #{portname} outletport from      
        (
		select x.*, y.idx from 
		( select t.* from
		(select a.id ifid, b.id entityid, b.name devicename, a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b
		 where a.entity_id=b.id  and a.id in (
		SELECT unnest(linkagepath) FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname})
		)) t left outer join lscms_cms_linkage_connection_interface tt on t.ifid=tt.interface_a_id) x, 
		(SELECT unnest(linkagepath) ifid, generate_subscripts(linkagepath, 1) AS idx
		 FROM bottomuptree 
		where interface_b_id=(select distinct b.id from lscms_cms_entity a, 
		lscms_cms_interface b,
		lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=#{nodeid}  and b.name=#{portname})
		)y where x.ifid = y.ifid
		order by y.idx limit 1
        ) xx,       
		(
		select a.id entityid, b.id ifid, a.ip, c.name ifname, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex, c.ifadminstatus, c.ifoperstatus from lscms_cms_entity a, lscms_cms_interface b, snmpinterface c
            where a.id=b.entity_id and upper(b.mac_address::TEXT)=replace(upper(c.physaddr), ' ', ':') 
		) yy where xx.ifid = yy.ifid and xx.entityid=yy.entityid	
	</select>				
	<select id="getNetworkNodePortStatus" parameterType="int" resultType="java.util.HashMap">
		select distinct x.*, z.status,
 		(SELECT interface_a_id
		FROM lscms_cms_linkage_connection_interface_switchtopo where x.interface_id=interface_a_id) downlink,
  		(SELECT interface_b_id
		FROM lscms_cms_linkage_connection_interface_switchtopo where x.interface_id=interface_b_id) uplink       
        from
		(
		select a.ip, c.name ifname, b.id interface_id, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex, c.ifadminstatus, c.ifoperstatus from lscms_cms_entity a, lscms_cms_interface b, snmpinterface c, lscms_cms_sitetree d, lscms_cms_site e
		where a.id=b.entity_id and a.id=d.entity_id and d.site_id=e.id and e.is_deleted = False and upper(b.mac_address::TEXT)=replace(upper(c.physaddr), ' ', ':')
		) x, managedobject z
		where x.ifname=z.name
		and x.devicename=( select distinct a.name from lscms_cms_entity a,
				lscms_cms_sitetree c where c.entity_id=a.id and c.id=#{nodeid} )
	</select>			
	
	<select id="getAlarmStatusAll" parameterType="int" resultType="java.util.HashMap">
		WITH RECURSIVE tree AS (
		  SELECT id, ARRAY[]::INTEGER[] AS linkagepath, entity_id
		  FROM lscms_cms_sitetree WHERE parent_id is null
		 
		  UNION ALL
		 
		  SELECT lscms_cms_sitetree.id, tree.linkagepath || lscms_cms_sitetree.parent_id,
		    lscms_cms_sitetree.entity_id
		  FROM lscms_cms_sitetree, tree
		  WHERE lscms_cms_sitetree.parent_id = tree.id
		) 

		select d.id nodeid, b.id entityid, b.opm_name devicename, a.status
         from lscms_cms_entity b, lscms_cms_category c, managedobject a, lscms_cms_sitetree d
		 where a.name=b.opm_name and b.category_id=c.id and d.entity_id=b.id
         and d.id in ( SELECT unnest(linkagepath) FROM tree where id=#{nodeid})  
	</select>

	<select id="getChildrensDirectStatus" parameterType="int" resultType="java.util.HashMap">
		with fulllist as 
		(
		             select x.*,  COALESCE((y.status), 5) status from (
                        select 
                          me.nodeid,
                          me.entityid,
                          me.devicename,     
                        case when parent.type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Rackspace') 
                             THEN parent.parent_id
                             else me.parent_id end parent_id,         
                          me.is_nms, me.type_id                 
                        from (
                             select d.id nodeid, b.id entityid, b.opm_name devicename, d.parent_id, c.is_nms, c.type_id
                                     from lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
                                     where 
                                     b.category_id=c.id and d.entity_id=b.id
                                         ) me,
                                         (
                             select d.id nodeid, b.id entityid, b.opm_name devicename, d.parent_id, c.is_nms, c.type_id
                                     from lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
                                     where 
                                     b.category_id=c.id and d.entity_id=b.id
                                         ) parent 
                         where me.parent_id=parent.nodeid and me.type_id !=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Rackspace') 
		                 ) x left outer join managedobject y on y.name=x.devicename 		                 
		),
		org as (
		    select * from fulllist where parent_id=#{nodeid}
		),
		 lvl2 as (    
		     select t.*, tt.nodeid lvl2nodeid, tt.entityid lvl2entityid, tt.devicename lvl2devicename, tt.parent_id lvl2parent_id, tt.status lvl2status from org t left outer join      
		     fulllist tt
		     on t.nodeid = tt.parent_id      
		)
		select w.*, ww.nodeid lvl3nodeid, ww.entityid lvl3entityid, ww.devicename lvl3devicename, ww.parent_id lvl3parent_id, ww.status lvl3status from lvl2 w left outer join
		     fulllist ww
		     on w.lvl2nodeid = ww.parent_id 
	</select>
	
	<select id="getChildrensAlarmStatus" parameterType="int" resultType="java.util.HashMap">	
		WITH  fulllist as 
		(
		             select x.*,  COALESCE((y.status), 5) status from (
                        select 
                          me.nodeid,
                          me.entityid,
                          me.devicename,     
                        case when parent.type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Rackspace') 
                             THEN parent.parent_id
                             else me.parent_id end parent_id,         
                          me.is_nms, me.type_id                 
                        from (
                             select d.id nodeid, b.id entityid, b.opm_name devicename, d.parent_id, c.is_nms, c.type_id
                                     from lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
                                     where 
                                     b.category_id=c.id and d.entity_id=b.id
                                         ) me,
                                         (
                             select d.id nodeid, b.id entityid, b.opm_name devicename, d.parent_id, c.is_nms, c.type_id
                                     from lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
                                     where 
                                     b.category_id=c.id and d.entity_id=b.id
                                         ) parent 
                         where me.parent_id=parent.nodeid and me.type_id !=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Rackspace') 
		                 ) x left outer join managedobject y on y.name=x.devicename  
		),
		org as (
		    select m.nodeid, m.entityid, m.devicename, m.parent_id, m.is_nms, m.status  from fulllist m
		    where m.parent_id=#{nodeid}
		),
		 lvl2 as (    
		     select t.*, tt.nodeid lvl2nodeid, tt.entityid lvl2entityid, tt.devicename lvl2devicename, tt.parent_id lvl2parent_id, tt.is_nms lvl2is_nms, 
             case when tt.nodeid is null then null when tt.is_nms then tt.status else null end lvl2status       
		     from org t left outer join      
		     fulllist tt
		     on t.nodeid = tt.parent_id      
		),
        lvl3 as(
		select w.*, ww.nodeid lvl3nodeid, ww.entityid lvl3entityid, ww.devicename lvl3devicename, ww.parent_id lvl3parent_id, ww.is_nms lvl3is_nms,             
            case when ww.nodeid is null then null when ww.is_nms then ww.status else null end lvl3status
		from lvl2 w left outer join
		     fulllist ww
		     on w.lvl2nodeid = ww.parent_id 
             )
		 select k.nodeid, k.entityid, k.parent_id, 
		 min(status) status,  min(lvl2status) lvl2status, min(lvl3status) lvl3status, min(lvl4status) lvl4status 
		 from (            
		 		select q.*, qq.nodeid lvl4nodeid, qq.entityid lvl4entityid, qq.devicename lvl4devicename, qq.parent_id lvl4parent_id, qq.is_nms lvl4is_nms,         		
		        		case when qq.nodeid is null then null when qq.is_nms then qq.status else null end lvl4status
				from lvl3 q left outer join
				     fulllist qq
				     on q.lvl3nodeid = qq.parent_id             
		 ) k group by nodeid, entityid, parent_id, is_nms        
	</select>             	
	
	<select id="getChildrensAlarmStatus__" parameterType="int" resultType="java.util.HashMap">		
		WITH RECURSIVE bottomuptree AS (
		SELECT interface_a_id, ARRAY[interface_a_id,interface_b_id]::INTEGER[] AS linkagepath, connector_id, interface_b_id
		FROM lscms_cms_linkage_connection_interface WHERE interface_a_id not in (select interface_b_id from lscms_cms_linkage_connection_interface)
		
		UNION ALL
		
		SELECT a.interface_a_id, b.linkagepath || a.interface_b_id,
		a.connector_id, a.interface_b_id
		FROM lscms_cms_linkage_connection_interface a, bottomuptree b
		WHERE a.interface_a_id = b.interface_b_id
		),
		fulllist as 
		(
		             select x.*, y.status from (
		     select d.id nodeid, b.id entityid, b.opm_name devicename, d.parent_id, c.is_nms
		             from lscms_cms_entity b, lscms_cms_category c, lscms_cms_sitetree d
		             where 
		             b.category_id=c.id and d.entity_id=b.id
		                 ) x left outer join managedobject y on y.name=x.devicename
		),
		org as (
		    select m.nodeid, m.entityid, m.devicename, m.parent_id, m.is_nms, m.status, (
		        select case when count(y.ip_address)=0 then 2 else 5 end from 
		        (
		        select a.id ifid, b.id entityid, b.name devicename, --c.image_linkage_connection deviceimage, 
		        a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c
		        where a.entity_id=b.id and b.category_id=c.id 
		            and a.id in (
		                        select 
		                        (linkagepath[1]) from (
		                        select interface_b_id, max(linkagepath) linkagepath from bottomuptree group by  interface_b_id
		                        ) x where x.interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		                                                        lscms_cms_interface b,
		                                                        lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=m.nodeid 
		                                                        )
		                        ) 
		        )x left outer join lscms_ipam_accesslist y on x.mac_address=upper(y.mac_address::TEXT)    
		    ) connectedstatus from fulllist m
		    where m.parent_id=#{nodeid}
		),
		 lvl2 as (    
		     select t.*, tt.nodeid lvl2nodeid, tt.entityid lvl2entityid, tt.devicename lvl2devicename, tt.parent_id lvl2parent_id, tt.is_nms lvl2is_nms, 
             case when tt.nodeid is null then null when tt.is_nms then tt.status else null end lvl2status, (
		        select case when tt.nodeid is null then null when tt.is_nms then null when count(y.ip_address)=0 then 2 else 5 end from 
		        (
		        select a.id ifid, b.id entityid, b.name devicename, 
		        a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c
		        where a.entity_id=b.id and b.category_id=c.id 
		            and a.id in (
		                        select  
		                        (linkagepath[1]) from (
		                        select interface_b_id, max(linkagepath) linkagepath from bottomuptree group by  interface_b_id
		                        ) x where x.interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		                                                        lscms_cms_interface b,
		                                                        lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=tt.nodeid 
		                                                        )
		                        ) 
		        )x left outer join lscms_ipam_accesslist y on x.mac_address=upper(y.mac_address::TEXT)    
		    ) lv2connectedstatus         
		     from org t left outer join      
		     fulllist tt
		     on t.nodeid = tt.parent_id      
		),
        lvl3 as(
		select w.*, ww.nodeid lvl3nodeid, ww.entityid lvl3entityid, ww.devicename lvl3devicename, ww.parent_id lvl3parent_id, ww.is_nms lvl3is_nms, 
            
            case when ww.nodeid is null then null when ww.is_nms then ww.status else null end lvl3status, (                      
		        select case when ww.nodeid is null then null when ww.is_nms then null when count(y.ip_address)=0 then 2 else 5 end from 
		        (
		        select a.id ifid, b.id entityid, b.name devicename, 
		        a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c
		        where a.entity_id=b.id and b.category_id=c.id 
		            and a.id in (
		                        select  
		                        (linkagepath[1]) from (
		                        select interface_b_id, max(linkagepath) linkagepath from bottomuptree group by  interface_b_id
		                        ) x where x.interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		                                                        lscms_cms_interface b,
		                                                        lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=ww.nodeid
		                                                        )
		                        ) 
		        )x left outer join lscms_ipam_accesslist y on x.mac_address=upper(y.mac_address::TEXT)    
		    ) lv3connectedstatus  
		from lvl2 w left outer join
		     fulllist ww
		     on w.lvl2nodeid = ww.parent_id 
             )
 select k.nodeid, k.entityid, k.parent_id, 
 case when k.is_nms is true then min(status) else min(connectedstatus) end status,  min(lvl2status) lvl2status, min(lvl3status) lvl3status, min(lvl4status) lvl4status 
 from (            
 		select q.*, qq.nodeid lvl4nodeid, qq.entityid lvl4entityid, qq.devicename lvl4devicename, qq.parent_id lvl4parent_id, qq.is_nms lvl4is_nms,         		
        		case when qq.nodeid is null then null when qq.is_nms then qq.status else null end lvl4status, (
		        select case when qq.nodeid is null then null when qq.is_nms then null when count(y.ip_address)=0 then 2 else 5 end from 
		        (
		        select a.id ifid, b.id entityid, b.name devicename, 
		        a.name portname, upper(a.mac_address::TEXT) mac_address from lscms_cms_interface a, lscms_cms_entity b, lscms_cms_category c
		        where a.entity_id=b.id and b.category_id=c.id 
		            and a.id in (
		                        select  
		                        (linkagepath[1]) from (
		                        select interface_b_id, max(linkagepath) linkagepath from bottomuptree group by  interface_b_id
		                        ) x where x.interface_b_id in (select distinct b.id from lscms_cms_entity a, 
		                                                        lscms_cms_interface b,
		                                                        lscms_cms_sitetree c where a.id=b.entity_id and c.entity_id=a.id and c.id=qq.nodeid
		                                                        )
		                        ) 
		        )x left outer join lscms_ipam_accesslist y on x.mac_address=upper(y.mac_address::TEXT)    
		    ) lv4connectedstatus  
		from lvl3 q left outer join
		     fulllist qq
		     on q.lvl3nodeid = qq.parent_id             
 ) k group by nodeid, entityid, parent_id, is_nms        
             
          
	</select>
	
	<select id="getAlarmStatus" parameterType="int" resultType="java.util.HashMap">
		select #{nodeid}, name, status from managedobject where name =
		(select distinct a.opm_name from lscms_cms_entity a,
				lscms_cms_sitetree c where c.entity_id=a.id and c.id=#{nodeid})

	</select>
	
	<select id="searchIPTerminal" parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select distinct c.id as node_id, c.site_id as site_id, b.name as portname, a.name || '' as name, a.comments || '' as comments , a.asset_tag || '' as asset_tag , a.ip || '' as ip , upper(b.mac_address::TEXT)  || '' as mac_address 
        from lscms_cms_entity a, lscms_cms_interface b, lscms_cms_sitetree c, lscms_cms_site d
		where 1=1
		and a.id=b.entity_id and a.id=c.entity_id and c.site_id=d.id and d.is_deleted = False and a.is_deleted = False
		<if test="systemUserName != null and systemUserName != ''">
		and d.id in (SELECT cms_site_id FROM lscms_systemuser_cms_site a, lscms_auth_systemuser b where a.systemuser_id = b.id and b.username=#{systemUserName})
		</if>		
		<if test="keyword != null and keyword != ''">
		and (UPPER(a.asset_tag) like '%' || UPPER(#{keyword}) || '%' or UPPER(a.name) like '%' || UPPER(#{keyword}) || '%' or a.ip like '%' || #{keyword} || '%'  or UPPER(b.mac_address::TEXT) like '%' || UPPER(#{keyword}) || '%')
		</if>			
		union all 
		select distinct (select x.id from lscms_cms_sitetree x, lscms_cms_interface y, lscms_cms_site z, lscms_cms_entity zz where x.entity_id=zz.id and x.entity_id=y.entity_id and x.site_id=z.id and z.is_deleted = False and zz.is_deleted = False 
		<if test="systemUserName != null and systemUserName != ''">
		and z.id in (SELECT cms_site_id FROM lscms_systemuser_cms_site a, lscms_auth_systemuser b where a.systemuser_id = b.id and b.username=#{systemUserName})
		</if>			
		and y.mac_address in (select mac_address from lscms_ipam_accesslist where enduser_name=a.name and enduser_mac=a.mac_address) limit 1) node_id,
		(select x.site_id from lscms_cms_sitetree x, lscms_cms_interface y, lscms_cms_site z, lscms_cms_entity zz where x.entity_id=zz.id and x.entity_id=y.entity_id and x.site_id=z.id and z.is_deleted = False and zz.is_deleted = False 
		<if test="systemUserName != null and systemUserName != ''">
		and z.id in (SELECT cms_site_id FROM lscms_systemuser_cms_site a, lscms_auth_systemuser b where a.systemuser_id = b.id and b.username=#{systemUserName})
		</if>			
		and y.mac_address in (select mac_address from lscms_ipam_accesslist where enduser_name=a.name and enduser_mac=a.mac_address) limit 1) site_id,
		'' as portname, 
		a.name || '' as name, a.email || '' as comments, a.asset_tag || '' as asset_tag, b.ip_address || '' as ip, upper(b.mac_address) || '' as mac_address 
        from lscms_view_enduser a left outer join lscms_mac_to_ip b
		on upper(a.mac_address::TEXT)=b.mac_address			
		<if test="keyword != null and keyword != ''">
		where (UPPER(a.asset_tag) like '%' || UPPER(#{keyword}) || '%' or UPPER(a.name) like '%' || UPPER(#{keyword}) || '%' or b.ip_address like '%' || #{keyword} || '%' or UPPER(b.mac_address) like '%' || UPPER(#{keyword}) || '%')
		</if>
		union all       
	select 
    distinct (select x.id from lscms_cms_sitetree x, lscms_cms_interface y, lscms_cms_site z, lscms_cms_entity zz where x.entity_id=zz.id and x.entity_id=y.entity_id and x.site_id=z.id and z.is_deleted = False and zz.is_deleted = False 		
		and upper(y.mac_address::TEXT) = zzzz.macaddress limit 1) node_id,
		(select x.site_id from lscms_cms_sitetree x, lscms_cms_interface y, lscms_cms_site z, lscms_cms_entity zz where x.entity_id=zz.id and x.entity_id=y.entity_id and x.site_id=z.id and z.is_deleted = False and zz.is_deleted = False 	
		and upper(y.mac_address::TEXT) = zzzz.macaddress limit 1) site_id,
		zzzz.port_no as portname,
    	'Unauthorized' as name, 
        '' as comments, 
        '' as asset_tag, 
         zz.mac_address ip,
         upper(zz.mac_address) mac_address
		from
		lscms_view_connectioninfo zzzz,
		( 
			select x.* from
        	(
	        select  
			b.ip_address || '' as ip_address, upper(a.peer_mac_address) || '' as mac_address 
	        from lscms_mac_to_port a left join lscms_mac_to_ip b
			on a.peer_mac_address=b.mac_address
	        left join (select mac_address from lscms_view_enduser union all select mac_address from lscms_ipam_unmanaged) c 
			on a.peer_mac_address = upper(c.mac_address::TEXT)		
	        where c.mac_address is null 
            ) x left outer join (select distinct a.ip from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c where a.id=b.entity_id and b.site_id=c.id and c.is_deleted=False and a.is_deleted=False) y
            on x.ip_address = y.ip
            where y.ip is null               
		) zz
		where (zzzz.peer_mac_address)=zz.mac_address		   
		<if test="keyword != null and keyword != 'Unauthorized'">
		and ( zzzz.peer_ip_address like '%' || #{keyword} || '%' or UPPER(zz.mac_address) like '%' || UPPER(#{keyword}) || '%')
		</if>  		
	</select>			
	
	<select id="getUsageHistory" parameterType="java.lang.String" resultType="java.util.HashMap">
		WITH usageHistory AS (
		(
		select 
		d.name as switch_name,
		d.ip as switch_ip,
		c.name as switch_port_no,
		c.ifindex as switch_ifindex,
		upper(a.mac_address::TEXT) as switch_mac_address,
		d.asset_tag as switch_asset_tag,
		to_char(a.access_time, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
		null as access_end,
		a.enduser_name,
		upper(b.mac_address::TEXT) as enduser_mac_address,
		host(a.ip_address) as enduser_ip_address,
		host(b.reg_ip_address) as reg_ip_address,
		b.asset_tag as enduser_asset_tag
		from lscms_ipam_accesslist a, lscms_view_enduser b, lscms_cms_interface c, lscms_cms_entity d, lscms_cms_sitetree e, lscms_cms_site f
		where a.enduser_name=b.name and a.enduser_mac=b.mac_address and a.mac_address=c.mac_address and c.entity_id=d.id and d.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and d.is_deleted=False
		)
		union all
		(
		select 
		d.name as switch_name,
		d.ip as switch_ip,
		c.name as switch_port_no,
		c.ifindex as switch_ifindex,
		upper(a.mac_address::TEXT) as switch_mac_address,
		d.asset_tag as switch_asset_tag,
		to_char(a.access_begin, 'MM-DD-YYYY HH24:MI:SS') as access_begin,
		to_char(a.access_end, 'MM-DD-YYYY HH24:MI:SS') as access_end,
		a.enduser_name,
		upper(b.mac_address::TEXT) as enduser_mac_address,
		host(a.ip_address) as enduser_ip_address,
		host(b.reg_ip_address) as reg_ip_address,
		b.asset_tag as enduser_asset_tag
		from lscms_ipam_accesshistory a, lscms_view_enduser b, lscms_cms_interface c, lscms_cms_entity d, lscms_cms_sitetree e, lscms_cms_site f
		where a.enduser_name=b.name and a.enduser_mac=b.mac_address and a.mac_address=c.mac_address and c.entity_id=d.id and d.id=e.entity_id and e.site_id=f.id and f.is_deleted=False and d.is_deleted=False
		    order by a.access_begin desc )
		    )
		    select * from usageHistory  
		    where enduser_name=#{enduser_name}	   
	</select>		
	
	<select id="searchCMSEntity" parameterType="java.util.HashMap" resultType="java.util.HashMap">
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath, ARRAY[]::TEXT[] AS linkagepathname
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))
			,array_append(b.linkagepathname, (select name::TEXT from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))) 
		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		)  
      
        select t.*, tt.bld_entity_id, tt.bld_entity_name , tt.floor_entity_id , tt.floor_entity_name , tt.area_entity_id , tt.area_entity_name , array_to_string(tt.linkagepathname, '>>') as location from
        (
		select a.id, b.site_id, a.name as entity_name, a.asset_tag as entity_asset_tag, a.comments as entity_comments, 
		a.opm_name as entity_opm_name, a.ip as entity_ip, c.name as site_name, c.description as site_description,
		d.name as region_name, b.type_id, 
        (select name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and id=b.type_id) type_name, 
        e.id ci_id, e.name ci_name, e.description ci_description
		from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_region d, lscms_cms_category e	      
		where a.id=b.entity_id and b.site_id=c.id and a.is_deleted=False and c.region_id=d.id and a.category_id=e.id
       ) t, 
        (
        select  site_id, site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(area_entity_id) area_entity_id, max(area_entity_name)area_entity_name, max(linkagepath) linkagepath, max(linkagepathname) linkagepathname, entity_id
        from 
            (        
                select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port,
                         t.entity_name, tt.linkagepath, tt.linkagepathname, unnest(tt.linkagepath) parent_tree_id
                         from
                (
                    select  
                        b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port,
                        b.site_id, a.name as entity_name, c.name as site_name 
                        from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d where 1=1 and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                        and d.type_id in (
                                select id from lscms_common_code 
                                where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                                and name not in ('Site', 'Building', 'Floor', 'Area'))
                ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
            ) y left join
             (
                select  
                    a.id bld_entity_id, a.name bld_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
            ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
             left join 
            (
                select  
                    a.id floor_entity_id, a.name floor_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
            ) yyy on y.parent_tree_id=yyy.floor_entity_id 
             left join 
            (
                select  
                    a.id area_entity_id, a.name area_entity_name
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
            ) yyyy on y.parent_tree_id=yyyy.area_entity_id
            where 1=1
             <if test="site_id != null and site_id  gt 0">
            	and	y.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	yy.bld_entity_id=#{bld_entity_id}
             </if>
             <if test="floor_entity_id != null and floor_entity_id  gt 0">
            	and	yyy.floor_entity_id=#{floor_entity_id}
             </if>            
             group by y.site_id, y.site_name, y.entity_id 
            ) tt where t.id=tt.entity_id
		<if test="keyword != null and keyword != ''">
		and (t.entity_name like '%' ||  #{keyword} || '%' or t.entity_asset_tag like '%' ||  #{keyword} || '%')
		</if>	
		<if test="type != null">
		and (t.type_id=#{type})		
		</if>	            
        order by t.site_name, t.region_name, t.type_name, t.ci_name, tt.bld_entity_name, tt.floor_entity_name ,  tt.area_entity_name

	
	</select>			

	<select id="searchCMSEntity_20181030" parameterType="java.util.HashMap" resultType="java.util.HashMap">
 		WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::TEXT[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b WHERE a.site_id=b.id and a.parent_id is null and b.is_deleted=False
		 
		  UNION ALL
		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, 
           array_append(b.linkagepath, (select name::TEXT from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))) 
            --b.linkagepath || (select name from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))
		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id
		) 
        
        select t.*, array_to_string(tt.linkagepath, '>>') as location
        --string_agg(tt.linkagepath, '>>') 
        from
        (
		select b.id, b.site_id, a.name as entity_name, a.asset_tag as entity_asset_tag, a.comments as entity_comments, 
		a.opm_name as entity_opm_name, a.ip as entity_ip, c.name as site_name, c.description as site_description,
		d.name as region_name, b.type_id
		from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_region d
		where a.id=b.entity_id and b.site_id=c.id and a.is_deleted=False and c.region_id=d.id
        ) t ,
        topdownsearchtree tt where t.id=tt.id
		<if test="keyword != null and keyword != ''">
		and (t.entity_name like '%' ||  #{keyword} || '%' or t.entity_asset_tag like '%' ||  #{keyword} || '%')
		</if>	
		<if test="type != null">
		and (t.type_id=#{type})		
		</if>			
	</select>	
			
	<select id="getAuthList" parameterType="int" resultType="java.util.HashMap">
		select a.cms_site_id, a.systemuser_id, b.username, b.fullname, b.email, 
		to_char(b.date_joined, 'MM-DD-YYYY HH24:MI:SS') as date_joined  
		from lscms_systemuser_cms_site a, lscms_auth_systemuser b
		where 1=1
		and a.systemuser_id=b.id
		and b.is_deleted=False
		and a.cms_site_id=#{siteid}
	</select>				

	<select id="getAvailableSystemUser" parameterType="int" resultType="java.util.HashMap">
		select a.id as systemuser_id, a.username, a.fullname, email, to_char(a.date_joined, 'MM-DD-YYYY HH24:MI:SS') as date_joined  
				FROM lscms_auth_systemuser a, lscms_auth_group b, lscms_auth_systemuser_groups c
		        where a.id=c.systemuser_id and b.id=c.group_id
		and a.id not in (select systemuser_id from lscms_systemuser_cms_site where cms_site_id=#{siteid})
		and a.is_deleted=False
		and b.name != 'Administrators'
	</select>			

	<insert id="addAuthorizedSystemUser"  parameterType="java.util.HashMap" >
		INSERT INTO lscms_systemuser_cms_site(
		cms_site_id, systemuser_id)
		VALUES (#{cms_site_id}, #{systemuser_id})
	</insert>	
	
	<delete id="removeAuthorizedSystemUser"  parameterType="java.util.HashMap" >
		delete from lscms_systemuser_cms_site
		where
		cms_site_id = #{cms_site_id} and systemuser_id =  #{systemuser_id}
	</delete>		
		
	<select id="getAuthList2" parameterType="int" resultType="java.util.HashMap">
