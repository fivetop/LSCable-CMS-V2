	</select>				

	<select id="getAvailableSystemUser2" parameterType="int" resultType="java.util.HashMap">
		select a.id as systemuser_id, a.username, a.fullname, email, to_char(a.date_joined, 'MM-DD-YYYY HH24:MI:SS') as date_joined  
				FROM lscms_auth_systemuser a, lscms_auth_group b, lscms_auth_systemuser_groups c
		        where a.id=c.systemuser_id and b.id=c.group_id
		and a.id not in (select systemuser_id from lscms_systemuser_mainpage where mainpage_id=#{mainpageid})
		and a.is_deleted=False
		and b.name != 'Administrators'
	</select>			

	<insert id="addAuthorizedSystemUser2"  parameterType="java.util.HashMap" >
		INSERT INTO lscms_systemuser_mainpage(
		mainpage_id, systemuser_id)
		VALUES (#{mainpage_id}, #{systemuser_id})
	</insert>	
	
	<delete id="removeAuthorizedSystemUser2"  parameterType="java.util.HashMap" >
		delete from lscms_systemuser_mainpage
		where
		mainpage_id = #{mainpage_id} and systemuser_id =  #{systemuser_id}
	</delete>		
	
	<select id="getMainPageLayout" parameterType="java.util.HashMap"  resultType="java.util.HashMap">
		select * from 
        (select a.id, a.name, description, (select name from lscms_common_code where id=layout) as layout,
		(select name from lscms_common_code where id=theme) as theme, b.username
		from lscms_mainpage a, lscms_auth_systemuser b
		where a.creator_id=b.id and a.is_deleted is False) x
        left outer join lscms_systemuser_mainpage y
        on x.id=y.mainpage_id
        where 1=1	         	
		<if test="systemUserRole != 'Administrators'">
	     and y.systemuser_id=(select id from lscms_auth_systemuser where username=#{systemUserName})
	   </if>  
	</select>		

	<select id="getMapWidgets" resultType="java.util.HashMap">
