	<select id="getMainPageLayoutDetail" parameterType="int" resultType="java.util.HashMap">
		select y.title, y.widget_id, y.rowindex, y.colindex, y.rowspan, y.colspan, z.content_data, z.option_data, t.name widgettype from (
			select name, description, id, 
			(select name from lscms_common_code where id=layout) layout_name,
			layout layout_id, 
			(select name from lscms_common_code where id=theme) theme_name,
			theme theme_id from lscms_mainpage where id=#{id} and is_deleted is False
	    ) x left outer join lscms_mainpage_widget y on x.id=y.mainpage_id left outer join lscms_widget z on y.widget_id=z.id left outer join lscms_common_code t on z.widgettype_id=t.id 
	    order by rowindex, colindex
	</select>

	<select id="getMainPageLayoutDetail4MainPage" parameterType="int" resultType="java.util.HashMap">
		select y.title, y.widget_id, y.rowindex, y.colindex, y.rowspan, y.colspan, 
        case t.name when 'Map' then '' else z.content_data
        end content_data, z.option_data, t.name widgettype from (
			select name, description, id, 
			(select name from lscms_common_code where id=layout) layout_name,
			layout layout_id, 
			(select name from lscms_common_code where id=theme) theme_name,
			theme theme_id from lscms_mainpage where id=#{id} and is_deleted is False
	    ) x left outer join lscms_mainpage_widget y on x.id=y.mainpage_id left outer join lscms_widget z on y.widget_id=z.id left outer join lscms_common_code t on z.widgettype_id=t.id 
	    order by rowindex, colindex
	</select>
	
