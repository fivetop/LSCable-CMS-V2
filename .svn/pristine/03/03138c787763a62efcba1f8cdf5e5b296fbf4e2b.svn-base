		select mainpage_id from lscms_systemuser_mainpage_admin_default
		where
		systemuser_id = (select id from lscms_auth_systemuser where username=#{systemUserName})
	</select>					
	
	<select id="isBasisPatchPanel"  parameterType="java.util.HashMap" resultType="java.lang.Boolean">
		SELECT is_basis
			FROM lscms_cms_linkage_connection_patchpanel 
		    where sitetree_id=#{patchpanel_id} and linkage_connection_id=#{linkage_connection_id}
	</select>		

	<select id="getRackspacesAsChildren"  parameterType="java.lang.Integer" resultType="java.lang.Integer">
		select b.entity_id
		from lscms_cms_sitetree_placement a, lscms_cms_sitetree_placement_entity b, lscms_cms_entity c, lscms_cms_category d, lscms_common_code e 
		where a.id=b.sitetree_placement_id and b.entity_id=c.id and c.category_id=d.id and d.type_id=e.id and a.sitetree_id=#{nodeid} and e.id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and name='Rackspace')
	</select>
			
	<select id="getDeviceInterfaces"  parameterType="java.lang.String" resultType="java.util.HashMap">
		 select si.name, si.ifdescr,  si.ifname, mo.displayname
         from SnmpInterface si 
		      INNER JOIN ManagedObject mo ON si.NAME=mo.NAME AND IFSPEEDIN!=0 AND IFSPEEDOUT!=0 and physmedia=6
              INNER JOIN IpAddress ipa ON si.NAME=ipa.NAME where ipa.PARENTNODE = #{devicename}
		      order by mo.NAME , mo.DISPLAYNAME 
	</select>	
	
	<select id="getAvailableDevicesInRack"  parameterType="java.util.HashMap" resultType="java.util.HashMap">

		select a.entity_opm_name as name, a.entity_name displayname from lscms_view_cmsinfo_device a, lscms_cms_sitetree b 
		where a.id=b.entity_id and parent_id in (
		<if test="source != null and source gt 0">
			#{source}
			<if test="target != null and target gt 0">
				, #{target}
			</if>	
		</if>
		<if test="(source == null or source == 0) and target != null and target gt 0">
			#{target}
		</if>
		) and a.entity_opm_name is not null
	</select>		

	<select id="getEdgeStatus_20180928"  parameterType="java.util.HashMap" resultType="java.util.HashMap">
		with temp as (
		 select comm.ID ,mo.NAME as NAME, mo.DISPLAYNAME DISPNAME, COLLECTIONTIME, (INOCTETS*8*1000/(DELTATIME)+OUTOCTETS*8*1000/(DELTATIME)) G, ipa.PARENTNODE DEVICENAME, (INOCTETS*8*1000/(DELTATIME)) rx,(OUTOCTETS*8*1000/(DELTATIME)) tx,si.IFSPEEDIN SPEEDIN, si.IFSPEEDOUT SPEEDOUT 
		                                                                              from SnmpInterface si 
		                                                                              INNER JOIN ManagedObject mo ON si.NAME=mo.NAME AND IFSPEEDIN!=0 AND IFSPEEDOUT!=0 AND mo.NAME=#{interfacename}
            																		  INNER JOIN IpAddress ipa ON si.NAME=ipa.NAME INNER JOIN ${tablename} comm ON mo.MOID=comm.ID AND COLLECTIONTIME  BETWEEN #{starttimehr} AND  #{endtimehr}
		                                                                              order by comm.ID ,mo.NAME , mo.DISPLAYNAME , COLLECTIONTIME desc
		)
		select temp.name, temp.dispname, temp.collectiontime, temp.rx rxRate, temp.tx txRate, temp.g, temp.DEVICENAME, temp.SPEEDIN, temp.SPEEDOUT from temp, ManagedObject mo where mo.NAME=temp.DEVICENAME
		order by temp.COLLECTIONTIME desc limit 1;
	</select>		
	
	<select id="getEdgeStatus"  parameterType="java.util.HashMap" resultType="java.util.HashMap">
		select 
		(INOCTETS*8*1000/(DELTATIME)) rxRate,
		(OUTOCTETS*8*1000/(DELTATIME)) txRate,
		si.IFSPEEDIN SPEEDIN, si.IFSPEEDOUT SPEEDOUT,
		(INOCTETS*8*1000/(DELTATIME)+OUTOCTETS*8*1000/(DELTATIME)) G,
		si.NAME,
		DISPLAYNAME as DISPNAME,
		COLLECTIONTIME
		from SnmpInterface si 
		INNER JOIN ManagedObject mo ON si.NAME=mo.NAME and mo.name=#{interfacename}
		INNER JOIN IpAddress ipa ON si.NAME=ipa.NAME
		LEFT JOIN  InterfaceDefinitionTemplate iftempl ON si.PHYSMEDIA=iftempl.TYPEID 
		LEFT JOIN (select PERFID,DELTATIME,INOCTETS,OUTOCTETS,(INERRORS+OUTERRORS) as ERRORS,COLLECTIONTIME 
		           from (select ID as PERFID,MAX(COLLECTIONTIME) as COLTIME from ManagedObject mo, IpAddress ipa, ${tablename}  rawT where mo.NAME=ipa.NAME
		                 and mo.name=#{interfacename}
		                 and mo.MOID=rawT.ID group by ID) as PerfData1 INNER JOIN  ${tablename} as comm ON PERFID=ID and COLTIME=COLLECTIONTIME) as PerfData ON MOID=PERFID order by IFINDEX
	</select>	

	<select id="retrievePortUsageRate"  parameterType="java.util.HashMap" resultType="java.util.HashMap">
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		),  		
        temp as 
	(
		select  max(site_id) site_id, max(site_name) site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
			max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
	        max(area_entity_id) area_entity_id, max(area_entity_name)area_entity_name, max(linkagepath) linkagepath, max(entity_id) entity_id, 
	        max(port_cnt) port_cnt, max(used_cnt) used_cnt, max(connected_cnt) connected_cnt
	from (        
	  	select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, linkagepath, z.entity_id, z.total_port, 
	    z.interface_id, 1 port_cnt,  
		case when zz.interface is null then 0 else 1 end used_cnt,
	    case when zzz.interface_id is null then 0 else 1 end connected_cnt
	    from
	    (select y.*, yy.bld_entity_id, yy.bld_entity_name, yyy.floor_entity_id, yyy.floor_entity_name, yyyy.area_entity_id, yyyy.area_entity_name
	    from  
		(        
        select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port, t.interface_id,
                 t.entity_name, tt.linkagepath, unnest(tt.linkagepath) parent_tree_id
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port, e.id interface_id,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d, lscms_cms_interface e where a.id=e.entity_id and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
     <if test="type != null and type == 'patchpanel'">
                and d.type_id in (
                        select id from lscms_common_code 
                        where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                        and name = 'Patch Panel')
     </if> 
     <if test="type != null and type == 'switch'">
                and d.type_id in (
                    select id from lscms_common_code 
                    where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                    	<![CDATA[  and name in ('L2 Switch', 'L3 Switch')) ]]>	
     </if> 
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
    ) y left join
     (
        select  
            a.id bld_entity_id, a.name bld_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
    ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
     left join 
    (
        select  
            a.id floor_entity_id, a.name floor_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
    ) yyy on y.parent_tree_id=yyy.floor_entity_id 
     left join 
    (
        select  
            a.id area_entity_id, a.name area_entity_name
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
    ) yyyy on y.parent_tree_id=yyyy.area_entity_id
     
    ) z left join
    (
    		select distinct interface, entity_id from
		(
		select interface_a_id interface, e.entity_id from lscms_cms_linkage_connection_interface a,
            lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
            where a.interface_a_id=e.id
            and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False

		    union all
		select interface_b_id interface, b.entity_id from lscms_cms_linkage_connection_interface a,
            lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
            where a.interface_b_id=e.id
            and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		) u
    ) zz on z.interface_id=zz.interface   
    left join

     <if test="type != null and type == 'patchpanel'">
    (
		select distinct interface_id, connection_list from
		(
						select --*
				            d.connection_list, a.id, a.ip, b.id interface_id, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex
				            from lscms_cms_entity a, lscms_cms_interface b, lscms_view_connectioninfo c, lscms_view_linkage_connection_all_array d
						where a.id=b.entity_id and upper(b.mac_address::TEXT)=c.macaddress
		                and b.mac_address = d.mac_address
		) x            
        
    ) zzz on zz.interface = ANY (zzz.connection_list)
     </if> 
     <if test="type != null and type == 'switch'">
     (
				select --*
		            a.id, a.ip, b.id interface_id, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex
		            from lscms_cms_entity a, lscms_cms_interface b, lscms_view_connectioninfo c
				where a.id=b.entity_id and upper(b.mac_address::TEXT)=c.macaddress 			

    ) zzz on zz.interface=zzz.interface_id
     </if> 

    ) v where 1=1
    group by entity_id, interface_id
 )
      <if test="site_id == null or site_id  == 0">
        select  site_id, site_name, null::integer bld_entity_id, null bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(connected_cnt) connected_cnt, sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate
        from temp group by site_id, site_name
        
        order by site_name,  bld_entity_name NULLS FIRST, floor_entity_name NULLS FIRST, area_entity_name NULLS FIRST
     </if>
     <if test="site_id != null and site_id  gt 0">
	     <if test="bld_entity_id == null or bld_entity_id  == 0">
		        select  site_id, site_name, bld_entity_id, bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
			sum(connected_cnt) connected_cnt, sum(port_cnt) - sum(used_cnt) available_port_cnt,  
			case when sum(port_cnt)=0 then '0'
			else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate 
		        from temp group by site_id, site_name, bld_entity_id, bld_entity_name
		        
		        order by site_name,  bld_entity_name NULLS FIRST, floor_entity_name NULLS FIRST, area_entity_name NULLS FIRST
	     </if>        
	     <if test="bld_entity_id != null and bld_entity_id  gt 0">
	        select * from
	        (         
	        select  0 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
		sum(connected_cnt) connected_cnt, sum(port_cnt) - sum(used_cnt) available_port_cnt,  
		case when sum(port_cnt)=0 then '0'
		else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate
	        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name
	        union all
	        select  1 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
		sum(connected_cnt) connected_cnt, sum(port_cnt) - sum(used_cnt) available_port_cnt,  
		case when sum(port_cnt)=0 then '0'
		else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate 
	        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
	        ) sub 
	        where 1=1
	        and	site_id=#{site_id}	
	        and	bld_entity_id=#{bld_entity_id}
        order by site_name,  bld_entity_name NULLS FIRST, floor_entity_name NULLS FIRST, area_entity_name NULLS FIRST, rnk
        
	     </if>  
     </if> 
 
 
	</select>	

	<select id="retrieveSwitchPortUsageRate"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		),
        temp as 
(
	select  max(site_id) site_id, max(site_name) site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(area_entity_id) area_entity_id, max(area_entity_name) area_entity_name, max(linkagepath) linkagepath, max(entity_id) entity_id, max(interface_id) interface_id,
        max(port_cnt) port_cnt, max(used_cnt) used_cnt
from (        
  	select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, linkagepath, z.entity_id, z.total_port, 
    z.interface_id, 1 port_cnt,  
	case when zz.ifoperstatus is null or zz.ifoperstatus!=1 then 0 else 1 end used_cnt
    from
    (select y.*, yy.bld_entity_id, yy.bld_entity_name, yyy.floor_entity_id, yyy.floor_entity_name, yyyy.area_entity_id, yyyy.area_entity_name
    from  
	(        
        select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port, t.interface_id,
                 t.entity_name, tt.linkagepath, unnest(tt.linkagepath) parent_tree_id
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port, e.id interface_id,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d, lscms_cms_interface e where a.id=e.entity_id and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                and d.type_id in (
                    select id from lscms_common_code 
                    where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                    	<![CDATA[  and name in ('L2 Switch', 'L3 Switch')) ]]>	
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
    ) y left join
     (
        select  
            a.id bld_entity_id, a.name bld_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
    ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
     left join 
    (
        select  
            a.id floor_entity_id, a.name floor_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
    ) yyy on y.parent_tree_id=yyy.floor_entity_id 
     left join 
    (
        select  
            a.id area_entity_id, a.name area_entity_name
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
    ) yyyy on y.parent_tree_id=yyyy.area_entity_id
     
    ) z left join
    (
				select --*
		            a.id, a.ip, b.id interface_id, c.name ifname, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex, c.ifadminstatus, c.ifoperstatus 
		            from lscms_cms_entity a, lscms_cms_interface b, snmpinterface c
				where a.id=b.entity_id and upper(b.mac_address::TEXT)=replace(upper(c.physaddr), ' ', ':')
    ) zz on z.interface_id=zz.interface_id
    ) zzz where 1=1
    group by entity_id, interface_id
 )
        select * from
        (
        select  0 AS rnk, site_id, site_name, null::integer bld_entity_id, null bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name
        union all            
        select  1 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name
        union all            
        select  2 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name
        union all
        select  3 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,           
	sum(port_cnt) - sum(used_cnt) available_port_cnt
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
        ) sub 
        where 1=1
     <if test="site_id != null and site_id  gt 0">
        and	site_id=#{site_id}
     </if>
     <if test="bld_entity_id != null and bld_entity_id  gt 0">
        and	bld_entity_id=#{bld_entity_id}
     </if>  
        order by site_id,  bld_entity_id NULLS FIRST, floor_entity_id NULLS FIRST, area_entity_id NULLS FIRST, rnk

 	</select>
		
	
	<select id="retrievePatchPortUsageRate"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		),
        temp as 
(
	select  max(site_id) site_id, max(site_name) site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(area_entity_id) area_entity_id, max(area_entity_name)area_entity_name, max(linkagepath) linkagepath, max(entity_id) entity_id, 
        max(port_cnt) port_cnt, max(used_cnt) used_cnt
from (        
  	select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, linkagepath, z.entity_id, z.total_port, 
    interface_id, 1 port_cnt,  
	case when zz.interface is null then 0 else 1 end used_cnt
    from
    (select y.*, yy.bld_entity_id, yy.bld_entity_name, yyy.floor_entity_id, yyy.floor_entity_name, yyyy.area_entity_id, yyyy.area_entity_name
    from  
	(        
        select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port, t.interface_id,
                 t.entity_name, tt.linkagepath, unnest(tt.linkagepath) parent_tree_id
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port, e.id interface_id,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d, lscms_cms_interface e where a.id=e.entity_id and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                and d.type_id=(
                        select id from lscms_common_code 
                        where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                        and name = 'Patch Panel')
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
    ) y left join
     (
        select  
            a.id bld_entity_id, a.name bld_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
    ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
     left join 
    (
        select  
            a.id floor_entity_id, a.name floor_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
    ) yyy on y.parent_tree_id=yyy.floor_entity_id 
     left join 
    (
        select  
            a.id area_entity_id, a.name area_entity_name
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
    ) yyyy on y.parent_tree_id=yyyy.area_entity_id
     
    ) z left join
    (
    		select distinct interface, entity_id from
		(
		select interface_a_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_a_id=b.id
		and (linkage_connection_id, interface_a_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )
		    union all
		select interface_b_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_b_id=b.id
		and (linkage_connection_id, interface_b_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )    
		) u
    ) zz on z.interface_id=zz.interface   
    ) zzz where 1=1
    group by entity_id, interface_id
 )
        select * from
        (
        select  0 AS rnk, site_id, site_name, null::integer bld_entity_id, null bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name
        union all            
        select  1 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, null::integer floor_entity_id, null floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name
        union all            
        select  2 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null::integer area_entity_id, null area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,          
	sum(port_cnt) - sum(used_cnt) available_port_cnt  
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name
        union all
        select  3 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate ,           
	sum(port_cnt) - sum(used_cnt) available_port_cnt
        from temp group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
        ) sub 
        where 1=1
 <if test="site_id != null and site_id  gt 0">
	and	site_id=#{site_id}
 </if>
 <if test="bld_entity_id != null and bld_entity_id  gt 0">
	and	bld_entity_id=#{bld_entity_id}
 </if>  
        order by site_id,  bld_entity_id NULLS FIRST, floor_entity_id NULLS FIRST, area_entity_id NULLS FIRST, rnk
        		
	</select>
		
	<select id="retrievePatchPortUsageRate_20181031"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
   		WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		)        
select site_id, site_name, bld_entity_id, bld_entity_name,  floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float) *100, '999') end utilization_rate
    from (
	select  max(site_id) site_id, max(site_name) site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(area_entity_id) area_entity_id, max(area_entity_name)area_entity_name, max(linkagepath) linkagepath, max(entity_id) entity_id, 
        max(port_cnt) port_cnt, max(used_cnt) used_cnt
from (        
  	select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, linkagepath, z.entity_id, z.total_port, 
    interface_id, 1 port_cnt,  
	case when zz.interface is null then 0 else 1 end used_cnt
    from
    (select y.*, yy.bld_entity_id, yy.bld_entity_name, yyy.floor_entity_id, yyy.floor_entity_name, yyyy.area_entity_id, yyyy.area_entity_name
    from  
	(        
        select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port, t.interface_id,
                 t.entity_name, tt.linkagepath, unnest(tt.linkagepath) parent_tree_id
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port, e.id interface_id,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d, lscms_cms_interface e where a.id=e.entity_id and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                and d.type_id=(
                        select id from lscms_common_code 
                        where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                        and name = 'Patch Panel')
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
    ) y left join
     (
        select  
            a.id bld_entity_id, a.name bld_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
    ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
     left join 
    (
        select  
            a.id floor_entity_id, a.name floor_entity_name 
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
    ) yyy on y.parent_tree_id=yyy.floor_entity_id 
     left join 
    (
        select  
            a.id area_entity_id, a.name area_entity_name
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
    ) yyyy on y.parent_tree_id=yyyy.area_entity_id
     
    ) z left join
    (
    		select distinct interface, entity_id from
		(
		select interface_a_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_a_id=b.id
		and (linkage_connection_id, interface_a_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )
		    union all
		select interface_b_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_b_id=b.id
		and (linkage_connection_id, interface_b_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )    
		) u
    ) zz on z.interface_id=zz.interface   
    ) zzz group by entity_id, interface_id
 ) zzzz 
  where 1=1
 <if test="site_id != null and site_id  gt 0">
	and	site_id=#{site_id}
 </if>
 <if test="bld_entity_id != null and bld_entity_id  gt 0">
	and	bld_entity_id=#{bld_entity_id}
 </if>
 group by site_id, site_name, bld_entity_id, bld_entity_name,  floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
 order by used_port_cnt desc
        		
	</select>
	

	<select id="retrievePatchPortUsageRate_old"  resultType="java.util.HashMap">	
 		WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		) 
    
select site_id, site_name, bld_entity_id, bld_entity_name, sum(port_cnt) total_port_cnt, sum(used_cnt) used_port_cnt,   
	sum(port_cnt) - sum(used_cnt) available_port_cnt,  
	case when sum(port_cnt)=0 then '0.00'
	else TO_CHAR(CAST(sum(used_cnt) AS float) /CAST(sum(port_cnt) AS float), '0.99') end utilization_rate
	from(
	select site_id, site_name, bld_entity_id, bld_entity_name, total_port port_cnt, count(interface) used_cnt
    from
    (select *
    from  
	(        
        select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port,
                 t.entity_name,  unnest(tt.linkagepath) parent_tree_id
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d where a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                and d.type_id=(
                        select id from lscms_common_code 
                        where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                        and name = 'Patch Panel')
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
    ) y,
     (
        select  
            a.id bld_entity_id, a.name bld_entity_name, c.name type_name
            from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id 
    ) yy where y.parent_tree_id=yy.bld_entity_id   and yy.type_name='Building'
    ) z left join
    (
    		select distinct interface, entity_id from
		(
		select interface_a_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_a_id=b.id
		and (linkage_connection_id, interface_a_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )
		    union all
		select interface_b_id interface, b.entity_id from lscms_cms_linkage_connection_interface a, lscms_cms_interface b where a.interface_b_id=b.id
		and (linkage_connection_id, interface_b_id) in (
		select linkage_connection_id, e.id from lscms_cms_linkage_connection_patchpanel a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_entity d, lscms_cms_interface e
		where a.sitetree_id=b.id and b.site_id=c.id and b.entity_id=d.id and d.id=e.entity_id and c.is_deleted=False and d.is_deleted=False
		    )    
		) u
    ) zz on z.entity_id=zz.entity_id    group by site_id, site_name, bld_entity_id, bld_entity_name, z.entity_id, z.total_port
        ) v   group by site_id, site_name, bld_entity_id, bld_entity_name
        order by site_id, bld_entity_id
        		
	</select>	
	
	<select id="getCMSSiteList"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
 		select * from 
        (select a.id, a.name
		from lscms_cms_site a
        where 1=1
		and a.is_deleted is False) x
        left outer join lscms_systemuser_cms_site y
        on x.id=y.cms_site_id
        where 1=1	         

	</select>		

	<select id="getCMSBuildingList"  parameterType="int" resultType="java.util.HashMap">	
     	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		)  
        select  t.entity_id as id, t.entity_name as name
                 from
        (
            select  
                b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port,
                b.site_id, a.name as entity_name, c.name as site_name 
                from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d where a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                and d.type_id=(
                        select id from lscms_common_code 
                        where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                        and name = 'Building')
        ) t, topdownsearchtree tt where t.sitetree_id=tt.id       
        and t.site_id = #{site_id}
	</select>		
	
	<select id="getCMSFSubList"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
	select * from
	(
	 select distinct 
        <if test="site_id == null or site_id == 0">
			site_id as id, site_name as name
		</if>	 
        <if test="site_id != null and site_id gt 0 and (building_id == null or building_id == 0)">
			bld_entity_id as id, bld_entity_name  as name
		</if>
        <if test="building_id != null and building_id gt 0">
			floor_entity_id as id, floor_entity_name  as name
		</if>				
	 from lscms_view_cmsinfo_device
		where 1=1
        <if test="site_id != null and site_id gt 0">
			and site_id = #{site_id} and bld_entity_id is not null
		</if>			
        <if test="building_id != null and building_id gt 0">
			and bld_entity_id=#{building_id} and floor_entity_id is not null
		</if>	
		) x		
		order by id
	</select>	
		
	<select id="getRealtimeAlarmList"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::TEXT[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id and a.type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where name='CMS Category Type') and name='Floor')
          and a.parent_id is not null and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, 
           array_append(b.linkagepath, (select name::TEXT from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))) 
            --b.linkagepath || (select name from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))
		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		) 
        select  xxx.* from
        (
        select z.*, xx.location, (ROW_NUMBER() OVER(partition BY z.source, z.entity)) AS ROWNUM from 
        (
            select  SOURCE,CATEGORY,AL.ENTITY,AL.DISPLAYNAME,AL.SEVERITY,MMESSAGE,MODTIME, eventtype
              from Alert AL WHERE AL.SEVERITY!=5  order by AL.MODTIME DESC        
        ) z  left join      
        (
        select t.*, array_to_string(tt.linkagepath, '>>') as location
        --string_agg(tt.linkagepath, '>>') 
        from
        (
		select b.id, b.site_id, a.name as entity_name, a.asset_tag as entity_asset_tag, a.comments as entity_comments, 
		a.opm_name as entity_opm_name, a.ip as entity_ip, c.name as site_name, c.description as site_description,
		d.name as region_name, b.type_id
		from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_region d
		where a.id=b.entity_id and b.site_id=c.id and a.is_deleted=False and c.region_id=d.id
        ) t ,
        topdownsearchtree tt where t.id=tt.id 
        ) xx on z.source =xx.entity_opm_name
            ) xxx 
        where xxx.rownum=1    
        and xxx.source = #{source}
        order by xxx.MODTIME DESC
	</select>
	
	<select id="searchCMSEntitySummary"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
   		WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))

		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		)  
      select v.site_id, v.site_name, v.region_name, v.bld_entity_id, v.bld_entity_name
        <if test="floorflag != null and floorflag == 'checked'">
		, v.floor_entity_id ,  v.floor_entity_name 
		</if>	 
        , v.type_id, v.type_name, v.ci_id, v.ci_name, count(*) total_cnt
      from
      (
        select t.*, tt.bld_entity_id, tt.bld_entity_name , tt.floor_entity_id , tt.floor_entity_name, array_to_string(tt.linkagepath, '>>') as location from
        (
		select a.id, b.site_id, a.name as entity_name, a.asset_tag as entity_asset_tag, a.comments as entity_comments, 
		a.opm_name as entity_opm_name, a.ip as entity_ip, c.name as site_name, c.description as site_description,
		d.name as region_name, b.type_id, 
        (select name from lscms_common_code where group_id=(select id from lscms_common_code where group_id is null and name='CMS Category Type') and id=b.type_id) type_name, 
        e.id ci_id, e.name ci_name, e.description ci_description
		from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_region d, lscms_cms_category e	      
		where a.id=b.entity_id and b.site_id=c.id and a.is_deleted=False and c.region_id=d.id and a.category_id=e.id
       ) t, 
        (
        select  site_id, site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(linkagepath) linkagepath, entity_id
        from 
            (        
                select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port,
                         t.entity_name, tt.linkagepath, unnest(tt.linkagepath) parent_tree_id
                         from
                (
                    select  
                        b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port,
                        b.site_id, a.name as entity_name, c.name as site_name 
                        from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d where 1=1 and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                        and d.type_id in (
                                select id from lscms_common_code 
                                where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                                and name not in ('Site', 'Building', 'Floor', 'Area'))
                ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
            ) y left join
             (
                select  
                    a.id bld_entity_id, a.name bld_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
            ) yy on y.parent_tree_id=yy.bld_entity_id   --and yy.type_name in ('Building')
             left join 
            (
                select  
                    a.id floor_entity_id, a.name floor_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
            ) yyy on y.parent_tree_id=yyy.floor_entity_id 
            where 1=1         
             group by y.site_id, y.site_name, y.entity_id --, yy.bld_entity_id, yy.bld_entity_name,  yyy.floor_entity_id, yyy.floor_entity_name, yyyy.area_entity_id, yyyy.area_entity_name
            ) tt where t.id=tt.entity_id
		<if test="keyword != null and keyword != ''">
		and (t.entity_name like '%' ||  #{keyword} || '%' or t.entity_asset_tag like '%' ||  #{keyword} || '%')
		</if>	
		<if test="type != null">
		and (t.type_id=#{type})		
		</if>	  
       ) v where 1=1
             <if test="site_id != null and site_id  gt 0">
            	and	v.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	v.bld_entity_id=#{bld_entity_id}
             </if>
             <if test="floor_entity_id != null and floor_entity_id  gt 0">
             	and	v.floor_entity_id=#{floor_entity_id}
             </if>          
       group by  v.site_id, v.site_name, v.region_name, v.bld_entity_id, v.bld_entity_name
        <if test="floorflag != null and floorflag == 'checked'">
		, v.floor_entity_id ,  v.floor_entity_name 
		</if>	            
        , v.type_id, v.type_name, v.ci_id, v.ci_name
        order by v.site_name, v.region_name, v.bld_entity_name
        <if test="floorflag != null and floorflag == 'checked'">
		, v.floor_entity_name
		</if>	        
		, v.type_name, v.ci_name
	</select>	
	
	
	<select id="getCurrentEndUsersTraffic"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		with temp as (
		 select comm.ID ,mo.NAME as NAME, mo.DISPLAYNAME DISPNAME, replace(upper(si.physaddr), ' ', ':') mac_address, COLLECTIONTIME, (INOCTETS*8*1000/(DELTATIME)+OUTOCTETS*8*1000/(DELTATIME)) G, ipa.PARENTNODE DEVICENAME, (INOCTETS*8*1000/(DELTATIME)) RCV,(OUTOCTETS*8*1000/(DELTATIME)) TRANS,si.IFSPEEDIN SPEEDIN, si.IFSPEEDOUT SPEEDOUT 
		                                                                              from SnmpInterface si 
		                                                                              INNER JOIN ManagedObject mo ON si.NAME=mo.NAME AND IFSPEEDIN!=0 AND IFSPEEDOUT!=0 INNER JOIN IpAddress ipa ON si.NAME=ipa.NAME 
            INNER JOIN ${tablename} comm ON mo.MOID=comm.ID AND COLLECTIONTIME  BETWEEN #{starttimehr} AND  #{endtimehr}
		                                                                              where 1=1
		                                                                              order by comm.ID ,mo.NAME , mo.DISPLAYNAME , COLLECTIONTIME desc
		),		
        temp1 as (
            select  xx.site_id, xx.site_name, xx.bld_entity_id, xx.bld_entity_name, xx.floor_entity_id, xx.floor_entity_name, xx.area_entity_id, xx.area_entity_name, COALESCE(sum(x.cnt), 0) enduser_cnt, COALESCE(sum(x.traffic), 0)  enduser_traffic from
           	lscms_view_cmsinfo_interface xx left join            
            (
            select y.* from 
                (
                select temp.dispname, temp. mac_address, 1 cnt, avg(temp.g) traffic from temp where 1=1
            	and temp.id in (select id from temp group by id order by sum(g))
            	group by  temp.dispname, temp. mac_address
                )y, lscms_view_connectioninfo yy where y.mac_address=yy.macaddress                
            ) x on  upper(xx.mac_address::TEXT)=(x.mac_address) 
            where 1=1         
             <if test="site_id != null and site_id  gt 0">
            	and	xx.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	xx.bld_entity_id=#{bld_entity_id}
             </if>            
            group by xx.site_id, xx.site_name, xx.bld_entity_id, xx.bld_entity_name, xx.floor_entity_id, xx.floor_entity_name, xx.area_entity_id, xx.area_entity_name
            order by xx.site_id, xx.site_name, xx.bld_entity_id nulls first, xx.bld_entity_name, xx.floor_entity_id nulls first, xx.floor_entity_name, xx.area_entity_id nulls first, xx.area_entity_name )
        select * from
        (
        select  0 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null area_entity_id, null area_entity_name, sum(enduser_cnt) enduser_cnt, pg_size_pretty(sum(enduser_traffic)::bigint) pretty_enduser_traffic, sum(enduser_traffic) enduser_traffic
        from temp1 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name
        union all
        select  1 AS rnk, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, sum(enduser_cnt) enduser_cnt, pg_size_pretty(sum(enduser_traffic)::bigint) pretty_enduser_traffic, sum(enduser_traffic) enduser_traffic
        from temp1 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
        ) sub order by site_name, bld_entity_name nulls first, floor_entity_name nulls first, rnk, area_entity_name nulls first
	</select>	
	
	<select id="getEndUsersStats"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
		with temp as (
		select x.s, x.dt, x.site_id, x.site_name, x.bld_entity_id, x.bld_entity_name, x.floor_entity_id, x.floor_entity_name, x.area_entity_id, x.area_entity_name, COALESCE((enduser_cnt), 0) enduser_cnt, COALESCE((enduser_duration), 0) enduser_duration 
		   from (select a.s, a.dt, b.site_id,  b.site_name, b.bld_entity_id, b.bld_entity_name, b.floor_entity_id, b.floor_entity_name, b.area_entity_id, b.area_entity_name, b.entity_name, b.port_no from (SELECT lpad(s::text,2,'0') as dt, s FROM generate_series(1,31) as t(s)) a, lscms_view_cmsinfo_interface b ) x 
		left join lscms_ipam_accessstat xx on '201810'|| x.dt=xx.stat_date
            where 1=1
             <if test="site_id != null and site_id  gt 0">
            	and	x.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	x.bld_entity_id=#{bld_entity_id}
             </if> 		
		--where xx.stat_date between '20181001' and '20181031'
		--group by x.site_id, x.site_name, x.bld_entity_id, x.bld_entity_name, x.floor_entity_id, x.floor_entity_name, x.area_entity_id, x.area_entity_name, x.s
		--order by x.site_id, x.site_name, x.bld_entity_id, x.bld_entity_name, x.floor_entity_id, x.floor_entity_name, x.area_entity_id, x.area_entity_name, x.s
		)
		SELECT
		  site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name,
		  array_agg( (enduser_cnt)) As counts,
		  array_agg( (enduser_duration)) AS connections
		FROM temp
		GROUP BY site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, s
		ORDER BY site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, s;


	</select>	
	
	<select id="getEndUsersStatsMonthly"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
    	WITH temp2 as
			(
			select v.*, vv.yyyymm, vv.enduser_cnt, vv.enduser_duration from
			(
			select a.dt, b.* from (
						<if test="type != null and type =='yearly'">
							SELECT dd::text dt from
							generate_series
							        ( #{startmonthint}
							        , #{endmonthint}) dd
						</if>
						
			 			<if test="type != null and type =='monthly'">
							SELECT to_char(dd, 'YYYYMM') dt from
							generate_series
							        ( #{startmonthint}::timestamp 
							        , #{endmonthint}::timestamp
							        , '1 month'::interval) dd
						</if>	
						<if test="type != null and type =='daily'">
							SELECT to_char(dd, 'YYYYMMDD') dt from
							generate_series
							        ( #{startmonthint}::timestamp 
							        , #{endmonthint}::timestamp
							        , '1 day'::interval) dd
						</if>	
						<if test="type != null and type =='dailypick'">
							SELECT lpad(dd::text, 2, '0') dt from
							generate_series
							        ( #{startmonthint}
							        , #{endmonthint}) dd
						</if>							        
			           		) a,
			           lscms_view_cmsinfo_interface b
			 ) v          
			           left join
			(select 
             <if test="type != null and type =='monthly'">
            	substring(stat_date, 1, 6) yyyymm, 
             </if>			
             <if test="type != null and type =='yearly'">
            	substring(stat_date, 1, 4) yyyymm, 
             </if>	
             <if test="type != null and type =='daily'">
            	(stat_date) yyyymm, 
             </if>	   
             <if test="type != null and type =='dailypick'">
            	stat_hr yyyymm, 
             </if>                       					
			max(enduser_cnt) enduser_cnt, sum(enduser_duration) enduser_duration,
			(select name from lscms_cms_site where id=x.site_id) site_name,
			(select name from lscms_cms_entity where id=x.building_id) building_name,
			(select name from lscms_cms_entity where id=x.floor_id) floor_name,
			(select name from lscms_cms_entity where id=x.area_id) area_name
			from lscms_ipam_accessstat x
			where x.stat_date between #{startmonth} and #{endmonth}	
             <if test="type != null and type =='monthly'">
            	group by substring(stat_date, 1, 6), 
             </if>			
             <if test="type != null and type =='yearly'">
            	group by substring(stat_date, 1, 4), 
             </if>		
             <if test="type != null and type =='daily'">
            	group by (stat_date) , 
             </if>   
             <if test="type != null and type =='dailypick'">
            	group by (stat_hr) ,
             </if>                          						
			 site_name, building_name, floor_name, area_name
			 ) vv on v.site_name=vv.site_name and v.bld_entity_name=vv.building_name and v.floor_entity_name=vv.floor_name and v.area_entity_name=vv.area_name
			 where  1=1
             <if test="site_id != null and site_id  gt 0">
            	and	v.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	v.bld_entity_id=#{bld_entity_id}
             </if> 	
			    ),
    temp3 as (
    SELECT case when dt=yyyymm then enduser_cnt else 0 end  enduser_cnt, 
        case when dt=yyyymm then enduser_duration else 0 end  enduser_duration, dt, yyyymm, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
		FROM temp2
		ORDER BY site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name nulls first, yyyymm
        )
        select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name,
          array_agg( enduser_cnt) As counts,
		  array_agg( enduser_duration)  AS connections
        from 
        (
        select * from
        (
        select  0 AS rnk, dt, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null area_entity_id, null area_entity_name, 
		  max(enduser_cnt) enduser_cnt,
		  max(enduser_duration)  enduser_duration           
        from temp3 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, dt
        union all
        select  1 AS rnk, dt, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, 
		  max(enduser_cnt) enduser_cnt,
		  max(enduser_duration)  enduser_duration               
        from temp3 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, dt
        ) sub order by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, rnk, area_entity_id nulls first, area_entity_name nulls first, rnk, dt
 		) k group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, rnk
        order by site_name, bld_entity_name, floor_entity_name, area_entity_name  nulls first, rnk
	</select>	
	

	<select id="getEndUsersStatsMonthly_20181109"  parameterType="java.util.HashMap" resultType="java.util.HashMap">	
    	WITH RECURSIVE topdownsearchtree AS (
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, ARRAY[]::integer[] AS linkagepath, ARRAY[]::TEXT[] AS linkagepathname
		  FROM lscms_cms_sitetree a, lscms_cms_site b 
          WHERE a.site_id=b.id 
          and a.parent_id is null  and b.is_deleted=False		 
		  UNION ALL		 
		  SELECT a.id, a.site_id, a.type_id, a.level, a.level_rank, a.entity_id, a.parent_id, array_append(b.linkagepath, (select id from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id)))
			,array_append(b.linkagepathname, (select name::TEXT from lscms_cms_entity where id=(select entity_id from lscms_cms_sitetree where id=a.parent_id))) 
		  FROM lscms_cms_sitetree a, topdownsearchtree b
		  WHERE a.parent_id = b.id 
		), 
      temp as(
        select  distinct site_id, site_name, max(bld_entity_id) bld_entity_id, max(bld_entity_name) bld_entity_name, 
		max(floor_entity_id) floor_entity_id, max(floor_entity_name) floor_entity_name,
        max(area_entity_id) area_entity_id, max(area_entity_name)area_entity_name --, max(linkagepath) linkagepath, max(linkagepathname) linkagepathname, entity_id
        from 
            (        
                select  t.site_id,  t.site_name, t.sitetree_id,  t.sitetree_parent_id,  t.entity_id, t.total_port,
                         t.entity_name, tt.linkagepath, tt.linkagepathname, unnest(tt.linkagepath) parent_tree_id
                         from
                (
                    select  
                        b.id sitetree_id, b.parent_id sitetree_parent_id, a.id entity_id, d.total_port,
                        b.site_id, a.name as entity_name, c.name as site_name 
                        from lscms_cms_entity a, lscms_cms_sitetree b, lscms_cms_site c, lscms_cms_category d where 1=1 and a.category_id=d.id and b.entity_id=a.id  and b.site_id=c.id  and a.is_deleted=False  and c.is_deleted=False
                        and d.type_id in (
                                select id from lscms_common_code 
                                where group_id = (select id from lscms_common_code where group_id is null and name='CMS Category Type')
                                and name not in ('Site', 'Building', 'Floor', 'Area'))
                ) t, topdownsearchtree tt where t.sitetree_id=tt.id     
            ) y left join
             (
                select  
                    a.id bld_entity_id, a.name bld_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Building')
            ) yy on y.parent_tree_id=yy.bld_entity_id 
             left join 
            (
                select  
                    a.id floor_entity_id, a.name floor_entity_name 
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Floor')
            ) yyy on y.parent_tree_id=yyy.floor_entity_id 
             left join 
            (
                select  
                    a.id area_entity_id, a.name area_entity_name
                    from lscms_cms_entity a, lscms_cms_category b, lscms_common_code c where a.category_id=b.id and b.type_id=c.id  and c.name in ('Area')
            ) yyyy on y.parent_tree_id=yyyy.area_entity_id
            where 1=1
              
             group by y.site_id, y.site_name, y.entity_id 
  			order by site_id, bld_entity_id NULLS first, floor_entity_id NULLS first, area_entity_id NULLS first
			), temp2 as
			(
			select v.*, vv.yyyymm, vv.enduser_cnt, vv.enduser_duration from
			(
			select a.dt, b.* from (
						<if test="type != null and type =='yearly'">
							SELECT dd::text dt from
							generate_series
							        ( #{startmonthint}
							        , #{endmonthint}) dd
						</if>
						
			 			<if test="type != null and type =='monthly'">
							SELECT to_char(dd, 'YYYYMM') dt from
							generate_series
							        ( #{startmonthint}::timestamp 
							        , #{endmonthint}::timestamp
							        , '1 month'::interval) dd
						</if>	
						<if test="type != null and type =='daily'">
							SELECT to_char(dd, 'YYYYMMDD') dt from
							generate_series
							        ( #{startmonthint}::timestamp 
							        , #{endmonthint}::timestamp
							        , '1 day'::interval) dd
						</if>	
						<if test="type != null and type =='dailypick'">
							SELECT lpad(dd::text, 2, '0') dt from
							generate_series
							        ( #{startmonthint}
							        , #{endmonthint}) dd
						</if>							        
			           		) a,
			           temp b
			 ) v          
			           left join
			(select --* 
             <if test="type != null and type =='monthly'">
            	substring(stat_date, 1, 6) yyyymm, 
             </if>			
             <if test="type != null and type =='yearly'">
            	substring(stat_date, 1, 4) yyyymm, 
             </if>	
             <if test="type != null and type =='daily'">
            	(stat_date) yyyymm, 
             </if>	   
             <if test="type != null and type =='dailypick'">
            	stat_hr yyyymm, 
             </if>                       					
			max(enduser_cnt) enduser_cnt, sum(enduser_duration) enduser_duration,
			--stat_date, stat_hr,
			(select name from lscms_cms_site where id=x.site_id) site_name,
			(select name from lscms_cms_entity where id=x.building_id) building_name,
			(select name from lscms_cms_entity where id=x.floor_id) floor_name,
			(select name from lscms_cms_entity where id=x.area_id) area_name
			--site_id, building_id, floor_id, area_id, enduser_cnt, enduser_duration
			from lscms_ipam_accessstat x
			where x.stat_date between #{startmonth} and #{endmonth}	
             <if test="type != null and type =='monthly'">
            	group by substring(stat_date, 1, 6), 
             </if>			
             <if test="type != null and type =='yearly'">
            	group by substring(stat_date, 1, 4), 
             </if>		
             <if test="type != null and type =='daily'">
            	group by (stat_date) , 
             </if>   
             <if test="type != null and type =='dailypick'">
            	group by (stat_hr) ,
             </if>                          						
			 site_name, building_name, floor_name, area_name
			 ) vv on v.site_name=vv.site_name and v.bld_entity_name=vv.building_name and v.floor_entity_name=vv.floor_name and v.area_entity_name=vv.area_name
			 where  1=1
             <if test="site_id != null and site_id  gt 0">
            	and	v.site_id=#{site_id}
             </if>
             <if test="bld_entity_id != null and bld_entity_id  gt 0">
            	and	v.bld_entity_id=#{bld_entity_id}
             </if> 	
			    ),
    temp3 as (
    SELECT case when dt=yyyymm then enduser_cnt else 0 end  enduser_cnt, 
        case when dt=yyyymm then enduser_duration else 0 end  enduser_duration, dt, yyyymm, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name
		FROM temp2
        --where site_id != 136
		--GROUP BY site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, yyyymm
		ORDER BY site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name nulls first, yyyymm
        )
        select site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name,
          array_agg( enduser_cnt) As counts,
		  array_agg( enduser_duration)  AS connections
        from 
        (
        select * from
        (
        select  0 AS rnk, dt, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, null area_entity_id, null area_entity_name, 
		  sum(enduser_cnt) enduser_cnt,
		  sum(enduser_duration)  enduser_duration          
        from temp3 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, dt
        union all
        select  1 AS rnk, dt, site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, 
		  sum(enduser_cnt) enduser_cnt,
		  sum(enduser_duration)  enduser_duration             
        from temp3 group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, dt
        ) sub order by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, rnk, area_entity_id nulls first, area_entity_name nulls first, rnk, dt
 		) k group by site_id, site_name, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, rnk
        order by site_name, bld_entity_name, floor_entity_name, area_entity_name  nulls first, rnk
	</select>		
	
	<select id="getTempUserInfo" resultType="java.util.HashMap">
		select upper(mac_address::TEXT) mac_address, system_name from lscms_ipam_temp_user
		where ip_address=#{clientIP}::INET limit 1
	</select>		

	<delete id="deleteTempUser"  parameterType="java.lang.String" >
		delete from lscms_ipam_temp_user
		where
		mac_address = #{mac_address}::varchar
	</delete>			

	<select id="getSwitchMac" resultType="java.lang.String">
		 select upper(b.mac_address::TEXT) mac_address from lscms_cms_entity a, lscms_cms_interface b, lscms_cms_sitetree c 
		 where a.id=b.entity_id and a.id=c.entity_id 
		 and c.id=#{nodeid} and b.name=#{portname}
	</select>	
		
	<select id="getRackListForDCIM" resultType="java.util.HashMap">
		SELECT b.parent_id rackspace_node_id, b.id node_id, a.id, a.id entity_id, a.site_id, entity_name "deviceName", entity_name "displayName", entity_asset_tag, entity_comments, entity_opm_name, entity_ip, site_name, site_description, region_name, a.type_id, type_name, ci_id, ci_name, ci_description, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, location2, location
		FROM lscms_view_cmsinfo_device a, lscms_cms_sitetree b
	    where a.id=b.entity_id
        and area_entity_id=(select entity_id from lscms_cms_sitetree where id=#{area_id}) and a.type_id=(select id from lscms_common_code where group_id=(select id from lscms_common_code where name='CMS Category Type') and name='Rack')
	</select>	
	
	<select id="get3DRackDetail_1209" resultType="java.util.HashMap">
		select b.parent_id rackspace_node_id, b.id node_id, a.id, a.id entity_id, a.site_id, entity_name "deviceName", entity_name "displayName", entity_asset_tag, entity_comments, entity_opm_name, entity_ip, site_name, site_description, region_name, a.type_id, type_name, ci_id, ci_name, ci_description, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, location2, location, e.image_rack_front image_rack_front3d, e.image_rack_rear image_rack_rear3d 
		from lscms_view_cmsinfo_device a, lscms_cms_sitetree b, lscms_cms_entity c, lscms_cms_category d, lscms_cms_category_3d_texture e
		where a.id=b.entity_id and b.id=c.id and a.ci_id=d.id and d.id=e.category_id and b.parent_id=#{rack_id}
	</select>		
	
	<select id="get3DRackDetail" resultType="java.util.HashMap">
		select x.position_u, y.* from
		(
		select b.sitetree_palcement_entity_id entity_id, b.position_rack, b.position_u  from lscms_cms_sitetree_placement a, lscms_cms_sitetree_rackspace_position b, lscms_cms_sitetree c --, lscms_cms_entity d
		WHERE a.id=b.sitetree_placement_id --and b.sitetree_palcement_entity_id=d.id 
		and a.sitetree_id=c.id and a.sitetree_id=(select parent_id from lscms_cms_sitetree where id=#{rack_id})
		) x,
		(
		    		select b.parent_id rackspace_node_id, b.id node_id, a.id, a.id entity_id, a.site_id, entity_name "deviceName", entity_name "displayName", entity_asset_tag, entity_comments, entity_opm_name, entity_ip, site_name, site_description, region_name, a.type_id, type_name, ci_id, ci_name, ci_description, bld_entity_id, bld_entity_name, floor_entity_id, floor_entity_name, area_entity_id, area_entity_name, location2, location, e.image_rack_front image_rack_front3d, e.image_rack_rear image_rack_rear3d 
				from lscms_view_cmsinfo_device a, lscms_cms_sitetree b, lscms_cms_entity c, lscms_cms_category d, lscms_cms_category_3d_texture e
				where a.id=b.entity_id and b.id=c.id and a.ci_id=d.id and d.id=e.category_id and b.parent_id=#{rack_id}
		) y where x.entity_id=y.entity_id
	</select>	
			
	<select id="getAllRacksInDCIM" resultType="java.util.HashMap">
		select b.id rack_node_id, a.displayname 
		from lscms_cms_mapwidget_entity a, lscms_cms_sitetree b 
		where a.entity_id=b.entity_id and a.mapwidget_id=#{dcim_widget_id} order by b.id
	</select>	
				
	<insert id="insert3DTexture" parameterType="ProductVO" >
		INSERT INTO lscms_cms_category_3d_texture(
			image_rack_front, image_rack_rear, category_id)
			VALUES (#{image_rack_front3d}, #{image_rack_rear3d}, #{id})
	</insert>		
		
	<delete id="delete3DTexture" parameterType="int" >
		delete from lscms_cms_category_3d_texture
		where category_id=#{id}
	</delete>	

	<select id="getAreaDCIMWidget" resultType="java.util.HashMap">
		select id dcim_widget_id, widgettype_id, (select site_id from lscms_cms_sitetree where id=#{area_id}::Integer) site_id from lscms_widget where widgettype_id =(
		select id from lscms_common_code 
		where group_id = (select id from lscms_common_code where group_id is null and name='Mainpage Widget Type') 
		and name='DCIM') and option_data=#{area_id}::TEXT
	</select>		

	<select id="getAreaDCIMWidget2" resultType="java.util.HashMap">
		select a.mapwidget_id dcim_widget_id, c.widgettype_id from lscms_cms_mapwidget_entity a, lscms_view_cmsinfo_device b, lscms_widget c where a.mapwidget_id=c.id and a.entity_id=b.id and c.widgettype_id=(select id from lscms_common_code where group_id = (select id from lscms_common_code where group_id is null and name='Mainpage Widget Type') and name='DCIM')
		and b.area_entity_id=(select entity_id from lscms_cms_sitetree where id=#{area_id}) group by a.mapwidget_id, c.widgettype_id
	</select>	
			
	<select id="getDCIMWidgetTypeId" resultType="java.lang.Integer">
		select id from lscms_common_code 
		where group_id = (select id from lscms_common_code where group_id is null and name='Mainpage Widget Type') 
		and name='DCIM'
	</select>	
		
	<select id="getSiteIdbyNodeId" resultType="java.lang.Integer">
		select site_id from lscms_cms_sitetree where id=#{node_id}
	</select>	
			
	<select id="getPatchPanelPortStatus" resultType="java.util.HashMap">
		select entity_id, node_id, interface_id, portname, devicename, min(ifadminstatus) ifadminstatus, min(ifoperstatus) ifoperstatus
			from (
				select distinct x.*, x2.* --, z.status  
		        from
				(
				select a.id entity_id, e.id node_id, b.id interface_id, b.name portname, a.name devicename
		            from lscms_cms_entity a, lscms_cms_interface b, lscms_cms_sitetree d, lscms_cms_site e
				where a.id=b.entity_id and a.id=d.entity_id and d.site_id=e.id and e.is_deleted = False and d.id=#{node_id} and e.id=(select site_id from lscms_cms_sitetree where id=#{node_id})
				) x,
				(
				select a.id entity_id2, a.ip, c.name ifname, b.id interface_id2, b.name portname2, a.name devicename2, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex, c.ifadminstatus, c.ifoperstatus 
		            from lscms_cms_entity a, lscms_cms_interface b, snmpinterface c, lscms_cms_sitetree d, lscms_cms_site e
				where a.id=b.entity_id and a.id=d.entity_id and d.site_id=e.id and e.is_deleted = False and upper(b.mac_address::TEXT)=replace(upper(c.physaddr), ' ', ':')
		            and e.id=(select site_id from lscms_cms_sitetree where id=#{node_id})
				)      x2,   
		    (
				select distinct interface_id, connection_list from
				(
								select
						            d.connection_list, a.id, a.ip, b.id interface_id, b.name portname, a.name devicename, a.opm_name, upper(b.mac_address::TEXT) mac_address, b.description, b.ifindex
						            from lscms_cms_entity a, lscms_cms_interface b, lscms_view_linkage_connection_all_array d, lscms_cms_sitetree e, lscms_cms_site f
								where a.id=b.entity_id --and upper(b.mac_address::TEXT)=c.macaddress
				                and b.mac_address = d.mac_address and a.id=e.entity_id and e.site_id=f.id and f.is_deleted = False and f.id=(select site_id from lscms_cms_sitetree where id=#{node_id})
				) xx            
		        
		    ) zzz,    
		        --managedobject z, 
		        IpAddress zz
				where 1=1
		        --z.name=zz.name
		        and x.interface_id = ANY (zzz.connection_list)   
				and x2.opm_name=zz.parentnode
		        and x2.interface_id2 = zzz.interface_id
		        order by x.interface_id, x.portname
		 ) w group by entity_id, node_id, interface_id, portname, devicename
	</select>	
	
	<select id="getUnAuthInfoBySWMac" resultType="java.lang.String">
		select peer_ip_address from lscms_view_connectioninfo
        where macaddress=#{mac_address} and switch_name=#{switch_name} limit 1	
	</select>		
					
</mapper>

