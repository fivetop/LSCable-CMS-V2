        var getUserHistory = function(enduser_name) {
            userHistoryTable = null;
            if (userHistoryTable) userHistoryTable.destroy();

            userHistoryTable = $('#userHistoryTable').DataTable({
                sAjaxDataProp: "",
                paging: true,
                ordering: false,
                info: false,
                destroy: true,
                searching: false,
                dom: 'Bfrtip',
                buttons: [{
                    extend: 'excel',
                    text: 'Excel',
                    className: 'exportExcel',
                    filename: 'User History',
                    exportOptions: {
                        modifier: {
                            page: 'all'
                        }
                    }
                }, {
                    extend: 'csv',
                    text: 'CSV',
                    filename: 'User History',
                    className: 'exportExcel',
                    exportOptions: {
                        modifier: {
                            search: 'none',
                            page: 'all'
                        }
                    }
                }],
                columnDefs: [{
                    visible: false,
                    targets: [3, 5, 11]
                }],
                ajax: {
                    url: "/api/htbackend/getUsageHistory?enduser_name=" + enduser_name,
                    type: 'get'
                }

                ,
                columns: [{
                    "data": "switch_name"
                }, {
                    "data": "switch_ip"
                }, {
                    "data": "switch_port_no"
                }, {
                    "data": "switch_ifindex"
                }, {
                    "data": "switch_mac_address"
                }, {
                    "data": "switch_asset_tag"
                }, {
                    "data": "access_begin"
                }, {
                    "data": "access_end"
                }, {
                    "data": "enduser_name"
                }, {
                    "data": "enduser_mac_address"
                }, {
                    "data": "enduser_ip_address"
                }, {
                    "data": "reg_ip_address"
                }, {
                    "data": "enduser_asset_tag"
                }]
            });

            $("#userHistoryTable_previous").closest("div").addClass('col-sm-12');
            $("#userHistoryTable_paginate").css("text-align", "center");
            $("#userHistoryTable_length").hide();
            $(".dt-buttons").addClass('pull-right');
        };
        //var csv is the CSV file with headers
        var csvJSON = function(csv) {

            var lines = csv.split("\n");

            var result = [];
            lines[0] = lines[0].replace("\r", "");
            var headers = lines[0].split(",");
            for (var i = 1; i < lines.length; i++) {
                if (lines[i].length == 0)
                    continue;
                lines[i] = lines[i].replace("\r", "");
                var obj = {};
                var currentline = lines[i].split(",");

                if (currentline.length > 0) {
                    for (var j = 0; j < headers.length; j++) {
                        if (headers[j] === 'mac_address') {
                            currentline[j] = currentline[j].replace(/\|/g, ',');
                        }
                        obj[headers[j]] = currentline[j];
                    }
                    result.push(obj);
                }
            }

            return JSON.stringify(result); //JSON
        };

        var initbulkdatatable = function() {

            bulk_datatable = null;
            if (bulk_datatable) bulk_datatable.destroy();
            bulk_datatable = $('#bulktable').DataTable({
                paging: true,
                ordering: false,
                info: false,
                destroy: true,
                searching: false,
                columns: [{
                    "data": "name",
                    "title": [[#{terminal_name}]]
                }, {
                    "data": "empno",
                    "title": [[#{usernum}]]
                }, {
                    "data": "mac_address",
                    "title": [[#{mac}]]
                }, {
                    "data": "ip_address",
                    "title": [[#{ip}]]                
                }, {
                    "data": "full_name",
                    "title": [[#{full_name}]]
                }, {
                    "data": "contact",
                    "title": [[#{contact}]]
                }, {
                    "data": "email",
                    "title": [[#{email}]]
                }, {
                    "data": "asset_tag",
                    "title": [[#{assetnum}]]
                }]
            });
            $("#bulktable_paginate").closest("div").unwrap();
            $("#bulktable_paginate").closest("div").addClass('col-sm-12');
            $("#bulktable_paginate").siblings("div").remove();
            $("#bulktable_paginate").css("text-align", "center");
            $("#bulktable_length").hide();
        };

        var openFile = function(event, type) {
            initbulkdatatable();
            var input = event.target;

            var reader = new FileReader(); {
                reader.onload = function() {
                    bulk_datatable.rows.add($.csv.toObjects(reader.result)).draw();
                    globaluserlistjson = csvJSON(reader.result);
                    console.log(globaluserlistjson);
                };
            }
            reader.readAsText(input.files[0]);
        };

        $(document).on("click", "#createBtn", function() {
            var createdata = $("#createForm").serializeArray();
            var data = {};
            $.each(createForm,
                function(i, v) {
                    data[v.name] = v.value;
                });
            console.log(createdata);
            $.ajax({
                url: '/api/htbackend/registerEndUser',
                dataType: 'text',
                contentType: 'application/json',
                data: JSON.stringify(data),
                method: 'post',
                success: function success(r) {
                    //alert("Saved:"+r);
                    $("#create").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            }); //ajax
        });
        $(document).on("click", "#regBulkBtn", function() {
            $.ajax({
                url: '/api/htbackend/registerBulkEndUser',
                dataType: 'text',
                contentType: 'application/json',
                data: globaluserlistjson,
                method: 'post',
                success: function success(r) {
                    //alert("Saved:"+r);
                    $("#myModal").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            }); //ajax
        });
        $(document).on("click", "#viewbutton", function() {
            var enduser_name = $("#modifyForm #name").val();
            getUserHistory(enduser_name);
            /*
		  var getUsageHistory =   function (mac_address) {
			  usageHistoryTable = null;
			    if(usageHistoryTable) usageHistoryTable.destroy();

			    usageHistoryTable = $('#usageHistoryTable').DataTable({
			    	sAjaxDataProp:""
