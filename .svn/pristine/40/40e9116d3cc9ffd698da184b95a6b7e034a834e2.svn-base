        $(document).on("click", "#deletelistBtn", function() {

            $.ajax({
                url: '/api/htbackend/deleteAllEndUser',
                dataType: 'text',
                method: 'get',
                success: function success(r) {
                    $("#myModal2").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            });
        });
        $(document).on("click", "#deleteBtn", function() {

            $.ajax({
                url: '/api/htbackend/deleteEndUser/' + $("#deleteForm #id").val(),
                dataType: 'text',
                contentType: 'application/x-www-form-urlencoded',
                method: 'get',
                success: function success(r) {
                    $("#delete").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            });
        });

        $(document).on("click", "#modifyBtn", function() {
            var modifydata = $("#modifyForm").serializeArray();
            var data = {};
            $.each(modifydata,
                function(i, v) {
                    data[v.name] = v.value;
                });
            console.log(JSON.stringify(data));
            $.ajax({
                url: '/api/htbackend/updateEndUser/' + $("#modifyForm #id").val(),
                dataType: 'text',
                contentType: 'application/json',
                data: JSON.stringify(data),
                method: 'post',
                success: function success(r) {
                    //alert("Saved:"+r);
                    $("#modify").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            });
        });
        /*    
        	 var serialize =   function (tokenfield) {
        	      var items = tokenfield.getItems();
        	      console.log(items);
        	      var prop;
        	      var data = {};
