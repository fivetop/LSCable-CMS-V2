        $(document).ready(function() {
            $.fn.dataTableExt.sErrMode = 'none';
            getEnduserList();

            function getEnduserList() {

                example_datatables = null;
                if (example_datatables) example_datatables.destroy();

                example_datatables = $('#enduser-table').DataTable({
                    sAjaxDataProp: "",
                    paging: false,
                    ordering: false,
                    info: false,
                    destroy: true,
                    searching: false,
                    columnDefs: [{
                        visible: false,
                        targets: [0]
                    }],
                    dom: 'Bfrtip',
                    buttons: [{
                        extend: 'excel',
                        text: 'Excel',
                        className: 'exportExcel',
                        filename: 'EndUser table',
                        exportOptions: {
                            modifier: {
                                page: 'all'
                            }
                        }
                    }, {
                        extend: 'csv',
                        text: 'CSV',
                        filename: 'User History',
                        className: 'exportExcel',
                        exportOptions: {
                            modifier: {
                                search: 'none',
                                page: 'all'
                            }
                        }
                    }],
                    ajax: {
                        url: "/api/htbackend/getEndUser",
                        type: 'get'
                    },
                    columns: [{
                        "data": "id"
                    }, {
                        "data": "name"
                    }, {
                        "data": "empno"
                    }, {
                        "data": "mac_address"
                    }, {
                        "data": "ip_address"
                    }, {
                        "data": "full_name"
                    }, {
                        "data": "contact"
                    }, {
                        "data": "email"
                    }, {
                        "data": "asset_tag"
                    }, {
                        data: null,
                        className: "center",
                        defaultContent: '<div class="btn-group" role="toolbar" aria-label="Toolbar with button groups"><button type="button" class="btn btn-warning-custom" th:text="#{modify}" data-toggle="modal" data-target="#modify" id="modifybutton">' + mod + '</button><button type="button" class="btn btn-danger-custom" data-toggle="modal" data-target="#delete" th:text="#{delete}" id="deletebutton">' + del + '</button><button type="button" class="btn btn-success-custom" data-toggle="modal" data-target="#history" th:text="#{connectlist}" id="viewbutton">' + view + '</button></div>'
                    }]
                });
            };
            $('#enduser-table tbody').on('click', 'tr', function() {
                if ($(this).hasClass('selected')) {
                    $(this).removeClass('selected');
                } else {

                    example_datatables.$('tr.selected').removeClass('selected');
                    $(this).addClass('selected');

                    var d = example_datatables.row(this).data();
                    $("#modifyForm #id").val(d.id);
                    $("#modifyForm #name").val(d.name);
                    $("#modifyForm #empno").val(d.empno);
                    $("#modifyForm #mac_address").val(d.mac_address);
                    $("#modifyForm #ip_address").val(d.ip_address);
                    $("#modifyForm #full_name").val(d.full_name);
                    $("#modifyForm #contact").val(d.contact);
                    $("#modifyForm #email").val(d.email);
                    $("#modifyForm #asset_tag").val(d.asset_tag);
                    $("#deleteForm #id").val(d.id);
                    $("#history_body #id").val(d.id);
                    $("#history_body #mac_address").val(d.mac_address);
                    //getUserHistory(d.mac_address);
                }
            });

        });
        /*]]>*/
    </script>
    <style>
    	.dt-buttons {float: right !important;}
        .table>thead>tr>th {
            padding: 10px 0;
            line-height: 32px;
        }  
        .exportExcel {
            color: #eee;
            padding: 5px;
            background: #79b4c1;
            border: 1px solid #79b4c1;
            margin: 5px;
            cursor: pointer;
        }
        .exportExcel:hover,
        .exportExcel:active:focus {
            background: #4c8a96!important;
            border: 1px solid #4c8a96;
            color: #eee;
        }
        .table>tbody>tr>td,
        .table>tbody>tr>th,
        .table>tfoot>tr>td,
        .table>tfoot>tr>th,
        .table>thead>tr>td,
        .table>thead>tr>th {
            text-align: center;
            vertical-align: middle;
        }
        input[type="file"] {
            display: none;
        }
    </style>
