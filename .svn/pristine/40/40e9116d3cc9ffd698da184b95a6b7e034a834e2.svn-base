<body>

    <div class="page-wrapper" layout:fragment="content">

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="panel-custom-wrap">
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="subpage-menu-border">
                        <h3 th:text="#{ipamuser}" class="title col-sm-6"></h3>
                        <ol class="breadcrumb no-margin-padding col-sm-6  text-right">
                            <li><a href="/ipam2/index" th:href="@{/ipam2/index.html}"><i class="fa fa-dashboard" th:text="' '+#{ipamopt}"></i></a>
                            </li>
                            <li><a href="../ipam2/setting" th:href="@{../ipam2/setting.html}" th:text="#{ipamset}">IPAM-setting</a>
                            </li>
                            <li class="active" th:text="#{ipamuser}">IPAM-user</li>
                        </ol>
                    </div>
                </section>
                <section class="content">
                    <div class="subpage-menu">
                        <div class="modal fade" id="create" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{add}">사용자 추가 등록</h4>
                                    </div>
                                    <div class="modal-body">

                                        <form accept-charset="UTF-8" role="form" method="post" id="createForm">
                                            <div class="form-group">
                                                <label for="name" th:text="#{terminal_name}">단말이름</label>
                                                <input name="name" id="name" type="text" class="form-control" />
                                            </div>

                                            <div class="form-group">
                                                <label for="full_name" th:text="#{full_name}">성명</label>
                                                <input name="full_name" id="full_name" type="text" class="form-control" />
                                            </div>

                                            <div class="form-group">
                                                <label for="empno" th:text="#{usernum}">사원번호</label>
                                                <input name="empno" id="empno" type="text" class="form-control" />
                                            </div>

                                            <div class="form-group">
                                                <label for="asset_tag" th:text="#{assetnum}">자산번호</label>
                                                <input name="asset_tag" id="asset_tag" type="text" class="form-control" />
                                            </div>

                                            <div class="form-group">
                                                <label for="mac_address" th:text="#{mac}">맥주소</label>
                                                <input name="mac_address" id="mac_address" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="ip_address" th:text="#{ipaddress}">ip주소</label>
                                                <input name="ip_address" id="ip_address" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="contact" th:text="#{contact}">연락처</label>
                                                <input name="contact" id="contact" type="text" class="form-control" />
                                            </div>

                                            <div class="form-group">
                                                <label for="email" th:text="#{email}">이메일</label>
                                                <input name="email" id="email" type="text" class="form-control" />
                                            </div>


                                        </form>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary-custom" th:text="#{create}" id="createBtn">등록</button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content" style="width: 1000px;">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{addbk}"></h4>
                                    </div>
                                    <div class="modal-body">
                                        <div class="btn-custom">
                                            <label for="file-upload" class="btn btn-primary-custom" th:text="' '+#{open_csv}">
                                            </label>
                                            <input type="file" id="file-upload" class="upload" onclick="this.value = null" onchange="openFile(event, 'updateForm')" />
                                        </div>
                                        <table class="table table-default " id="bulktable">
                                            <!--<thead>
						<tr>
						
				<th th:text="#{name}" id="name">사용자명</th>
				<th th:text="#{usernum}" id="empno">사원번호</th>
				<th th:text="#{mac}" id="mac_address">MAC</th>
				<th th:text="#{full_name}" id="full_name"></th>
				<th th:text="#{contact}" id="contact"></th>
				<th th:text="#{email}" id="email"></th>
				<th th:text="#{assetnum}" id="asset_tag">재산번호</th>	
						</tr>
				</thead>
				<tbody>
					<tr>
					</tr>
				</tbody>-->
                                        </table>

                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary-custom" id="regBulkBtn" th:text="#{addbk}"></button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal fade" id="myModal2" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{deletelist}">리스트삭제</h4>
                                    </div>
                                    <div class="modal-body">

                                        <span th:text="#{delmsg}">삭제하시겠습니까?</span>

                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary-custom" id="deletelistBtn" th:text="#{deletelist}">삭제</button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal fade" id="delete" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{delete}">삭제</h4>
                                    </div>
                                    <div class="modal-body">
                                        <form accept-charset="UTF-8" role="form" method="get" id="deleteForm">
                                            <input id="id" type="hidden" class="form-control" />
                                            <span th:text="#{delmsg}">삭제하시겠습니까?</span>
                                        </form>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary-custom" id="deleteBtn" th:text="#{delete}">삭제</button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="modal fade" id="modify" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{modify}">사용자 수정</h4>
                                    </div>
                                    <div class="modal-body">

                                        <form accept-charset="UTF-8" id="modifyForm">
                                            <input id="id" name="id" type="hidden" class="form-control" />
                                            <div class="form-group">
                                                <label for="name" th:text="#{terminal_name}">단말이름</label>
                                                <input name="name" id="name" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="full_name" th:text="#{full_name}">성명</label>
                                                <input name="full_name" id="full_name" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="empno" th:text="#{usernum}">사원번호</label>
                                                <input name="empno" id="empno" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="asset_tag" th:text="#{assetnum}">자산번호</label>
                                                <input name="asset_tag" id="asset_tag" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="mac_address" th:text="#{mac}">맥주소</label>
                                                <input name="mac_address" id="mac_address" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="ip_address" th:text="#{ipaddress}">ip주소</label>
                                                <input name="ip_address" id="ip_address" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="contact" th:text="#{contact}">연락처</label>
                                                <input name="contact" id="contact" type="text" class="form-control" />
                                            </div>
                                            <div class="form-group">
                                                <label for="email" th:text="#{email}">이메일</label>
                                                <input name="email" id="email" type="text" class="form-control" />
                                            </div>

                                        </form>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary-custom" th:text="#{modify}" id="modifyBtn">등록</button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="panel panel-wrap">
                            <div class="panel-title">
                                <span class="godo" th:text="#{terminal}+#{list}">IPAM 사용자 리스트</span>
                                <div class="btn-group pull-right">
                                    <a class="btn btn-primary-custom" data-target="#create" data-toggle="modal" id="MainNavHelp" href="#create">
                                        <i class="fa fa-plus" th:text="' '+#{add}"></i>
                                    </a>
                                    <a class="btn btn-primary-custom" data-target="#myModal" data-toggle="modal" id="MainNavHelp" href="#myModal">
                                        <i class="fa fa-exchange" th:text="' '+#{addbk}"></i>
                                    </a>
                                    <a class="btn btn-primary-custom" data-target="#myModal2" data-toggle="modal" id="MainNavHelp" href="#myModa2">
                                        <i class="fa fa-times" th:text="' '+#{deletelist}"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="panel-body">
                                <div class="table-responsive col-md-12">
                                    <table id="enduser-table" class="display table table-fixed table-striped " cellspacing="0" width="100%">
                                        <thead class="thead-search" id="tableth">
                                            <tr>
                                                <th th:text="#{no}" id="id">No.</th>
                                                <th th:text="#{terminal_name}" id="name">사용자명</th>
                                                <th th:text="#{usernum}" id="empno">사원번호</th>
                                                <th th:text="#{mac}" id="mac_address">MAC</th>
                                                <th th:text="#{ipaddress}" id="ip_address">IP주소</th>
                                                <th th:text="#{full_name}" id="full_name"></th>
                                                <th th:text="#{contact}" id="contact"></th>
                                                <th th:text="#{email}" id="email"></th>
                                                <th th:text="#{assetnum}" id="asset_tag">재산번호</th>
                                                <th th:text="#{opt}">설정</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td></td>
                                                <td>
                                                    <div class="btn-group" role="toolbar" aria-label="Toolbar with button groups">
                                                        <button type="button" class="btn btn-success-custom" th:text="#{modify}">수정</button>
                                                        <button type="button" class="btn btn-success-custom" data-toggle="modal" data-target="#delete" th:text="#{delete}">삭제</button>
                                                        <button type="button" class="btn btn-success-custom" data-toggle="modal" data-target="#history" th:text="#{connectlist}" id="viewButton">접속이력</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="modal modal-center fade" id="history" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-50size modal-center" style="width: 60% !important;">
                                <div class="modal-content modal-50size">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                        </button>
                                        <h4 class="modal-title" id="myModalLabel" th:text="#{connectlist}">접속이력</h4>
                                    </div>
                                    <div class="modal-body" id="history_body">
                                        <input id="id" type="hidden" class="form-control" />
                                        <input name="mac_address" id="mac_address" type="hidden" class="form-control" />
                                        <table class="table table-default " id="userHistoryTable">
                                            <thead>
                                                <tr id="tablerh">
                                                    <th th:text="#{switch}+' '+#{name}" id="switch_name">switch_name</th>
                                                    <th th:text="#{switch}+' '+#{ip}" id="switch_ip">switch_ip</th>
                                                    <th th:text="#{portnum}" id="port_no">port_no</th>
                                                    <th th:text="#{switch}+' '+#{ifindex}" id="switch_ifindex">switch_ifindex</th>
                                                    <th th:text="#{switch}+' '+'Mac'" id="switch_mac">switch_mac</th>
                                                    <th th:text="#{switch}+' '+#{assetnum}" id="switch_asset_tag">switch_asset_tag</th>
                                                    <th th:text="#{access}+' '+#{begin}" id="access_begin">access_begin</th>
                                                    <th th:text="#{access}+' '+#{end}" id="access_end">access_end</th>
                                                    <th th:text="#{enduser}+' '+#{name}" id="enduser_name">enduser_name</th>
                                                    <th th:text="#{enduser}+' '+#{mac}" id="enduser_mac">enduser_mac</th>
                                                    <th th:text="#{usedIpAddress}" id="enduser_ip">사용된IP</th>
                                                    <th th:text="#{regIpAddress}" id="reg_ipAddress">등록된IP</th>
                                                    <th th:text="#{enduser}+' '+#{assetnum}" id="enduser_asset_tag">자산번호</th>
                                                    
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr id="tabletr">
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </section>
                <!-- /.content -->
            </div>
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->

</body>

</html>