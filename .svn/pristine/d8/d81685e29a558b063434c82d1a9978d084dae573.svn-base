<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" layout:decorator="layout/default6">

<head>
    <title>simpleEye MainPage</title>
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />
    <!-- Bootstrap 3.3.7 -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/bootstrap/dist/css/bootstrap.min.css" th:href="@{/modules/bootstrap/dist/css/bootstrap.min.css}" />
    <!-- Font Awesome -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/font-awesome/css/font-awesome.min.css" th:href="@{/modules/font-awesome/css/font-awesome.min.css}" />
    <!-- Ionicons -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/Ionicons/css/ionicons.min.css" th:href="@{/modules/Ionicons/css/ionicons.min.css}" />
    <!-- jvectormap -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/modules/jvectormap/jquery-jvectormap.css" th:href="@{/modules/jvectormap/jquery-jvectormap.css}" />
    <!-- theme custom -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/system-white.css" th:href="@{/css/system-white.css}" />
    <!-- AdminLTE Skins. Choose a skin from the css/skins
       folder instead of downloading all of them to reduce the load. -->
    <link rel="stylesheet" type="text/css" media="screen" href="../../static/css/skins/_all-skins.min.css" th:href="@{/css/skins/_all-skins.min.css}" />

    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
  <![endif]-->
    <!-- jQuery 3 -->
    <script src="../../static/modules/jquery/dist/jquery.min.js" th:src="@{/modules/jquery/dist/jquery.min.js}"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="../../static/modules/bootstrap/dist/js/bootstrap.min.js" th:src="@{/modules/bootstrap/dist/js/bootstrap.min.js}"></script>
    <!-- FastClick -->
    <script src="../../static/modules/fastclick/lib/fastclick.js" th:src="@{/modules/fastclick/lib/fastclick.js}"></script>
    <!-- AdminLTE App -->
    <script src="../../static/js/adminlte.min.js" th:src="@{/js/adminlte.min.js}"></script>
    <!-- AdminLTE for demo purposes -->
    <script src="../../static/js/demo.js" th:src="@{/js/demo.js}"></script>
    <!-- Sparkline -->
    <script src="../../static/modules/jquery-sparkline/dist/jquery.sparkline.min.js" th:src="@{/modules/jquery-sparkline/dist/jquery.sparkline.min.js}"></script>
    <!-- jvectormap  -->
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-1.2.2.min.js}"></script>
    <script src="../../static/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js" th:src="@{/modules/plugins/jvectormap/jquery-jvectormap-world-mill-en.js}"></script>
    <!-- SlimScroll -->
    <script src="../../static/modules/jquery-slimscroll/jquery.slimscroll.min.js" th:src="@{/modules/jquery-slimscroll/jquery.slimscroll.min.js}"></script>
    <!-- ChartJS -->
    <script src="../../static/modules/Chart.js/Chart.js" th:src="@{/modules/Chart.js/Chart.js}"></script>
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="../../static/js/pages/dashboard2.js" th:src="@{/js/pages/dashboard2.js}"></script>
    <script type="text/javascript" th:inline="javascript">
        /*<![CDATA[*/
        $(document).ready(function() {

            $.ajax({
                url: '/api/htbackend/getSubRegion',
                dataType: 'text',
                method: 'get',
                success: function success(r) {
                    console.log(r);
                    var rspns = eval(r);
                    //fill country
                    $("#country option").remove(); // Remove all <option> child tags.
                    $("#country").append( // Append an object to the inside of the select box
                        $("<option></option>") // Yes you can do this.
                        .text('--- Select ---')
                        .val('NONE')
                    );
                    $.each(rspns, function(index, item) { // Iterates through a collection
                        $("#country").append( // Append an object to the inside of the select box
                            $("<option></option>") // Yes you can do this.
                            .text(item.name)
                            .val(item.id)
                        );
                    });
                }
            }); //ajax//
        });

        $(document).on("click", "#createBtn", function() {
            var x = document.getElementById("createRegion");

            if ($(country).val() == "NONE") {
                $('#createRegion #country').remove();
            }

            var createregion = $("#createRegion").serialize();
            //var parent_id = if $(country).val();
            console.log(createregion);
            $.ajax({
                url: '/api/htbackend/addRegion',
                dataType: 'text',
                contentType: 'application/x-www-form-urlencoded',
                data: createregion,
                method: 'post',
                success: function success(r) {
                    $("#addRegion").modal("hide");
                    setTimeout("location.reload();", 100);
                }
            });
        }); /* 생성버튼 클릭시 ajax 방식으로 데이터 인서트 */

        $(document).on("click", "#deleteCityBtn", function() {
            var cityId = $(this).attr('city-id');
            var cityName = $(this).attr('city-name');
            console.log(cityId);
            $(".modal-body #city_id").val(cityId);
            $(".modal-body #city_name").val(cityName);
            //도시삭제 버튼 클릭시 삭제모달 실행//
            $(document).on("click", "#deleteCity", function() {
                var y = document.getElementById("deletecityModal");
                var deletecityModal = $("#deletecityModal").serialize();
                //var parent_id = if $(country).val();
                $.ajax({
                    url: '/api/htbackend/deleteRegion/' + $(".modal-body #city_id").val(),
                    dataType: 'text',
                    contentType: 'application/x-www-form-urlencoded',
                    data: deletecityModal,
                    method: 'get',
                    success: function success(r) {
                        var result = JSON.parse(r).Result;
                        if (result === 'Failure') {
                            alert("Not able to delete City " + $(".modal-body #city_name").val());
                        }
                        $("#deletecityModal").modal("hide");
                        setTimeout("location.reload();", 100);
                    }
                });
            });
        }); /* 생성버튼 클릭시 ajax 방식으로 도시 데이터 딜리트 */

        $(document).on("click", "#deleteCountryBtn", function() {
            var countryId = $(this).attr('country-id');
            var countryName = $(this).attr('country-name');

            console.log(countryId);
            $(".modal-body #country_id").val(countryId);
            $(".modal-body #country_name").val(countryName);

            //국가삭제 버튼 클릭시 삭제모달 실행//
            $(document).on("click", "#deleteCountry", function() {
                var z = document.getElementById("deletecountryModal");
                var deletecountryModal = $("#deletecountryModal").serialize();
                //var parent_id = if $(country).val();
                $.ajax({
                    url: '/api/htbackend/deleteRegion/' + $(".modal-body #country_id").val(),
                    dataType: 'text',
                    contentType: 'application/x-www-form-urlencoded',
                    data: deletecountryModal,
                    method: 'get',
                    success: function success(r) {
                        var result = JSON.parse(r).Result;
                        if (result === 'Failure') {
                            alert("Not able to delete Country " + $(".modal-body #country_name").val());
                        }
                        $("#deletecountryModal").modal("hide");
                        setTimeout("location.reload();", 100);
                    }
                });
            });
        }); /* 삭제버튼 클릭시 ajax 방식으로 국가 데이터 딜리트 */

        $(document).on("click", "#modifyBtn", function() {
            var countryId = $(this).attr('country-id');
            var countryName = $(this).attr('country-name');
            var cityId = $(this).attr('city-id');
            var cityName = $(this).attr('city-name');
            console.log(countryId);
            $(".modal-body #country_id").val(countryId);
            $(".modal-body #country_name").val(countryName);
            $(".modal-body #city_id").val(cityId);
            $(".modal-body #city_name").val(cityName);
            //변경 버튼 클릭시 변경모달 실행//
            $(document).on("click", "#modifyButton", function() {
                var modifydata = $("#modifyCity").serialize();
                console.log(modifydata);
                //var parent_id = if $(country).val();
                $.ajax({
                    url: '/api/htbackend/updateRegion',
                    dataType: 'text',
                    contentType: 'application/x-www-form-urlencoded',
                    data: modifydata,
                    method: 'post',
                    success: function success(r) {
                        console.log(r)
                        $("#modify").modal("hide");
                        setTimeout("location.reload();", 100);
                    }
                });
            });
        }); /* 변경버튼 클릭시 ajax 방식으로 데이터변경 */
        /*]]>*/
    </script>
    <style>
        .table>thead>tr>th {
            padding: 10px 0;
            line-height: 32px;
        }   
    </style>
</head>

<body>

    <div class="page-wrapper" layout:fragment="content">

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <div class="panel-custom-wrap">
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="subpage-menu-border">
                        <h3 th:text="#{regionopt}" class="title col-sm-6"></h3>
                        <ol class="breadcrumb no-margin-padding col-sm-6  text-right">
                            <li><a href="/cms2/index" th:href="@{/cms2/index.html}"><i class="fa fa-dashboard" th:text="' '+#{cmsopt}"></i></a>
                            </li>
                            <li>
                                <a href="../cms2/setting" th:href="@{../cms2/setting.html}" th:text="#{adminpage}"></a>
                            </li>
                            <li class="active" th:text="#{regionopt}"></li>
                        </ol>
                    </div>
                </section>
                <!-- Main content -->
                <section class="content">
                    <div class="subpage-menu">
                        <div class="panel panel-wrap">
                            <div class="panel-body">
                                <div class="panel-title">
                                    <span class="godo" th:text="#{regionopt}+#{list}">list</span>
                                    <div class="pull-right">
                                        <div class="btn-group" role="group" aria-label="...">
                                            <a type="button" class="btn btn-primary-custom" data-target="#addRegion" data-toggle="modal" id="regionBtn" href="#addRegion"><i class="glyphicon glyphicon-plus" th:text="' '+#{addregion}"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="panel-body">
                                <div class="col-md-12">
                                    <table class="table text-center">
                                        <thead class="thead">
                                            <tr id="tableth">
                                                <th th:text="#{countryname}">국가</th>
                                                <th style="display:none;" th:text="#{no}">No</th>
                                                <th style="display:none;" th:text="#{no}">No</th>
                                                <th th:text="#{cityName}">도시</th>
                                                <th th:modify="#{modify}" style="width:500px;">수정</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr th:each="Hashmap : ${Hashmap}" id="tabletr">
                                                <td th:text="${Hashmap['country_id']}" id="countryId" class="td-country" style="display:none;"></td>
                                                <td th:text="${Hashmap['country_name']}" id="countryName" class="td-country">국가</td>
                                                <td th:text="${Hashmap['city_id']}" id="cityId" class="td-city" style="display:none;"></td>
                                                <td th:text="${Hashmap['city_name']}" id="cityName" class="td-city">도시</td>
                                                <td>
                                                    <div class="btn-group">
                                                        <a class="btn btn-warning-custom" data-target="#modify" data-toggle="modal" id="modifyBtn" href="#modify" th:attr="city-id=${Hashmap['city_id']},country-id=${Hashmap['country_id']},
								city-name=${Hashmap['city_name']},country-name=${Hashmap['country_name']}" th:text="#{modify}"></a>
                                                        <a class="btn btn-danger-custom" data-target="#deletecountryModal" data-toggle="modal" id="deleteCountryBtn" href="#deletecountryModal" th:attr="country-id=${Hashmap['country_id']},country-name=${Hashmap['country_name']}" th:text="#{countryname}+' '+#{delete}"></a>
                                                        <a class="btn btn-success-custom" data-target="#deletecityModal" data-toggle="modal" id="deleteCityBtn" href="#deletecityModal" th:attr="city-id=${Hashmap['city_id']},city-name=${Hashmap['city_name']}" th:text="#{cityName}+' '+#{delete}"></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <!-- 지역생성 -->
                                    <div class="modal fade" id="addRegion" tabindex="-1" role="dialog" aria-labelledby="addRegionLabel" aria-hidden="true">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                                    </button>
                                                    <h4 class="modal-title" id="addRegionLabel" th:text="#{region}"></h4>
                                                </div>
                                                <div class="modal-body text-center">
                                                    <form class="form-horizontal" accept-charset="UTF-8" role="form" method="post" id="createRegion">
                                                        <div class="form-group">
                                                            <label class="col-md-2" for="country" th:text="#{countryname}">parent</label>
                                                            <div class="col-md-10">
                                                                <select id="country" name="parent_id" class="form-control">
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="form-group">
                                                            <label class="col-sm-2" for="name" th:text="#{name}">name</label>
                                                            <div class="col-sm-10">
                                                                <input name="name" id="name" type="text" class="form-control" />
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-primary-custom" id="createBtn" th:text="#{create}">create</button>
                                                    <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}"></button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 지역변경모달 -->
                                    <div class="modal fade" id="modify" tabindex="-1" role="dialog" aria-labelledby="modifyLabel" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                                    </button>
                                                    <h4 class="modal-title" id="modifyLabel">Region</h4>
                                                </div>
                                                <div class="modal-body row">
                                                    <form class="form-horizontal col-sm-12" accept-charset="UTF-8" id="modifyCity" role="form" method="post">
                                                        <div class="form-group col-md-12">
                                                            <label class="col-sm-2" for="parent_id" th:text="#{countryname}">parent</label>
                                                            <input type="hidden" id="country_id" name="parent_id" />
                                                            <div class="col-sm-10">
                                                                <input type="text" id="country_name" class="form-control" readonly="readonly" />
                                                            </div>
                                                        </div>
                                                        <div class="form-group col-md-12">
                                                            <label class="col-sm-2" for="name" th:text="#{cityName}">name</label>
                                                            <div class="col-sm-10">
                                                                <input type="hidden" id="city_id" name="id" />
                                                                <input type="text" id="city_name" name="name" class="form-control" />
                                                            </div>
                                                        </div>
                                                    </form>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-primary-custom" id="modifyButton" th:text="#{modify}">modify</button>
                                                    <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">cancle</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 도시삭제 모달 -->
                                    <div class="modal fade" id="deletecityModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                                    </button>
                                                    <h4 class="modal-title" id="myModalLabel" th:text="#{delete}">삭제</h4>
                                                </div>
                                                <form accept-charset="UTF-8" role="form" method="get" id="deleteForm">
                                                    <div class="modal-body">
                                                        <input type="hidden" name="city_id" id="city_id" />
                                                        <span th:text="#{citydel}">삭제하시겠습니까?</span>
                                                    </div>
                                                </form>
                                                <div class="modal-footer">
                                                    <button type="submit" class="btn btn-primary-custom" id="deleteCity" th:text="#{delete}">삭제</button>
                                                    <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 국가삭제 모달 -->
                                    <div class="modal fade" id="deletecountryModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span>
                                                    </button>
                                                    <h4 class="modal-title" id="myModalLabel" th:text="#{delete}">삭제</h4>
                                                </div>
                                                <form accept-charset="UTF-8" role="form" method="get" id="deleteForm">
                                                    <div class="modal-body">
                                                        <input type="hidden" name="country_id" id="country_id" />
                                                        <span th:text="#{countrydel}+' '+#{countrydel2}">삭제하시겠습니까?</span>
                                                    </div>
                                                </form>
                                                <div class="modal-footer">
                                                    <button type="submit" class="btn btn-primary-custom" id="deleteCountry" th:text="#{delete}">삭제</button>
                                                    <button type="button" class="btn btn-default" data-dismiss="modal" th:text="#{cancel}">취소</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- /.content -->
            </div>
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->
</body>

</html>