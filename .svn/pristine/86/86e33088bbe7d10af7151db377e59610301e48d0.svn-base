});

var SwitchBuild = function () {
	function SwitchBuild(cms) {
		classCallCheck(this, SwitchBuild);

		this.cms = cms;
		this.NMS_URL = 'http://localhost/';
		this.init();
	}

	createClass(SwitchBuild, [{
		key: 'init',
		value: function init() {
			var _this = this;

			var cms = this.cms,
			    mainBorder = this.mainBorder = new ht.widget.BorderPane(),
			    formPane = this.formPane = new FormPane(),
			    tablePane = this.tablePane = new ht.widget.TablePane(),
			    noDataDiv = this.noDataDiv = ht.Default.createDiv(),
			    portGv = this.portGv = new ht.graph.GraphView(),
			    topoGv = this.topoGv = new ht.graph.GraphView(),
			    topBorder,
			    btnGv,
			    innerBorder;


			if (cms.isViewing) {
				this.getOPMUrlBase();
				topBorder = this.topBorder = new ht.widget.BorderPane();
				innerBorder = this.innerBorder = new ht.widget.BorderPane();
				btnGv = this.btnGv = new ht.graph.GraphView();

				topBorder.setCenterView(portGv);
				topBorder.setRightView(btnGv);
				topBorder.setRightWidth(180);
				var toggle = this.toggleBtn = new ht.Node(),
				    regBtn = this.regBtn = new ht.Node(),
				    nmsBtn = this.nmsBtn = new ht.Node();

				btnGv.setInteractors([]);
				btnGv.getView().addEventListener('click', function (e) {
					var btn = btnGv.getDataAt(e);
					if (btn === toggle && toggle.a('target')) {
						var port = _this.portGv.sm().ld(),
						    portInfo = port.a('portInfo'),
						    opm_name = _this.data.a('entityParam').opm_name;
						if (portInfo && opm_name) {
							var url = API_HEAD + 'manageSwitchPort?opm_name=' + opm_name + '&ifindex=' + portInfo.ifindex + '&req_id=' + (portInfo.ifadminstatus === 1 ? 'port_down' : 'port_up');
							loading.show(_this.getView());
							util.ajax({
								url: url,
								success: function success(r) {
									loading.hide();
									tipWin.show(r);
									
								}
							});
						}
					} else if (btn === regBtn) {
						var _port = _this.portGv.sm().ld(),
						    _portInfo = _port.a('portInfo'),
						    _opm_name = _this.data.a('entityParam').opm_name;
						if (_portInfo && _opm_name) {
							var left = window.innerWidth / 2 - 600 / 2,
							    top = 100;
							//top   = ((window).innerHeight/2)-(630/2);
							//open new windows with client_ip parameter
							window.open('/api/endUserRegistration3?switch_mac=' + _portInfo.mac_address, 'targetWindow', 'toolbar=no, location=no, status=no, menubar=no, scrollbars=no, resizable=yes, top=' + top + ', left=' + left + ', width=600, height=630');
							/*
       let url = `${API_HEAD}getUnAuthInfoBySWMac?opm_name=${opm_name}&mac_address=${portInfo.mac_address}`;
       loading.show(this.getView());
       util.ajax({
       	url,
       	success: r => {
       		loading.hide();
       		if(r.error){
       			tipWin.show(r.error);
       		}else{
       			var client_ip = r.result;
       			var left  = ((window).innerWidth/2)-(600/2),
       			top = 100;
       		    //top   = ((window).innerHeight/2)-(630/2);
       			//open new windows with client_ip parameter
       			window.open(`/api/endUserRegistration2?switch_mac=${portInfo.mac_address}`,'targetWindow','toolbar=no, location=no, status=no, menubar=no, scrollbars=no, resizable=yes, top='+top+', left='+left+', width=600, height=630');
       		}
       		}
       });*/
						}
					} else if (btn === nmsBtn) {
						var _opm_name2 = _this.data.a('entityParam').opm_name;
						window.open(NMS_URL + 'apiclient/ember/index.jsp#/Inventory/Snapshot/MonitoringDevice/' + _opm_name2);
						//window.open(this.NMS_URL +`apiclient/ember/index.jsp#/Inventory/Snapshot/MonitoringDevice/${opm_name}`);
					}
				});
				nmsBtn.setImage('icon.nms');
				nmsBtn.p(0, 40);
				regBtn.setImage('icon.reguser');
				regBtn.p(0, 20);
				toggle.setImage('icon.portnormal');
				toggle.s({
					// 'opacity': 0,
					'select.width': 0

