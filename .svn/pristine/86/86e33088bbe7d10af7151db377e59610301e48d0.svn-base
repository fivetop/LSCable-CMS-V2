	}, {
		key: 'setData',
		value: function setData(data) {

			if (!data || this.data === data) {
				return;
			}
			this.formPane.reset();

			var nodeid = this.nodeid = data.a('node_id');
			this.data = this.Rack3dBuild.getTreeNodeByNodeid(nodeid);
			this.loadDatas(nodeid);
		}
	}, {
		key: 'loadDatas',
		value: function loadDatas(id) {
			var _this4 = this;

			var form = this.formPane;
			loading.show(this.getView());
			util.ajax({
				url: API_HEAD + 'getSiteTreeNodeDetail/' + id,
				success: function success(r) {
					loading.hide();
					if (r && r[0]) {
						var obj = r[0];
						for (var key in obj) {
							var item = form.getItemById(key);
							if (item) {
								if (item.element instanceof ht.widget.Image && obj[key]) {
									item.element.setIcon(obj[key]);
								} else {
									form.v(key, obj[key]);
								}
							}
						}
						_this4.loadPorts(id, form.v('total_port'));
					}
				},
				error: function error(s) {
					tipWin.show(s);
					loading.hide();
				}
			});
		}
	}, {
		key: 'loadPorts',
		value: function loadPorts(nodeid, totalPort) {
			var _this5 = this;

			this.createPorts(totalPort);
			this.getNetworkNodePortStatus(nodeid);
			this.getRealtimeAlarm(this.data.a('entityParam').opm_name);
			if (this._portStatusTimer) {
				clearInterval(this._portStatusTimer);
			}
			this._portStatusTimer = setInterval(function () {
				_this5.getNetworkNodePortStatus(nodeid);
				_this5.getRealtimeAlarm(_this5.data.a('entityParam').opm_name);
			}, POLLING_PERIOD / 2 * 1000);
		}
	}, {
		key: 'getRealtimeAlarm',
		value: function getRealtimeAlarm(source) {
			var alarmTable = this.alarmTable,
			    noDataDiv = this.noDataDiv;
			//complete = 0;
			//loading.show(innerBorder.getView());

			util.ajax({
				url: API_HEAD + 'getRealtimeAlarmList?source=' + source,
				success: function success(r) {
					/*if (++ complete == 2) {
         loading.hide();
     }*/
					var dm = alarmTable.getDataModel();
					if (r && r.length > 0) {
						if (noDataDiv.parentNode === alarmTable.getView()) {
							alarmTable.getView().removeChild(noDataDiv);
						}
						dm.clear();
						r.forEach(function (d) {
							var data = new ht.Data();
							data.a(d);
							dm.add(data);
						});
					} else if (noDataDiv.parentNode !== alarmTable.getView()) {
						dm.clear();
						alarmTable.getView().appendChild(noDataDiv);
					}
				}
			});
		}
	}, {
		key: 'getSwitchPortUsageHistory',
		value: function getSwitchPortUsageHistory(switch_node_id, portname) {
			var portTable = this.portTable,
			    noDataAvaiable = this.noDataAvaiable,
			    portPage = this.portPage,
			    self = this;

			util.ajax({
				url: API_HEAD + 'getSwitchPortUsageHistory/' + switch_node_id + '?portname=' + portname,
				success: function success(r) {
					var targetDm = portTable.getDataModel();
					var portDm = self.portDm = new ht.DataModel();
					if (r && r.length > 0) {
						var i = 0;
						if (noDataAvaiable.parentNode === portTable.getView()) {
							portTable.getView().removeChild(noDataAvaiable);
						}

						r.forEach(function (d) {
							var data = new ht.Data();
							data.a(d);
							portDm.add(data);
						});
						self.showTable(portDm, targetDm, i);
						portPage.getView().addEventListener('click', function (e) {
							var data = portPage.getDataAt(e);
							if (data.a('type') === 'next' && i + 10 < portDm.size()) {
								self.showTable(portDm, targetDm, i += 10);
							} else if (data.a('type') === 'previous' && i - 10 >= 0) {
								self.showTable(portDm, targetDm, i -= 10);
							}
						});
					} else if (noDataAvaiable.parentNode !== portTable.getView()) {
						portDm.clear();
						portTable.getView().appendChild(noDataAvaiable);
					}
				}
			});
		}
	}, {
		key: 'showTable',
		value: function showTable(dm, targetDm, i) {
			if (dm) {
				targetDm.clear();
				dm.toDatas().forEach(function (d, index) {
					if (index >= i && index < i + 10) {
						var data = new ht.Data();
						data.setAttrObject(d.getAttrObject());
						targetDm.add(data);
					}
				});
			}
		}
	}, {
		key: 'getNetworkNodePortStatus',
		value: function getNetworkNodePortStatus(nodeid) {
			var _this6 = this;

			util.ajax({
				url: API_HEAD + 'getNetworkNodePortStatus/' + nodeid,
				success: function success(r) {

					if (r) {
						r.forEach(function (item) {
							var node = _this6.portMap[item.portname];
							if (!node) return;
							node.a('status', item.ifoperstatus);
							if (item.uplink) {
								node.a('linkinfo', 1);
							} else if (item.downlink) {
								node.a('linkinfo', 2);
							}
							node.a('portInfo', item);
							var ifadmin = 'DOWN',
							    ifoper = 'DOWN';
							if (item.ifadminstatus == 1) ifadmin = 'UP';
							if (item.ifoperstatus == 1) ifoper = 'UP';
							node.setToolTip('\n\t\t\t\t\t\t<p>Interface Name: ' + item.ifname + '</p>\n\t\t\t\t\t\t<p>Mac Address: ' + item.mac_address + '</p>\n\t\t\t\t\t\t<p>Description: ' + item.description + '</p>\n\t\t\t\t\t\t<p>Interface Index: ' + item.ifindex + '</p>\n\t\t\t\t\t\t<p>Administation Status: ' + ifadmin + '</p>\n\t\t\t\t\t\t<p>Operation Status: ' + ifoper + '</p>');
						});
					}
				}
			});
		}
	}, {
		key: 'createPorts',
		value: function createPorts(totalPort) {
			var node = void 0,
			    cms = this.cms,
			    dm = this.portGv.dm(),
			    i = 0,
			    x = 0,
			    y = 0;


			this.portMap = {};
			dm.clear();

			for (; i < totalPort; i++) {
				node = new ht.Node();
				node.setImage('switch.portLinkInfo');
				node.a({
					'status': 0,
					'rotation': 0,
					//'linkinfo': 1,
					'portname': i + 1
				});
				node.s({
					label: i + 1,
					'label.position': totalPort <= 12 || i % 2 === 0 ? 3 : 31,
					'2d.movable': false
				});
				if (totalPort > 12) {
					if (i % 2 === 1) {
						node.setRotation(Math.PI);
						node.a({
							'rotation': Math.PI
						});
					}
				}
				node.p(x, y);
				dm.add(node);
				this.portMap[i + 1] = node;
				if (totalPort <= 12) {
					if (i && (i + 1) % 6 === 0) {
						x += 36 + PORT_GAP$2;
					}
					if (i && (i + 1) % 12 === 0) {
						x = 0;
						y += 36;
					}
					x += node.getWidth() + PORT_GAP$2;
				} else {
					if (i % 2 === 0) {
						y = 36 + PORT_GAP$2;
					} else if (i && i % 2 === 1) {
						y = 0;
						x += node.getWidth() + PORT_GAP$2;
					}
					if ((i + 1) % 12 === 0) {
						x += 36;
					}
				}
			}
			if (totalPort > 4) this.portGv.fitContent(true, 5);else this.portGv.fitContent(true, 5, true);
		}
	}, {
		key: 'handlePortSelect',
		value: function handlePortSelect() {
			var portTable = this.portTable,
			    noDataAvaiable = this.noDataAvaiable;

			var ld = this.portGv.sm().ld();
			this.topoGv.dm().clear();
			if (!ld) {
				portTable.getDataModel().clear();
				if (noDataAvaiable.parentNode === portTable.getView()) {
					portTable.getView().removeChild(noDataAvaiable);
				}
