				btnGv.dm().add(toggle);
				btnGv.dm().add(regBtn);
				btnGv.dm().add(nmsBtn);
				btnGv.fitContent();

				var style = noDataDiv.style;
				style.top = 0;
				style.left = 0;
				style.right = 0;
				style.bottom = 0;
				style.textAlign = 'center';
				style.fontSize = '18px';
				style.fontFamily = 'Godo';
				style.fontWeight = 'bold';
				style.paddingTop = ' 50px';

				noDataDiv.innerText = 'No Alarms';

				tablePane.addColumns([{ tag: 'severity', name: 'severity', displayName: '장애등급', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {
						var image = ht.Default.getImage('/images/severity_' + data.a('severity') + '.png');
						ht.Default.drawStretchImage(g, image, 'centerUniform', x, y, w, h);
					} }, { tag: 'displayname', name: 'displayname', displayName: '장비명', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {

						ht.Default.drawText(g, data.a('displayname'), '11px Godo', 'black', x, y, w, h, 'center', 'middle');
					} }, { tag: 'message', name: 'message', displayName: '장애내역', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {

						ht.Default.drawText(g, data.a('mmessage'), '11px Godo', 'black', x, y, w, h, 'left', 'middle');
					} }, { tag: 'modtime', name: 'modtime', displayName: '발생시간', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {
						var d = new Date(data.a('modtime'));
						var n = d.toLocaleString();
						//ht.Default.drawStretchImage(g, image, 'centerUniform', x, y, w, h);
						ht.Default.drawText(g, n, '11px Godo', 'black', x, y, w, h, 'left', 'middle');
					} }, { tag: 'eventype', name: 'eventtype', displayName: '장애유형', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {

						ht.Default.drawText(g, data.a('eventtype'), '11px Godo', 'black', x, y, w, h, 'left', 'middle');
					} }, { tag: 'location', name: 'location', displayName: '장소', align: 'center', accessType: 'attr',
					drawCell: function drawCell(g, data, selected, column, x, y, w, h, view) {
						var location = '-';
						if (data.a('location')) {
							var loc = data.a('location').split(">>");
							if (loc.length > 0) {
								loc.splice(0, 1);
								location = loc.join(" - ");
							}
						}
						//ht.Default.drawStretchImage(g, image, 'centerUniform', x, y, w, h);
						ht.Default.drawText(g, location, '11px Godo', 'black', x, y, w, h, 'left', 'middle');
					} }]);
				tablePane.getTableHeader().setResizable(true);
				tablePane.getTableHeader().getView().style.background = 'rgba(68, 73, 91, 0.8)';
				tablePane.getTableHeader().getLabelFont = function (column) {
					return 'bold 12px Godo';
				};
				tablePane.getTableHeader().getLabelColor = function (column) {
					return 'white';
				};
				tablePane.addViewListener(function (e) {
					if (e.kind === 'beginValidate') {
						var columnModel = tablePane.getColumnModel(),
						    width = tablePane.getWidth();
						columnModel.getDataByTag('severity').setWidth(width * 0.1);
						columnModel.getDataByTag('displayname').setWidth(width * 0.1);
						columnModel.getDataByTag('message').setWidth(width * 0.3);
						columnModel.getDataByTag('modtime').setWidth(width * 0.15);
						columnModel.getDataByTag('eventype').setWidth(width * 0.08);
						columnModel.getDataByTag('location').setWidth(width * 0.27);
					}
				});
				tablePane.getTableView().onDataClicked = function (data) {
					var event_type = data.a('entity');
					window.open(NMS_URL + 'apiclient/ember/index.jsp#/Alarms/Alarm/Details/' + event_type);
				};

				var tableView2 = tablePane.getTableView();
				//tableView2.setSelectBackground('#6DCDF3');
				tableView2.setRowLineColor('#EDEDED');
				//tableView2.setColumnLineVisible(false);                
				//tableView2.setRowHeight(24);
				tableView2.setAutoHideScrollBar(false);
				tableView2.drawRowBackground = function (g, data, selected, x, y, width, height) {
					if (selected) {
						g.fillStyle = '#87A6CB';
					} else if (tableView2.getRowIndex(data) % 2 === 0) {
						g.fillStyle = "rgba(207,213,234, 0.3)";
					} else {
						g.fillStyle = "rgba(233,235,245, 0.3)";
					}
					g.beginPath();
					g.rect(x, y, width, height);
					g.fill();
				};
				innerBorder.setTopView(formPane);
				innerBorder.setTopHeight(240);
				innerBorder.setLeftView(this.createDiv('#FFFFFF'), 30);
				innerBorder.setRightView(this.createDiv('#FFFFFF'), 30);
				innerBorder.setCenterView(tablePane);
			}

			mainBorder.setCenterView(cms.isViewing ? innerBorder : formPane);
			mainBorder.setTopView(cms.isViewing ? topBorder : portGv);
			mainBorder.setBottomView(topoGv);
			mainBorder.setTopHeight(128);
			mainBorder.setBottomHeight(220);

			portGv.enableToolTip();
			var topView = cms.isViewing ? topBorder.getView() : portGv.getView();
			topView.style.borderBottom = '1px solid #066086';
			portGv.setInteractors([new ht.graph.SelectInteractor(portGv)]);

			topoGv.enableToolTip();
			topoGv.getView().style.borderTop = '1px solid #066086';
			topoGv.setInteractors([new ht.graph.SelectInteractor(topoGv)]);

			topoGv.fitContent(1);

			portGv.sm().ms(this.handlePortSelect, this);

			this.initForm();
		}
	}, {
		key: 'getOPMUrlBase',
		value: function getOPMUrlBase() {
			var self = this;
			util.ajax({
				url: API_HEAD + 'getOPMUrlBase',
				success: function success(r) {
					if (r && r.url) self.NMS_URL = r.url;
				}
			});
		}
	}, {
		key: 'createDiv',
		value: function createDiv(background, text) {
			var div = document.createElement('div');
			div.style.position = 'absolute';
			div.style.background = background;
			if (text) div.innerHTML = text;
			return div;
		}
	}, {
		key: 'initForm',
		value: function initForm() {
			var self = this,
			    form = self.formPane,
			    itemWidths = [itemWidth, ctrlWidth];

			form.setVPadding(36);
			form.setHPadding(46);
			var formItems = [];
