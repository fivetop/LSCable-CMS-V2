		key: 'createPageView',
		value: function createPageView() {
			var gv = new ht.graph.GraphView();
			gv.setInteractors([new ht.graph.SelectInteractor(gv)]);

			var previousBtn = this.previousBtn = new ht.Node(),
			    nextBtn = this.nextBtn = new ht.Node();

			gv.dm().add(previousBtn);
			previousBtn.setSize(30, 30);
			previousBtn.setPosition(30, 15);
			previousBtn.a('type', 'previous');
			previousBtn.s('select.width', 0);
			previousBtn.setImage('./imgs/previous.json');

			gv.dm().add(nextBtn);
			nextBtn.setSize(30, 30);
			nextBtn.setPosition(80, 15);
			nextBtn.a('type', 'next');
			nextBtn.s('select.width', 0);
			nextBtn.setImage('./imgs/next.json');

			return gv;
		}
	}, {
		key: 'createDiv',
		value: function createDiv(background, text, exportMenu) {
			var _this3 = this;

			//var self = this;
			var div = document.createElement('div');
			div.style.position = 'absolute';
			div.style.background = background;
			if (text) {
				var title = document.createElement('div');
				div.appendChild(title);
				title.innerHTML = text;
				title.style.position = 'absolute';
				title.style.top = 0;
				title.style.left = 0;
				title.style.width = '100px';
				title.style.height = '25px';
				title.style.fontSize = '11px';
				title.style.fontFamily = 'Godo';
				title.style.textAlign = 'center';
				title.style.lineHeight = '25px';
				title.style.background = '#EEEEEE';
				//title.style.border = '2px solid #008080'
			}
			if (exportMenu) {
				var menu = document.createElement('div');
				div.appendChild(menu);
				menu.innerHTML = 'Export';
				menu.style.position = 'absolute';
				menu.style.top = '10px';
				menu.style.right = '40px';
				menu.style.width = '50px';
				menu.style.height = '20px';
				menu.style.fontSize = '11px';
				menu.style.fontFamily = 'Godo';
				menu.style.textAlign = 'center';
				menu.style.lineHeight = '20px';
				menu.style.color = 'white';
				menu.style.background = '#00BFFF';
				menu.onclick = function () {
					_this3.handleExport();
				};
			}
			return div;
		}
	}, {
		key: 'handleExport',
		value: function handleExport() {
			var cm = this.portTable.getColumnModel(),
			    dm = this.portDm,
			    content = '';
			if (dm.size() === 0) return;

			cm.each(function (col) {
				content += col.getDisplayName() + ',';
			});
			content.substring(0, content.length - 1);
			content += '\n';

			dm.each(function (data) {
				var attr = data.getAttrObject();
				var switch_name = attr.switch_name,
				    switch_ip = attr.switch_ip,
				    switch_port_no = attr.switch_port_no,
				    switch_ifindex = attr.switch_ifindex,
				    switch_mac_address = attr.switch_mac_address,
				    switch_asset_tag = attr.switch_asset_tag,
				    access_begin = attr.access_begin,
				    access_end = attr.access_end,
				    enduser_name = attr.enduser_name,
				    enduser_mac_address = attr.enduser_mac_address,
				    enduser_ip_address = attr.enduser_ip_address,
				    enduser_asset_tag = attr.enduser_asset_tag;

				content += [switch_name, switch_ip, switch_port_no, switch_ifindex, switch_mac_address, switch_asset_tag, access_begin, access_end, enduser_name, enduser_mac_address, enduser_ip_address, enduser_asset_tag].join(',');
				content += '\n';
			});
			util.exportAndDownload(content, this.data.getName() + '-' + this.currentPort + '.csv');
		}
