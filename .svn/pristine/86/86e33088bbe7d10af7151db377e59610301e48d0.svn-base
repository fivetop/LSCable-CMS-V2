	}, {
		key: 'handleSave',
		value: function handleSave() {
			var ld = this.data,
			    form = this.formPane,
			    data = {
				siteTreeParam: ld.a('siteTreeParam'),
				entityParam: ld.a('entityParam')
			};
			data.entityParam.asset_tag = form.v('asset_tag');
			data.entityParam.comments = form.v('comments');
			data.entityParam.ip = form.v('ip');
			data.entityParam.opm_category = form.v('opm_category');
			data.entityParam.opm_name = form.v('opm_name');
			data.entityParam.displayname = form.v('displayname');

			loading.show();
			this.cms.updateSiteTreeNodeDetail(this.data, data, function (r) {
				loading.hide();
				tipWin.show('Save Success');
			});
		}
	}, {
		key: 'handleRemove',
		value: function handleRemove() {
			this.cms.remove();
		}
	}, {
		key: 'handleResync',
		value: function handleResync() {
			var ld = this.data,
			    form = this.formPane,
			    data = {
				siteTreeParam: ld.a('siteTreeParam'),
				entityParam: ld.a('entityParam')
			};

			loading.show();
			this.cms.resyncWithNMS(this.data, data, function (r) {
				loading.hide();
				tipWin.show('Resync Success [' + data.entityParam.opm_name + ']');
			});
		}
	}, {
		key: 'setData',
		value: function setData(data) {

			if (!data || this.data === data) {
				return;
			}
			this.data = data;
			this.formPane.reset();

			var nodeid = util.getNodeId(data);
			this.loadDatas(nodeid);
			// this.loadPorts(nodeid);
			// this.iv();
		}
	}, {
		key: 'loadDatas',
		value: function loadDatas(id) {
			var _this2 = this;

			var form = this.formPane;
			loading.show(this.getView());
			util.ajax({
				url: API_HEAD + 'getSiteTreeNodeDetail/' + id,
				success: function success(r) {
					loading.hide();
					if (r && r[0]) {
						var obj = r[0];
						for (var key in obj) {
							var item = form.getItemById(key);
							if (item) {
								if (item.element instanceof ht.widget.Image && obj[key]) {
									item.element.setIcon(obj[key]);
								} else {
									form.v(key, obj[key]);
								}
							}
						}
						_this2.loadPorts(id, form.v('total_port'));
					}
				},
				error: function error(s) {
					tipWin.show(s);
					loading.hide();
				}
			});
		}
		//	iv (){
		//	}

	}, {
		key: 'loadPorts',
		value: function loadPorts(nodeid, totalPort) {
			var _this3 = this;

			this.createPorts(totalPort);
			this.getNetworkNodePortStatus(nodeid);
			if (this.cms.isViewing) {
				this.getRealtimeAlarm(this.data.a('entityParam').opm_name);
				if (this._portStatusTimer) {
					clearInterval(this._portStatusTimer);
				}
				this._portStatusTimer = setInterval(function () {
					_this3.getNetworkNodePortStatus(nodeid);
					_this3.getRealtimeAlarm(_this3.data.a('entityParam').opm_name);
				}, POLLING_PERIOD / 2 * 1000);
			}
		}
	}, {
		key: 'getRealtimeAlarm',
