		key: 'initDialog',
		value: function initDialog() {
			var _this5 = this;

			var dialog = this.dropDialog = new ht.widget.Dialog(),
			    form = this.dropDialogForm = new FormPane();

			form.setHPadding(30);
			form.setVPadding(24);

			dialog.setConfig({
				title: "Floor Map Select",
				content: form,
				width: 410,
				height: 180,
				draggable: true,
				closable: true,
				resizeMode: "wh",
				buttons: [{
					label: "Ok",
					action: function action(button, e) {
						_this5.handleSelectFloorMapImg();
					}
				}, {
					label: 'Cancel',
					action: function action() {
						/*this.dm.remove(this._lastAdd);
      this._lastAdd = null;
      this.listView.ivm()*/
						dialog.hide();
					}
				}],
				buttonsAlign: "right"
			});

			var formItems = [{
				id: 'floorMapImage',
				label: 'Floor Image',
				comboBox: {
					values: this.floorMapImgs.map(function (d) {
						return d.filename;
					}),
					labels: this.floorMapImgs.map(function (d) {
						return d.filename;
					})
				}
			}];
			var itemWidths = [80, 0.1];

			form.addFormItems(formItems, itemWidths, 26);
		}
	}, {
		key: 'handleSelectFloorMapImg',
		value: function handleSelectFloorMapImg() {
			var form = this.dropDialogForm,
			    dialog = this.dropDialog,
			    mapImg = form.v('floorMapImage');
			var self = this,
			    background = this.gv.dm().getDataByTag('background');
			background.setImage(mapImg);
			background.setSize(-1, -1);
			dialog.hide();
		}
