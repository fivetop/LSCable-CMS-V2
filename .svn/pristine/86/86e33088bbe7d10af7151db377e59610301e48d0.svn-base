				form.addRow(['', {
					button: {
						label: 'Save',
						background: btnBackground,
						borderColor: btnBorderColor,
						labelColor: btnLabelColor,
						onClicked: self.handleSave.bind(self)
					}
				}, {
					button: {
						label: 'Remove',
						background: btnBackground,
						borderColor: btnBorderColor,
						labelColor: btnLabelColor,
						onClicked: self.handleRemove.bind(self)
					}
				}, {
					button: {
						label: 'Re-Sync',
						background: btnBackground,
						borderColor: btnBorderColor,
						labelColor: btnLabelColor,
						onClicked: self.handleResync.bind(self)
					}
				}, ''], [0.1, 80, 80, 80, 0.1], 30);
