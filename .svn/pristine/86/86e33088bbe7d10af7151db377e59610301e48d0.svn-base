	}, {
		key: 'showComponentDetail',
		value: function showComponentDetail(nodeid, img) {
			var cms = this.cms,
			    borderPane = this.borderPane,
			    propertyView = this.propertyView,
			    propertyDM = this.propertyDM,
			    propertyData = this.propertyData,
			    node = cms.getTreeNodeByNodeid(nodeid),
			    typeName = cms.getNodeTypeNameById(node.a('type'));


			if (MODAL_TYPES$1.indexOf(typeName) >= 0) {
				cms.showDetailDialog(nodeid, img);
				propertyView.getView().style.display = 'none';
			} else {
				propertyView.getView().style.display = 'block';
				if (propertyData.a('nodeid') === nodeid) {
					return;
				}

				var items = this.getPropertyItems(typeName);
				propertyView.setProperties(items.map(function (item) {
					return {
						name: item.id,
						displayName: item.label,
						accessType: 'attr'
					};
				}));
				propertyData.a({ nodeid: nodeid });
				loading.show(propertyView.getView());
				this.cms.loadNodeDetail(node, function (r) {
					loading.hide();
					if (r && r[0]) {
						propertyData.a(r[0]);
					}
				});
			}
		}
	}, {
		key: 'getPropertyItems',
		value: function getPropertyItems(typeName) {
			var itemsMap = this.itemsMap,
			    cms = this.cms,
			    cache = itemsMap[typeName];

			if (!cache) {
				var clazz = getFormClazz(typeName),
				    form = new clazz(cms, cms.siteid, typeName),
				    items = form.formItems;
				itemsMap[typeName] = items;
			}
			return itemsMap[typeName];
		}
	}, {
		key: 'onRemove',
		value: function onRemove(data) {
			var treeNode = data.a('treeNode');
			cms.treeView.dm().remove(treeNode);
		}
